msgstr "Válido desde"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_TO"
msgid "Valid To"
msgstr "Válido hasta"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_CN"
msgid "Common Names (domains)"
msgstr "Nombres comunes (dominios)"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_ISSUER"
msgid "Issued By"
msgstr "Emitido por"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_ERR_DATE_INVALID_HEAD"
msgid "Unknown Validity"
msgstr "Validez desconocida"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_ERR_DATE_INVALID"
msgid "The SSL/TLS certificate lacks valid from/to dates, making it impossible to determine whether it is valid."
msgstr "El certificado SSL/TLS carece de fechas de inicio/fin de validez, lo que hace imposible determinar si es válido."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_TOOSOON_HEAD"
msgid "Invalid (Too Soon)"
msgstr "Inválido (demasiado pronto)"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_TOOSOON"
msgid "The SSL/TLS certificate has a Valid From date in the future. Browsers will report it as invalid as it\'s not meant to be used just yet."
msgstr "El certificado SSL/TLS tiene una fecha de inicio de validez en el futuro. Los navegadores lo reportarán como inválido."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_EXPIRING_HEAD"
msgid "Imminent Expiration"
msgstr "Expiración inminente"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_EXPIRING"
msgid "The SSL/TLS certificate will expire soon. You need to replace it with a new one to prevent problems with your site."
msgstr "El certificado SSL/TLS expirará pronto. Necesita reemplazarlo por uno nuevo antes de que expire."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_EXPIRED_HEAD"
msgid "Expired"
msgstr "Expirado"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_EXPIRED"
msgid "The SSL/TLS certificate has a Valid To date in the past. Browsers will report it as invalid as it\'s not meant to be used any more."
msgstr "El certificado SSL/TLS tiene una fecha de fin de validez en el pasado. Los navegadores lo reportarán como inválido."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_INVALID_CN_HEAD"
msgid "Invalid Domain"
msgstr "Dominio inválido"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_INVALID_CN"
msgid "The SSL/TLS certificate is issued for a different domain name than the one you are using it for. Browsers will report it as invalid."
msgstr "El certificado SSL/TLS está emitido para un nombre de dominio diferente al que está accediendo actualmente."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_INVALID_SIG_HEAD"
msgid "Invalid or Self-signed Certificate"
msgstr "Certificado inválido o autofirmado"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_INVALID_SIG"
msgid "The signature of your SSL/TLS certificate cannot be verified against the Certification Authorities known to the server. This usually means that you are using a self-signed certificate which will be rejected by browsers."
msgstr "La firma de su certificado SSL/TLS no puede verificarse contra la Autoridad Certificadora (CA) conocida."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO"
msgid "Domain Information"
msgstr "Información del dominio"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_ERR_DATE_INVALID_HEAD"
msgid "Unknown Validity"
msgstr "Validez desconocida"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_ERR_DATE_INVALID"
msgid "We could not retrieve the domain\'s expiration date. Either the domain name does not appear in the WHOIS database, or you are using a domain name which only resolves locally."
msgstr "No se pudo recuperar la fecha de expiración del dominio. Es posible que el dominio no exista o que el servidor WHOIS no proporcione esa información."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_TOOSOON_HEAD"
msgid "Invalid (Too Soon)"
msgstr "Inválido (demasiado pronto)"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_TOOSOON"
msgid "The domain registrar claims the domain name was registered in a future date. This does not seem right."
msgstr "El registrador del dominio indica que el nombre de dominio fue registrado en una fecha futura. Esto podría indicar un error en los datos WHOIS."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_EXPIRING_HEAD"
msgid "Imminent Expiration"
msgstr "Expiración inminente"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_EXPIRING"
msgid "The domain name will expire soon. You need to renew it with your registrar to avoid losing it."
msgstr "El nombre de dominio expirará pronto. Necesita renovarlo con su registrador para evitar perder el dominio."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_EXPIRED_HEAD"
msgid "Expired"
msgstr "Expirado"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_EXPIRED"
msgid "The domain name has expired. You might still be able to access the domain due to your registrar\'s grace period, but <strong>you must renew this domain name immediately with your registrar</strong> to avoid losing it."
msgstr "El nombre de dominio ha expirado. Es posible que aún pueda acceder al dominio debido al período de gracia del registrador."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_NONAMESERVERS_HEAD"
msgid "Missing nameservers"
msgstr "Faltan servidores de nombres"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_NONAMESERVERS"
msgid "There are no nameservers reported in the WHOIS database. A site without valid nameservers will not be accessible on the Internet. If you recently assigned nameservers to the domain don\'t panic; it may take up to 5 days for this information to propagate."
msgstr "No hay servidores de nombres reportados en la base de datos WHOIS. Un sitio sin servidores de nombres válidos no funcionará correctamente."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_TABLE_CAPTION"
msgid "Table of domain information"
msgstr "Tabla de información del dominio"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_DOMAIN"
msgid "Domain"
msgstr "Dominio"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_REGISTERED"
msgid "Registered On"
msgstr "Registrado el"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_EXPIRES"
msgid "Expires On"
msgstr "Expira el"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_REGISTRAR"
msgid "Registrar"
msgstr "Registrador"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_NAMESERVERS"
msgid "Nameservers"
msgstr "Servidores de nombres"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_CACHING_NOTICE"
msgid "Domain registration information may be cached in the WHOIS servers for a period ranging from a few hours to a few days. As a result, the information above may be out of date."
msgstr "La información de registro del dominio puede estar almacenada en caché en los servidores WHOIS durante un período determinado."

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_UPTIME_TITLE"
msgid "Very Basic Site Uptime Monitoring"
msgstr "Monitorización básica de disponibilidad del sitio"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_UPTIME_NOTE"
msgid "This is <em>very basic</em> uptime monitoring through Panopticon itself. It only notifies you by email when your site goes down and comes back up. It does not integrate with third party services, it does not offer history, it does not have a public uptime page. We strongly recommend using a third party service or software to monitor your sites\' uptime instead of using this feature."
msgstr "Esta es una monitorización de disponibilidad <em>muy básica</em> a través del propio Panopticon. Solo verifica si el sitio responde a las solicitudes HTTP."

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_UPTIME_ENABLED"
msgid "Monitor Uptime"
msgstr "Monitorizar disponibilidad"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_UPTIME_ENABLED_HELP"
msgid "Disabling this option will no longer send you emails, log site actions, or display badges when your site goes down and comes back up."
msgstr "Desactivar esta opción dejará de enviarle correos electrónicos, registrar acciones del sitio o mostrar el estado de disponibilidad."

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_UPTIME_PATH"
msgid "URL Path To Monitor"
msgstr "Ruta URL a monitorizar"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_UPTIME_STRING"
msgid "Look For This String"
msgstr "Buscar esta cadena"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_UPTIME_STRING_HELP"
msgid "The site will be considered up if the page contains this string. Do <em>NOT</em> use HTML; all tags and multiple whitespaces are removed before evaluating this string. Leave blank to consider any HTTP 2xx response as adequate proof the site is up."
msgstr "El sitio se considerará activo si la página contiene esta cadena. <em>NO</em> debe usar HTML aquí."

#, phpformat
msgctxt "PANOPTICON_SITES_BATCH_TITLE"
msgid "Batch process the selected sites"
msgstr "Procesar en lote los sitios seleccionados"

#, phpformat
msgctxt "PANOPTICON_SITES_BATCH_PROCESS"
msgid "Process"
msgstr "Procesar"

#, phpformat
msgctxt "PANOPTICON_SITES_BATCH_LBL_ADD_TO_GROUP"
msgid "Add to group"
msgstr "Añadir al grupo"

#, phpformat
msgctxt "PANOPTICON_SITES_BATCH_LBL_REMOVE_FROM_GROUP"
msgid "Remove from group"
msgstr "Eliminar del grupo"

#, phpformat
msgctxt "PANOPTICON_SITES_BATCH_COMPLETED"
msgid "The group membership of sites you selected has been processed."
msgstr "Se ha procesado la membresía de grupo de los sitios seleccionados."

#, phpformat
msgctxt "PANOPTICON_SITES_BATCH_ERR_NO_IDS"
msgid "You have not selected any sites to process the group membership of."
msgstr "No ha seleccionado ningún sitio para procesar la membresía de grupo."

#, phpformat
msgctxt "PANOPTICON_SITES_TITLE_READ"
msgid "Site Information"
msgstr "Información del sitio"

#, phpformat
msgctxt "PANOPTICON_ERR_SITES_NOTFOUND"
msgid "Site Record Not Found"
msgstr "Registro de sitio no encontrado"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_REFRESHED_OK"
msgid "The site information has been refreshed."
msgstr "La información del sitio ha sido actualizada."

#, phpformat
msgctxt "PANOPTICON_SITE_ERR_REFRESHED_FAILED"
msgid "The site information refresh has failed: %s"
msgstr "La actualización de la información del sitio ha fallado: %s"

#, phpformat
msgctxt "PANOPTICON_SITE_ERR_COREUPDATESITEFIX_FAILED"
msgid "Could not fix the Joomla Update Site record: %s"
msgstr "No se pudo corregir el registro del sitio de actualización de Joomla: %s"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_EXTENSIONS_REFRESHED_OK"
msgid "The extensions update information has been refreshed."
msgstr "La información de actualizaciones de extensiones ha sido actualizada."

#, phpformat
msgctxt "PANOPTICON_SITE_ERR_EXTENSIONS_REFRESHED_FAILED"
msgid "The extensions update information refresh has failed: %s"
msgstr "La actualización de la información de extensiones ha fallado: %s"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_EXTENSION_UPDATE_SCHEDULE_OK"
msgid "Scheduled the extension update."
msgstr "Se ha programado la actualización de la extensión."

#, phpformat
msgctxt "PANOPTICON_SITE_ERR_EXTENSION_UPDATE_SCHEDULE_FAILED"
msgid "Scheduling the extension update has failed."
msgstr "La programación de la actualización de la extensión ha fallado."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_EXTENSION_UPDATE_SCHEDULE_ERROR_CLEARED"
msgid "The scheduling error has been cleared."
msgstr "El error de programación ha sido borrado."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_EXTENSION_UPDATE_SCHEDULE_ERROR_NOT_CLEARED"
msgid "The scheduling error could not be cleared: %s"
msgstr "No se pudo borrar el error de programación: %s"

#, phpformat
msgctxt "PANOPTICON_SITE_BTN_CMSUPDATE_RELOAD"
msgid "Reload Update information"
msgstr "Recargar información de actualización"

#, phpformat
msgctxt "PANOPTICON_SITE_BTN_CMSUPDATE_RELOAD_SR"
msgid "Reload Update information for site “%s”"
msgstr "Recargar información de actualización para el sitio \"%s\""

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SCHEDULE_OK"
msgid "Scheduled the Joomla core update."
msgstr "Se ha programado la actualización del núcleo de Joomla."

#, phpformat
msgctxt "PANOPTICON_SITE_ERR_JUPDATE_SCHEDULE_FAILED"
msgid "Scheduling the Joomla core update has failed."
msgstr "La programación de la actualización del núcleo de Joomla ha fallado."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SCHEDULE_ERROR_CLEARED"
msgid "The scheduling error has been cleared."
msgstr "El error de programación ha sido borrado."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SCHEDULE_ERROR_NOT_CLEARED"
msgid "The scheduling error could not be cleared: %s"
msgstr "No se pudo borrar el error de programación: %s"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_HEAD"
msgid "Joomla!&reg; Update"
msgstr "Actualización de Joomla!&reg;"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_NO_VERSION_HEAD"
msgid "Version information missing"
msgstr "Falta información de versión"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_NO_VERSION_BODY"
msgid "Your site has not reported the version of Joomla!&reg; it is running on."
msgstr "Su sitio no ha reportado la versión de Joomla!&reg; que está utilizando."

#, phpformat
msgctxt "PANOPTICON_SITE_BTN_JUPDATE_RELOAD"
msgid "Reload Joomla!&reg; Update information"
msgstr "Recargar información de actualización de Joomla!&reg;"

#, phpformat
msgctxt "PANOPTICON_SITE_BTN_JUPDATE_RELOAD_SR"
msgid "Reload Joomla!&reg; Update information for site “%s”"
msgstr "Recargar información de actualización de Joomla!&reg; para el sitio \"%s\""

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_LAST_CHECKED"
msgid "Last checked:"
msgstr "Última comprobación:"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_ERR_JOOMLA_FILES_EXT_MISSING"
msgid "The Joomla! extension record is missing from your site. Joomla! cannot detect whether updates to itself are available."
msgstr "El registro de la extensión de Joomla! no existe en su sitio. Joomla! no puede detectar si hay actualizaciones disponibles sin este registro."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SEEK_HELP_JFORUM"
msgid "Try asking for help on the <a href=\"https://forum.joomla.org\" target=\"_blank\">Joomla! Forum</a>."
msgstr "Intente pedir ayuda en el <a href=\"https://forum.joomla.org\" target=\"_blank\">foro de Joomla!</a>."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_ALT_FIX"
msgid "Alternatively, try clicking the button below."
msgstr "Alternativamente, intente hacer clic en el botón a continuación."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_ERR_UPDATESITE_MISSING"
msgid "The Joomla! Update Site record is missing from your site. Joomla! cannot detect whether updates to itself are available."
msgstr "El registro del sitio de actualización de Joomla! no existe en su sitio. Joomla! no puede detectar actualizaciones disponibles sin este registro."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_UPDATESITE_FIX_J4"
msgid "Go to your site\'s administrator backend, System, Update, Update Sites, and click on the Rebuild button."
msgstr "Vaya al backend de administración de su sitio, Sistema, Actualización, Sitios de actualización y haga clic en el botón de reparación."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_UPDATESITE_FIX_J3"
msgid "Go to your site\'s administrator backend, Extensions, Manage, Update Sites, and click on the Rebuild button."
msgstr "Vaya al backend de administración de su sitio, Extensiones, Gestionar, Sitios de actualización y haga clic en el botón de reparación."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_COREUPDATESITEFIX_BTN"
msgid "Attempt an automatic fix"
msgstr "Intentar una corrección automática"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_AVAILABLE_UPDATE"
msgid "Joomla! %s is available"
msgstr "Joomla! %s está disponible"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_CURRENT_VERSION"
msgid "Your site is currently using Joomla! %s."
msgstr "Su sitio está usando actualmente Joomla! %s."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_IS_PATCH_RELEASE"
msgid "This is a patch (point) update which is almost always safe."
msgstr "Esta es una actualización de parche (punto) que casi siempre es segura."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_IS_MINOR_RELEASE"
msgid "This is a minor (version family) update which may affect your template overrides, templates, and some third party extensions."
msgstr "Esta es una actualización menor (familia de versiones) que puede afectar a sus anulaciones de plantilla."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_MINOR_RELEASE_ADMONISHMENT"
msgid "It is a good idea to take a backup of your site, and test this update on a copy of your site first."
msgstr "Es recomendable realizar una copia de seguridad de su sitio y probar esta actualización en una copia antes de aplicarla al sitio en producción."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_IS_MAJOR_RELEASE"
msgid "This is a major version update which will most likely affect your template overrides, templates, and possibly some third party extensions."
msgstr "Esta es una actualización de versión principal que muy probablemente afectará a sus anulaciones de plantilla y posiblemente a las extensiones de terceros."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_MAJOR_RELEASE_ADMONISHMENT"
msgid "It is very strongly recommended that you take a backup of your site, and test this update on a copy of your site first."
msgstr "Se recomienda encarecidamente realizar una copia de seguridad de su sitio y probar esta actualización en una copia antes de aplicarla al sitio en producción."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_UP_TO_DATE"
msgid "Joomla! %s is up-to-date"
msgstr "Joomla! %s está actualizado"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_EOL"
msgid "Joomla! %s is unsupported"
msgstr "Joomla! %s no tiene soporte"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_EOL_MAJOR"
msgid "The Joomla! %s series is End-of-Life"
msgstr "La serie Joomla! %s ha llegado al fin de vida útil"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_EOL_MINOR"
msgid "The Joomla! %s version family is End-of-Life"
msgstr "La familia de versiones Joomla! %s ha llegado al fin de vida útil"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_EOL_DATE"
msgid "Joomla! %s became End of Life on %s"
msgstr "Joomla! %s llegó al fin de vida útil el %s"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SECURITY_DATE"
msgid "Joomla! %s receives security updates only since %s and will become End-of-Life on %s."
msgstr "Joomla! %s recibe solo actualizaciones de seguridad desde %s y llegará al fin de vida útil el %s"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_STABLE_DATE"
msgid "Joomla! %s receives security updates and bug fixes until %s. It will become End-of-Life and superseded by a new minor version on %s."
msgstr "Joomla! %s recibe actualizaciones de seguridad y correcciones de errores hasta %s. Llegará al fin de vida útil el %s."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_LAST_STABLE_DATE"
msgid "Joomla! %s receives security updates and bug fixes until %s. It will become End-of-Life on %s. It is superseded by a new major version."
msgstr "Joomla! %s recibe actualizaciones de seguridad y correcciones de errores hasta %s. Llegará al fin de vida útil el %s."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_CANNOT_INSTALL"
msgid "The newer Joomla! version %s is available but cannot be installed because of your site preferences."
msgstr "La versión más nueva de Joomla! %s está disponible pero no se puede instalar debido a la configuración actual de su sitio."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_FIX_TO_INSTALL_NEXT_VERSION"
msgid "Go to your site\'s administrator backend, System, Update, Joomla, click on Options, and change the update channel to Joomla Next. Please check Joomla\'s requirements, especially the database version and PHP version requirements. Note that your site is currently using PHP %s."
msgstr "Vaya al backend de administración de su sitio, Sistema, Actualización, Joomla, haga clic en Opciones y ajuste la configuración de actualización."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_NOT_SCHEDULED"
msgid "The update is <span class=\"text-danger fw-semibold\">not scheduled</span> to run automatically. You can run the update manually on your site, or click on the button below."
msgstr "La actualización <span class=\"text-danger fw-semibold\">no está programada</span> para ejecutarse automáticamente."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SCHEDULED"
msgid "The update is <span class=\"fw-semibold text-success\">scheduled</span> to run automatically after %s."
msgstr "La actualización está <span class=\"fw-semibold text-success\">programada</span> para ejecutarse automáticamente."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SCHEDULED_ASAP"
msgid "The update is <span class=\"fw-semibold text-success\">scheduled</span> to run automatically as soon as possible."
msgstr "La actualización está <span class=\"fw-semibold text-success\">programada</span> para ejecutarse tan pronto como sea posible."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_RUNNING"
msgid "The update is <span class=\"fw-semibold text-success\">currently taking place</span>"
msgstr "La actualización está <span class=\"fw-semibold text-success\">ejecutándose actualmente</span>."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_ERRORED"
msgid "The update was scheduled to run automatically but ran into an error:"
msgstr "La actualización estaba programada para ejecutarse automáticamente pero encontró un error:"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_THE_ERROR_REPORTED_WAS"
msgid "The error reported was:"
msgstr "El error reportado fue:"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_ERROR_TRACE"
msgid "Error trace (for debugging):"
msgstr "Traza del error (para depuración):"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SCHEDULE_UPDATE"
msgid "Schedule Automatic Update to Joomla! %s"
msgstr "Programar actualización automática a Joomla! %s"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_UNSCHEDULE_UPDATE"
msgid "Cancel Automatic Update"
msgstr "Cancelar actualización automática"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_UNSCHEDULE_ERR_NOT_SCHEDULED"
msgid "There is no scheduled update."
msgstr "No hay ninguna actualización programada."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_UNSCHEDULE_ERR_RUNNING"
msgid "The scheduled update is already running."
msgstr "La actualización programada ya está en ejecución."

#, phpformat
msgctxt "PANOPTICON_SITE_ERR_JUPDATE_UNSCHEDULE_FAILED"
msgid "Could not cancel the Joomla core update."
msgstr "No se pudo cancelar la actualización del núcleo de Joomla."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SCHEDULE_CLEAR_ERROR"
msgid "Clear Error"
msgstr "Borrar error"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_REFRESH_CORE_PROMPT"
msgid "Site woes? Try refreshing the Joomla! core files."
msgstr "¿Problemas con el sitio? Intente actualizar los archivos del núcleo de Joomla!."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_BTN_REFRESH_CORE_PROMPT"
msgid "Schedule Joomla! %s Files Refresh"
msgstr "Programar actualización de archivos Joomla! %s"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_REFRESH_CORE_NOTE"
msgid "Refreshing the Joomla! core files is <em>always safe</em>. Your site contents will not be changed. Use this to undo changes to the Joomla! core files (“core hacks”), or if you suspect that your site does not work correctly because of a failed update."
msgstr "Actualizar los archivos del núcleo de Joomla! es <em>siempre seguro</em>. El contenido de su sitio no se verá afectado."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_REFRESH_SCHEDULED"
msgid "The core files refresh is <span class=\"fw-semibold text-success\">scheduled</span> to run automatically after %s."
msgstr "La actualización de archivos del núcleo está <span class=\"fw-semibold text-success\">programada</span> para ejecutarse."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_REFRESH_SCHEDULED_ASAP"
msgid "The core files refresh is <span class=\"fw-semibold text-success\">scheduled</span> to run automatically as soon as possible."
msgstr "La actualización de archivos del núcleo está <span class=\"fw-semibold text-success\">programada</span> para ejecutarse tan pronto como sea posible."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_REFRESH_RUNNING"
msgid "The core files refresh is <span class=\"fw-semibold text-success\">currently taking place</span>"
msgstr "La actualización de archivos del núcleo se está <span class=\"fw-semibold text-success\">ejecutando actualmente</span>."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_REFRESH_ERRORED"
msgid "The core files refresh ran into an error:"
msgstr "La actualización de archivos del núcleo encontró un error:"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SOURCE_INFO"
msgid "The Joomla! update availability information is provided by your site. Joomla! End-of-Life and security-only support dates are manually collected from the information published by the Joomla! project."
msgstr "La información de disponibilidad de actualizaciones de Joomla! es proporcionada por su sitio. Joomla! Extension Directory (JED) es la fuente de esta información."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_SCHEDULE_OK"
msgid "Scheduled the WordPress core update."
msgstr "Se ha programado la actualización del núcleo de WordPress."

#, phpformat
msgctxt "PANOPTICON_SITE_ERR_WPUPDATE_SCHEDULE_FAILED"
msgid "Scheduling the WordPress core update has failed."
msgstr "La programación de la actualización del núcleo de WordPress ha fallado."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_SCHEDULE_ERROR_CLEARED"
msgid "The scheduling error has been cleared."
msgstr "El error de programación ha sido borrado."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_SCHEDULE_ERROR_NOT_CLEARED"
msgid "The scheduling error could not be cleared: %s"
msgstr "No se pudo borrar el error de programación: %s"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_UNSCHEDULE_ERR_NOT_SCHEDULED"
msgid "There is no scheduled update."
msgstr "No hay ninguna actualización programada."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_UNSCHEDULE_ERR_RUNNING"
msgid "The scheduled update is already running."
msgstr "La actualización programada ya está en ejecución."

#, phpformat
msgctxt "PANOPTICON_SITE_ERR_WPUPDATE_UNSCHEDULE_FAILED"
msgid "Could not cancel the WordPress core update."
msgstr "No se pudo cancelar la actualización del núcleo de WordPress."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_HEAD"
msgid "WordPress Update"
msgstr "Actualización de WordPress"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_NO_VERSION_HEAD"
msgid "Version information missing"
msgstr "Falta información de versión"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_NO_VERSION_BODY"
msgid "Your site has not reported the version of WordPress it is running on."
msgstr "Su sitio no ha reportado la versión de WordPress que está utilizando."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_AVAILABLE_UPDATE"
msgid "WordPress %s is available"
msgstr "WordPress %s está disponible"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_CURRENT_VERSION"
msgid "Your site is currently using WordPress %s."
msgstr "Su sitio está usando actualmente WordPress %s."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_IS_PATCH_RELEASE"
msgid "This is a patch (point) update which is almost always safe."
msgstr "Esta es una actualización de parche (punto) que casi siempre es segura."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_IS_MINOR_RELEASE"
msgid "This is a minor (version family) update which may affect your plugins, and themes."
msgstr "Esta es una actualización menor (familia de versiones) que puede afectar a sus plugins y temas."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_MINOR_RELEASE_ADMONISHMENT"
msgid "It is a good idea to take a backup of your site, and test this update on a copy of your site first."
msgstr "Es recomendable realizar una copia de seguridad de su sitio y probar esta actualización en una copia antes de aplicarla al sitio en producción."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_IS_MAJOR_RELEASE"
msgid "This is a major version update which will most likely affect your plugins, and themes."
msgstr "Esta es una actualización de versión principal que muy probablemente afectará a sus plugins y temas."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_MAJOR_RELEASE_ADMONISHMENT"
msgid "It is very strongly recommended that you take a backup of your site, and test this update on a copy of your site first."
msgstr "Se recomienda encarecidamente realizar una copia de seguridad de su sitio y probar esta actualización en una copia antes de aplicarla al sitio en producción."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_EOL"
msgid "WordPress %s is unsupported"
msgstr "WordPress %s no tiene soporte"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_CANNOT_INSTALL"
msgid "The newer WordPress version %s is available but cannot be installed because of your site preferences."
msgstr "La versión más nueva de WordPress %s está disponible pero no se puede instalar debido a la configuración actual de su sitio."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_EOL_DATE"
msgid "WordPress %s became End of Life on %s"
msgstr "WordPress %s llegó al fin de vida útil el %s"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_UP_TO_DATE"
msgid "WordPress %s is up-to-date"
msgstr "WordPress %s está actualizado"

#, phpformat
msgctxt "PANOPTICON_SITE_BTN_WPUPDATE_RELOAD"
msgid "Reload WordPress update information"
msgstr "Recargar información de actualización de WordPress"

#, phpformat
msgctxt "PANOPTICON_SITE_BTN_WPUPDATE_RELOAD_SR"
msgid "Reload WordPress update information for site “%s”"
msgstr "Recargar información de actualización de WordPress para el sitio \"%s\""

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_SOURCE_INFO"
msgid "The WordPress update availability information is provided by your site. WordPress End-of-Life dates come from <a href=\\\"%s\\\" target=\\\"_blank\\\">%1$s</a>. The WordPress project does not publish end of security updates and / or end of life dates ahead of time, which is why this information is not displayed in Panopticon."
msgstr "La información de disponibilidad de actualizaciones de WordPress es proporcionada por su sitio. WordPress.org es la fuente de esta información."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_SCHEDULE_UPDATE"
msgid "Schedule Automatic Update to WordPress %s"
msgstr "Programar actualización automática a WordPress %s"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_PLUGIN_UPDATE_SCHEDULE_OK"
msgid "Scheduled the plugin / theme update."
msgstr "Se ha programado la actualización del plugin / tema."

#, phpformat
msgctxt "PANOPTICON_SITE_ERR_PLUGIN_UPDATE_SCHEDULE_FAILED"
msgid "Scheduling the plugin / theme update has failed."
msgstr "La programación de la actualización del plugin / tema ha fallado."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_TEMPLATE_OVERRIDES_CHANGED_N"
msgid "%d template overrides need to be reviewed"
msgstr "%d anulaciones de plantilla deben ser revisadas"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_TEMPLATE_OVERRIDES_CHANGED_N_1"
msgid "One template override needs to be reviewed"
msgstr "Una anulación de plantilla debe ser revisada"

#, phpformat
msgctxt "PANOPTICON_SITE_BTN_TEMPLATE_OVERRIDES_CHECK"
msgid "Check Template Overrides"
msgstr "Comprobar anulaciones de plantilla"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_EXTENSION_UPDATE_SCHEDULE_UPDATE"
msgid "Schedule Automatic Update to version %s"
msgstr "Programar actualización automática a versión %s"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_EXTENSION_UPDATE_WILL_RUN"
msgid "Extension updates will run automatically"
msgstr "Las actualizaciones de extensiones se ejecutarán automáticamente"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_EXTENSION_UPDATE_RUNNING"
msgid "Automatic extension updates are in progress"
msgstr "Las actualizaciones automáticas de extensiones están en progreso"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_EXTENSION_UPDATE_ERRORED"
msgid "Automatic extension updates ran into an error:"
msgstr "Las actualizaciones automáticas de extensiones encontraron un error:"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_EXTENSION_UPDATE_STUCK"
msgid "Automatic extension updates are stuck"
msgstr "Las actualizaciones automáticas de extensiones están bloqueadas"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_EXTENSION_UPDATE_STUCK_HELP"
msgid "There are pending extension updates, but there is no scheduled update task to install them."
msgstr "Hay actualizaciones de extensiones pendientes, pero no hay ninguna tarea de actualización programada para instalarlas."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_EXTENSION_UPDATE_MAYBE_STUCK"
