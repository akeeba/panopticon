#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_SUBHEAD_PASSWORD_SECURITY"
msgid "Password Security"
msgstr "Seguridad de contraseña"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_SUBHEAD_SESSION"
msgid "Session Storage"
msgstr "Almacenamiento de sesión"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_NO_EXTENSIONS_HEAD"
msgid "No extensions found"
msgstr "No se encontraron extensiones"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_NO_EXTENSIONS_BODY"
msgid "Set up your sites and wait until their extension update information refreshes - up to 15 minutes later. You will then see all of their installed extensions here."
msgstr "Configure sus sitios y espere a que se actualice la información de actualizaciones de extensiones; después podrá configurar sus preferencias de actualización automática aquí."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_LIVE_SITE"
msgid "Panopticon URL"
msgstr "URL de Panopticon"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_LIVE_SITE_HELP"
msgid "The base URL of your Panopticon installation. Used when sending email from unattended tasks."
msgstr "La URL base de su instalación de Panopticon. Se usa al enviar correos electrónicos desde tareas desatendidas."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_SESSION_TIMEOUT"
msgid "Session Timeout"
msgstr "Tiempo de espera de sesión"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_SESSION_USE_DEFAULT_PATH"
msgid "Use Default PHP Session Save Path"
msgstr "Usar ruta de guardado de sesión PHP predeterminada"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_SESSION_USE_DEFAULT_PATH_HELP"
msgid "When enabled, Panopticon uses the <code>session.save_path</code> in your PHP configuration for saving PHP session data files. When disabled, Panopticon uses the <code>tmp/session</code> folder under your web root."
msgstr "Cuando está habilitado, Panopticon usa <code>session.save_path</code> en su configuración PHP. De lo contrario, usa una carpeta personalizada."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_TIMEZONE"
msgid "Time Zone"
msgstr "Zona horaria"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DEBUG"
msgid "Debug System"
msgstr "Depurar sistema"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_LOGIN_FAILURE_ENABLE"
msgid "Automatic IP block on failed login attempts"
msgstr "Bloqueo automático de IP en intentos fallidos de inicio de sesión"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_LOGIN_MAX_FAILURES"
msgid "Maximum login failures"
msgstr "Número máximo de fallos de inicio de sesión"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_LOGIN_FAILURE_WINDOW"
msgid "Login failure window"
msgstr "Ventana de tiempo para fallos de inicio de sesión"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_LOGIN_LOCKOUT"
msgid "IP block time"
msgstr "Tiempo de bloqueo de IP"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_LOGIN_LOCKOUT_EXTEND"
msgid "Extend IP lockout time"
msgstr "Extender el tiempo de bloqueo de IP"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_LOGIN_LOCKOUT_EXTEND_HELP"
msgid "When enabled, every time a blocked IP address tries to access Akeeba Panopticon it will have its lockout time reset, i.e. the lockout will be extended for another “IP lockout time” seconds. This penalises some bots, but it comes at the expense of slowing down legitimate access to Akeeba Panopticon."
msgstr "Cuando está habilitado, cada vez que una IP bloqueada intenta acceder a Akeeba Panopticon se extiende el tiempo de bloqueo."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PASSWORD_HIBP"
msgid "Forbid using leaked passwords"
msgstr "Prohibir el uso de contraseñas filtradas"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PASSWORD_HIBP_HELP"
msgid "Prevent users from using passwords which are found in online password leaks. Powered by the third party service <a href=\'https://haveibeenpwned.com/\' _target=\'blank\'>Have I Been Pwned</a>."
msgstr "Evita que los usuarios usen contraseñas encontradas en filtraciones de contraseñas en línea. Funciona gracias al servicio Have I Been Pwned."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_STATS_COLLECTION"
msgid "Anonymous Usage Statistics Collection"
msgstr "Recopilación de estadísticas de uso anónimas"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_STATS_COLLECTION_HELP"
msgid "Akeeba Panopticon collects anonymous information about the Panopticon, PHP, and database server version. This aggregated information allows Akeeba to determine which versions of PHP and database servers to support in future releases."
msgstr "Akeeba Panopticon recopila información anónima sobre el entorno de Panopticon, PHP y la base de datos. Esta información se usa para mejorar el software."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_STATS_COLLECTION_HELP_LEARN_MORE"
msgid "Details of the information collected."
msgstr "Detalles de la información recopilada."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_ERROR_REPORTING"
msgid "Error Reporting"
msgstr "Informe de errores"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_TEMPLATE"
msgid "Template"
msgstr "Plantilla"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_TEMPLATE_HELP"
msgid "Custom templates must be installed in the <code>templates</code> folder."
msgstr "Las plantillas personalizadas deben instalarse en la carpeta <code>templates</code>."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_THEME"
msgid "CSS Theme File"
msgstr "Archivo de tema CSS"

#, phpformat
