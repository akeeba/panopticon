msgstr "¿Qué es esto?"

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_LBL_FORCED_NEEDED"
msgid "You must set up a passkey to be allowed further access to this application."
msgstr "Debe configurar una clave de acceso para tener acceso a esta aplicación."

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_LBL_FORCED_COMPLETE"
msgid "You can now click on the Cancel button in the toolbar to return to the application."
msgstr "Ahora puede hacer clic en el botón Cancelar de la barra de herramientas para volver a la aplicación."

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_ERR_DISABLED"
msgid "Passkey login is disabled"
msgstr "El inicio de sesión con clave de acceso está desactivado"

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_ERR_NO_STORED_CREDENTIAL"
msgid "Cannot find the stored credentials for your passkey."
msgstr "No se pueden encontrar las credenciales almacenadas para su clave de acceso."

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_ERR_CORRUPT_STORED_CREDENTIAL"
msgid "The stored credentials are corrupt for your user account. Log in using another method, then remove and add again your passkey."
msgstr "Las credenciales almacenadas están corruptas para su cuenta de usuario. Inicie sesión usando otro método, luego elimine y vuelva a añadir su clave de acceso."

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_ERR_CANT_STORE_FOR_GUEST"
msgid "Cannot possibly store credentials without a user!"
msgstr "¡No es posible almacenar credenciales sin un usuario!"

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_ERR_CREDENTIAL_ID_ALREADY_IN_USE"
msgid "Cannot save credentials. These credentials are already being used by a different user."
msgstr "No se pueden guardar las credenciales. Estas credenciales ya están siendo utilizadas por otro usuario."

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_ERR_USER_REMOVED"
msgid "The user for this passkey seems to no longer exist on this site."
msgstr "El usuario de esta clave de acceso parece que ya no existe en este sitio."

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_ERR_NO_BROWSER_SUPPORT"
msgid "Sorry, your browser does not support passkeys. You will need to log into this site using your username and password."
msgstr "Lo sentimos, su navegador no es compatible con las claves de acceso. Tendrá que iniciar sesión en este sitio usando su nombre de usuario y contraseña."

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_ERR_CREATE_NO_PK"
msgid "The server has not issued a Public Key for passkey registration but somehow received a passkey registration request from the browser. This means that someone tried to hack you or something is broken."
msgstr "El servidor no emitió una clave pública para el registro de la clave de acceso, pero de alguna manera recibió una solicitud de registro de clave de acceso del navegador. Esto significa que alguien intentó atacarle o algo está averiado."

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_ERR_CREATE_INVALID_PK"
msgid "The passkey registration has failed. The authenticator response received from the browser does not match the Public Key issued by the server. This means that someone tried to hack you or something is broken."
msgstr "El registro de la clave de acceso ha fallado. La respuesta del autenticador recibida del navegador no coincide con la clave pública emitida por el servidor. Esto significa que alguien intentó atacarle o algo está averiado."

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_ERR_CREATE_INVALID_USER"
msgid "For security reasons you are not allowed to register passkeys on behalf of another user."
msgstr "Por razones de seguridad, no tiene permiso para registrar claves de acceso en nombre de otro usuario."

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_ERR_CREATE_NO_ATTESTED_DATA"
msgid "Something went wrong but no further information about the error is available at this time. Please retry registering your passkey."
msgstr "Algo salió mal, pero no hay más información disponible sobre el error en este momento. Por favor, intente registrar su clave de acceso de nuevo."

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_ERR_LABEL_NOT_SAVED"
msgid "Could not save the new label"
msgstr "No se pudo guardar la nueva etiqueta"

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_ERR_NOT_DELETED"
msgid "Could not remove the passkey"
msgstr "No se pudo eliminar la clave de acceso"

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_ERR_CREATE_INVALID_LOGIN_REQUEST"
msgid "Invalid passwordless login request. Something is broken or this is an attempt to hack the site."
msgstr "Solicitud de inicio de sesión sin contraseña no válida. Algo está averiado o esto es un intento de ataque al sitio."

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_ERR_CANNOT_FIND_USERNAME"
msgid "Cannot find the username field. Sorry, passkeys will not work on this site."
msgstr "No se puede encontrar el campo de nombre de usuario. Lo sentimos, las claves de acceso no funcionarán en este sitio."

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_ERR_EMPTY_USERNAME"
msgid "You need to enter your username (but NOT your password) before clicking the Passwordless Login button."
msgstr "Debe introducir su nombre de usuario (pero NO su contraseña) antes de hacer clic en el botón de inicio de sesión sin contraseña."

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_ERR_INVALID_USERNAME"
msgid "The specified username does not correspond to a user account that has enabled passwordless login on this site."
msgstr "El nombre de usuario especificado no corresponde a una cuenta de usuario que haya activado el inicio de sesión sin contraseña en este sitio."

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_ERR_INVALID_USERNAME_RESIDENT"
msgid "The passkey you selected does not correspond to an active user of this site."
msgstr "La clave de acceso seleccionada no corresponde a un usuario activo de este sitio."

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_ERR_WEBAUTHN_REQUIRES_GMP_OR_BCMATCH"
msgid "One of the PHP extensions GMP and BCMath must be installed and enabled on your server to add passkeys."
msgstr "Una de las extensiones PHP GMP y BCMath debe estar instalada y activada en su servidor para añadir claves de acceso."

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_ERR_CANNOT_ADD_FOR_A_USER"
msgid "You cannot add or remove passkeys on behalf of users. Users must login, and set up their own passkeys."
msgstr "No puede añadir ni eliminar claves de acceso en nombre de otros usuarios. Los usuarios deben iniciar sesión y configurar sus propias claves de acceso."

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_ERR_NOPASSWORDLOGIN"
msgid "You are not allowed to log into the site with a username and password."
msgstr "No tiene permiso para iniciar sesión en el sitio con nombre de usuario y contraseña."

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_ERR_AJAX_INVALIDACTION"
msgid "Invalid ajax action"
msgstr "Acción ajax no válida"

#, phpformat
msgctxt "PANOPTICON_PASSKEYS_ERR_XHR_INITCREATE"
msgid "Cannot get the passkey registration information from your site."
msgstr "No se puede obtener la información de registro de clave de acceso de su sitio."

#, phpformat
