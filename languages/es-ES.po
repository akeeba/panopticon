msgid "Please select how you would like to verify your login to this site."
msgstr "Por favor, seleccione cómo desea verificar su inicio de sesión en este sitio."

#, phpformat
msgctxt "PANOPTICON_MFA_LBL_BACKUPCODES"
msgid "Backup Codes (Emergency Access)<br><small class=\"text-muted\">Use these if you get locked out.</small>"
msgstr "Códigos de copia de seguridad (acceso de emergencia)<br><small class=\"text-muted\">Úselos si ningún otro método está disponible</small>"

#, phpformat
msgctxt "PANOPTICON_MFA_LBL_BACKUPCODES_METHOD_NAME"
msgid "Backup Codes"
msgstr "Códigos de copia de seguridad"

#, phpformat
msgctxt "PANOPTICON_MFA_LBL_BACKUPCODES_DESCRIPTION"
msgid "Single-use codes to let you login to the site if none of the other methods can be used."
msgstr "Códigos de un solo uso para permitirle iniciar sesión en el sitio si ninguno de los otros métodos está disponible."

#, phpformat
msgctxt "PANOPTICON_MFA_LBL_BACKUPCODES_PRINT_PROMPT"
msgid "<strong><a href=\"%s\">Print these codes</a> and keep them in your wallet</strong>. <span class=\"text-muted\">Backup codes let you log into the site if your regular Multi-factor Authentication method does not work or you no longer have access to it. Each code can be used <em>only once</em>.</span>"
msgstr "<strong><a href=\"%s\">Imprima estos códigos</a> y guárdelos en su cartera</strong>"

#, phpformat
msgctxt "PANOPTICON_MFA_LBL_BACKUPCODES_INSTRUCTIONS"
msgid "Print this page and keep it in your wallet. Each of the following codes below can be used only once. Use them in case of emergency, when none of the other Multi-factor Authentication methods you\'ve set up can be used. For example, if your phone is out of battery or misplaced."
msgstr "Imprima esta página y guárdela en su cartera. Cada uno de los códigos siguientes se puede usar una sola vez."

#, phpformat
msgctxt "PANOPTICON_MFA_LBL_BACKUPCODES_RESET"
msgid "Regenerate Backup Codes"
msgstr "Regenerar códigos de copia de seguridad"

#, phpformat
msgctxt "PANOPTICON_MFA_LBL_BACKUPCODES_RESET_INFO"
msgid "Use the “Regenerate Backup Codes” toolbar button to generate a new set of backup codes. You should do that if you have misplaced your backup codes, believe they may have been compromised, or are running out of available backup codes."
msgstr "Use el botón \"Regenerar códigos de copia de seguridad\" de la barra de herramientas para generar un nuevo conjunto de códigos de copia de seguridad."

#, phpformat
msgctxt "PANOPTICON_MFA_LBL_BACKUPCODES_ENTRY_LABEL"
msgid "Your emergency backup code"
msgstr "Su código de copia de seguridad de emergencia"

#, phpformat
msgctxt "PANOPTICON_MFA_LBL_BACKUPCODES_USE_WHEN_LOCKED_OUT"
msgid "Enter an emergency backup code if you are locked out."
msgstr "Introduzca un código de copia de seguridad de emergencia si está bloqueado."

#, phpformat
msgctxt "PANOPTICON_MFA_FIXED_LBL_DISPLAYEDAS"
msgid "Fixed Code"
msgstr "Código fijo"

#, phpformat
msgctxt "PANOPTICON_MFA_FIXED_LBL_SHORTINFO"
msgid "Choose your own preset code, essentially a second password. <strong>For demonstration purposes only - this is disabled in production</strong>."
msgstr "Elija su propio código predefinido, que actúa esencialmente como una segunda contraseña. <strong>Solo con fines de demostración: esta función está desactivada en producción</strong>."

#, phpformat
msgctxt "PANOPTICON_MFA_FIXED_LBL_LABEL"
msgid "Enter your fixed Multi-factor Authentication code"
msgstr "Introduzca su código fijo de autenticación multifactor"

#, phpformat
msgctxt "PANOPTICON_MFA_FIXED_LBL_PLACEHOLDER"
msgid "Enter your Fixed Code"
msgstr "Introduzca su código fijo"

#, phpformat
msgctxt "PANOPTICON_MFA_FIXED_LBL_PREMESSAGE"
msgid "<p>This is a demonstration Multi-factor Authentication plugin for Panopticon. You need to enter the fixed code you configured when enabling the Multi-factor Authentication for this user. It effectively works as a second password.</p>"
msgstr "<p>Este es un complemento de autenticación multifactor de demostración para Panopticon. Debe introducir el código fijo que configuró al activar la autenticación multifactor para este usuario. Funciona efectivamente como una segunda contraseña.</p>"

#, phpformat
msgctxt "PANOPTICON_MFA_FIXED_LBL_POSTMESSAGE"
msgid "<p class=\"alert alert-info\">The messages appearing above and below the code area can be customized by overriding the language strings <code>PANOPTICON_MFA_LBL_PREMESSAGE</code> and <code>PANOPTICON_MFA_FIXED_LBL_POSTMESSAGE</code>.</p>"
msgstr "<p class=\"alert alert-info\">Los mensajes que aparecen arriba y abajo del área de código se pueden personalizar reemplazando las cadenas de idioma <code>PANOPTICON_MFA_LBL_PREMESSAGE</code> y <code>PANOPTICON_MFA_FIXED_LBL_POSTMESSAGE</code>.</p>"

#, phpformat
msgctxt "PANOPTICON_MFA_FIXED_LBL_DEFAULTTITLE"
msgid "Fixed Code"
msgstr "Código fijo"

#, phpformat
msgctxt "PANOPTICON_MFA_FIXED_LBL_SETUP_PREMESSAGE"
msgid "<p>Enter a password below. This password will be required to be entered after logging in before you\'re able to use the site.</p>"
msgstr "<p>Introduzca una contraseña a continuación. Esta contraseña será requerida tras iniciar sesión antes de que pueda usar el sitio.</p>"

#, phpformat
msgctxt "PANOPTICON_MFA_FIXED_LBL_SETUP_POSTMESSAGE"
msgid "<p class=\"alert alert-info\">The messages appearing above and below the setup area can be customized by overriding the language strings <code>PANOPTICON_MFA_FIXED_LBL_SETUP_PREMESSAGE</code> and <code>PANOPTICON_MFA_FIXED_LBL_SETUP_POSTMESSAGE</code></p>"
msgstr "<p class=\"alert alert-info\">Los mensajes que aparecen arriba y abajo del área de configuración se pueden personalizar reemplazando las cadenas de idioma <code>PANOPTICON_MFA_FIXED_LBL_SETUP_PREMESSAGE</code> y <code>PANOPTICON_MFA_FIXED_LBL_SETUP_POSTMESSAGE</code></p>"

#, phpformat
msgctxt "PANOPTICON_MFA_FIXED_ERR_EMPTYCODE"
msgid "Your fixed code cannot be empty."
msgstr "Su código fijo no puede estar vacío."

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_LBL_DISPLAYEDAS"
msgid "Passkey"
msgstr "Clave de acceso"

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_LBL_SHORTINFO"
msgid "Use a Passkey, with any hardware or software security key."
msgstr "Use una clave de acceso, con cualquier clave de seguridad de hardware o software."

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_LBL_REGISTERKEY"
msgid "Register a Passkey"
msgstr "Registrar una clave de acceso"

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_LBL_VALIDATEKEY"
msgid "Validate Your Login with a Passkey"
msgstr "Valide su inicio de sesión con una clave de acceso"

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_LBL_CONFIGURED"
msgid "You have already configured this Passkey. Please note that you can only modify its title from this page."
msgstr "Ya ha configurado esta clave de acceso. Tenga en cuenta que solo puede modificar su título desde esta página."

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_LBL_INSTRUCTIONS"
msgid "Follow the instructions on your device\'s screen to use your preferred Passkey."
msgstr "Siga las instrucciones en la pantalla de su dispositivo para usar su clave de acceso preferida."

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_ERR_NOTAVAILABLE_HEAD"
msgid "Your browser lacks support for Passkeys"
msgstr "Su navegador no es compatible con claves de acceso"

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_ERR_NOTAVAILABLE_BODY"
msgid "Your browser doesn\'t support Passkeys, or your site does not meet the minimum requirements (HTTPS-only, with an SSL/TLS certificate signed by a commercial Certification Authority)."
msgstr "Su navegador no es compatible con claves de acceso, o su sitio no cumple los requisitos mínimos (solo HTTPS, con un certificado SSL/TLS firmado por una autoridad de certificación comercial)."

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_ERR_NO_STORED_CREDENTIAL"
msgid "You have not configured a Passkey yet or the Passkey you are trying to use is unknown to this site."
msgstr "Todavía no ha configurado una clave de acceso, o la clave que intenta usar es desconocida para este sitio."

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_ERR_CREATE_NO_PK"
msgid "The server has not issued a Public Key for Passkey registration but somehow received an authenticator registration request from the browser. This means that someone tried to hack you, or something is terribly broken."
msgstr "El servidor no emitió una clave pública para el registro de la clave de acceso, pero de alguna manera recibió una solicitud de registro de autenticador del navegador. Esto significa que alguien intentó atacarle, o algo está gravemente averiado."

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_ERR_CREATE_INVALID_PK"
msgid "The Passkey registration has failed. The response received from the browser does not match the Public Key issued by the server. This means that someone tried to hack you, or something is terribly broken."
msgstr "El registro de la clave de acceso ha fallado. La respuesta recibida del navegador no coincide con la clave pública emitida por el servidor. Esto significa que alguien intentó atacarle, o algo está gravemente averiado."

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_ERR_CREATE_INVALID_USER"
msgid "For security reasons you are not allowed to register Passkeys on behalf of another user."
msgstr "Por razones de seguridad, no tiene permiso para registrar claves de acceso en nombre de otro usuario."

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_ERR_CREATE_NO_ATTESTED_DATA"
msgid "Something went wrong but no further information about the error is available at this time. Please retry registering your Passkey."
msgstr "Algo salió mal, pero no hay más información disponible sobre el error en este momento. Por favor, intente registrar su clave de acceso de nuevo."

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_ERR_CREATE_INVALID_LOGIN_REQUEST"
msgid "Invalid authentication request."
msgstr "Solicitud de autenticación no válida."

#, phpformat
msgctxt "PANOPTICON_MFA_TOTP_LBL_DISPLAYEDAS"
msgid "Authenticator code (TOTP)"
msgstr "Código de autenticador (TOTP)"

#, phpformat
msgctxt "PANOPTICON_MFA_TOTP_LBL_SHORTINFO"
msgid "Six-digit code which changes every 30 seconds."
msgstr "Código de seis dígitos que cambia cada 30 segundos."

#, phpformat
msgctxt "PANOPTICON_MFA_TOTP_LBL_CODE"
msgid "Code"
msgstr "Código"

#, phpformat
msgctxt "PANOPTICON_MFA_TOTP_LBL_PLACEHOLDER"
msgid "Enter your six-digit code"
msgstr "Introduzca su código de seis dígitos"

#, phpformat
msgctxt "PANOPTICON_MFA_TOTP_QR_LBL_TITLE"
msgid "Set up your authenticator software"
msgstr "Configure su software autenticador"

#, phpformat
msgctxt "PANOPTICON_MFA_TOTP_QR_LBL_INSTRUCTIONS"
msgid "Depending on your authenticator software, do one of the following:"
msgstr "Según su software autenticador, realice una de las siguientes acciones:"

#, phpformat
msgctxt "PANOPTICON_MFA_TOTP_QR_LBL_INSTRUCTIONS_OPT1"
msgid "Scan this QR Code&trade;."
msgstr "Escanee este código QR&trade;."

#, phpformat
msgctxt "PANOPTICON_MFA_TOTP_QR_LBL_INSTRUCTIONS_OPT2"
msgid "Use this <a href=\"%s\">link</a>."
msgstr "Use este <a href=\"%s\">enlace</a>."

#, phpformat
msgctxt "PANOPTICON_MFA_TOTP_QR_LBL_INSTRUCTIONS_OPT3"
msgid "Enter the Secret"
msgstr "Introduzca el secreto"

#, phpformat
msgctxt "PANOPTICON_MFA_TOTP_QR_LBL_ENTER_CODE"
msgid "Enter the generated 6-digit code into the field below, and click on “Save”."
msgstr "Introduzca el código de 6 dígitos generado en el campo a continuación, y haga clic en \"Guardar\"."

#, phpformat
msgctxt "PANOPTICON_MFA_TOTP_QR_LBL_SOFTWARE"
msgid "Looking for compatible authenticator software? We have tested with <a href=\"https://keepassxc.org/\">KeePassXC</a>, <a href=\"https://strongboxsafe.com/\">Strongbox</a>, <a href=\"https://1password.com/\">1Password</a>, <a href=\"https://en.wikipedia.org/wiki/Google_Authenticator\">Google Authenticator</a>, <a href=\"https://authy.com/\">Twilio Authy</a>, and the built-in feature in macOS / iOS / iPadOS."
