#, phpformat
msgctxt "PANOPTICON_BACKUPTASKS_LBL_BACKUP_OPTIONS"
msgid "Backup Options"
msgstr "Opciones de copia de seguridad"

#, phpformat
msgctxt "PANOPTICON_BACKUPTASKS_LBL_BACKUP_PROFILE"
msgid "Backup Profile"
msgstr "Perfil de copia de seguridad"

#, phpformat
msgctxt "PANOPTICON_BACKUPTASKS_LBL_DESCRIPTION"
msgid "Description"
msgstr "Descripción"

#, phpformat
msgctxt "PANOPTICON_BACKUPTASKS_LBL_DESCRIPTION_HELP"
msgid "You can use Akeeba Backup variables such as <code>[DATE]</code>, <code>[SITE]</code>, etc. They will be replaced by Akeeba Backup at backup time. You can also use the variables <code>{DATE_FORMAT_LC}</code>,<code>{DATE_FORMAT_LC1}</code>…<code>{DATE_FORMAT_LC7}</code> which will be replaced by Panopticon with a formatted version of the backup time. Please note that the Panopticon variables may differ by a few seconds compared to the Akeeba Backup variables as they are processed on the server running Panopticon, not the site\'s server where Akeeba Backup runs."
msgstr "Puede usar variables de Akeeba Backup como <code>[DATE]</code>, <code>[SITE]</code>, etc."

#, phpformat
msgctxt "PANOPTICON_BACKUPTASKS_LBL_DESCRIPTION_DEFAULT"
msgid "Scheduled remote backup with Panopticon taken on {DATE_FORMAT_LC7}"
msgstr "Copia de seguridad remota programada con Panopticon realizada el {DATE_FORMAT_LC7}"

#, phpformat
msgctxt "PANOPTICON_BACKUPTASKS_LBL_SCHEDULE"
msgid "Schedule"
msgstr "Programación"

#, phpformat
msgctxt "PANOPTICON_BACKUPTASKS_LBL_MINUTES"
msgid "Minutes"
msgstr "Minutos"

#, phpformat
msgctxt "PANOPTICON_BACKUPTASKS_LBL_MINUTES_HELP"
msgid "Number <code>0</code> to <code>59</code>, contiguous range e.g. <code>5-15</code>, comma–separated list of values e.g. <code>1,15,30,45</code>, every minute as <code>*</code>, every X minutes using slash e.g. <code>*/5</code> (every 5 minutes)."
msgstr "Número del <code>0</code> al <code>59</code>, rango contiguo p.ej. <code>5-15</code>, lista p.ej. <code>5,15,30</code>, o <code>*</code> para todos."

#, phpformat
msgctxt "PANOPTICON_BACKUPTASKS_LBL_HOURS"
msgid "Hours"
msgstr "Horas"

#, phpformat
msgctxt "PANOPTICON_BACKUPTASKS_LBL_HOURS_HELP"
msgid "Number <code>0</code> to <code>23</code> (0–11 is a.m., 12–23 is p.m.), contiguous range e.g. <code>5-15</code>, comma–separated list of values e.g. <code>0,6,12,18</code>, every hour as <code>*</code>, every X hours using slash e.g. <code>*/2</code> (every 2 hours)."
msgstr "Número del <code>0</code> al <code>23</code> (0-11 es a.m., 12-23 es p.m.), rango contiguo, lista o <code>*</code> para todas."

#, phpformat
msgctxt "PANOPTICON_BACKUPTASKS_LBL_DOM"
msgid "Day of the Month"
msgstr "Día del mes"

#, phpformat
msgctxt "PANOPTICON_BACKUPTASKS_LBL_DOM_HELP"
msgid "Number <code>1</code> to <code>31</code>, <code>L</code> for the last day of the month (cannot be used in lists of values!), contiguous range e.g. <code>1-15</code>, comma–separated list of values e.g. <code>1,7,14,21,28</code>, every day as <code>*</code>, every X days using slash e.g.<code>*/3</code> (every 3 days).<br>Use a number with <code>W</code> for the closest day within the same month that\'s not a Saturday or Sunday, e.g. <code>15W</code> is the closest day (from the 13th to the 17th) which is not a Saturday or Sunday."
msgstr "Número del <code>1</code> al <code>31</code>, <code>L</code> para el último día del mes, rango contiguo, lista o <code>*</code> para todos."

#, phpformat
msgctxt "PANOPTICON_BACKUPTASKS_LBL_MONTH"
msgid "Month"
msgstr "Mes"

#, phpformat
msgctxt "PANOPTICON_BACKUPTASKS_LBL_MONTH_HELP"
msgid "Number <code>1</code> (January) to <code>12</code> (December), contiguous range e.g. <code>3-7</code>, comma–separated list of values e.g. <code>3,6,9,12</code>, every month as <code>*</code>, every X months using slash e.g. <code>*/2</code> (every 2 months).<br>Instead of numbers you may use the abbreviated, three–letter, English names of the months: <code>JAN</code> <code>FEB</code>, <code>MAR</code>, <code>APR</code>, <code>MAY</code>, <code>JUN</code>, <code>JUL</code>, <code>AUG</code>, <code>SEP</code>, <code>OCT</code>, <code>NOV</code>, <code>DEC</code>."
msgstr "Número del <code>1</code> (enero) al <code>12</code> (diciembre), rango contiguo, lista o <code>*</code> para todos."

#, phpformat
msgctxt "PANOPTICON_BACKUPTASKS_LBL_DOW"
msgid "Day of the Week"
msgstr "Día de la semana"

#, phpformat
msgctxt "PANOPTICON_BACKUPTASKS_LBL_DOW_HELP"
msgid "Number <code>0</code> (Sunday) to <code>6</code> (Saturday), contiguous range e.g. <code>1-5</code>, comma–separated list of values e.g. <code>1,3,5</code>, every day as <code>*</code>.<br> Instead of numbers you may use the abbreviated, three–letter, English names of the days of the week: <code>SUN</code>, <code>MON</code>, <code>TUE</code>, <code>WED</code>, <code>THU</code>, <code>FRI</code>, <code>SAT</code><br>A number followed by <code>L</code> for the last day of the week in the month, e.g. <code>5L</code> is the last Friday of the month.<br>Two numbers separated by <code>#</code> for n-th day of the week in the month, e.g. <code>5#3</code> is the 3rd Friday of the month."
msgstr "Número del <code>0</code> (domingo) al <code>6</code> (sábado), rango contiguo, lista o <code>*</code> para todos."

