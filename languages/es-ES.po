msgctxt "PANOPTICON_SYSERROR_LEAKED_PASSWORD"
msgid "The password you are trying to use is present in online password leaks, making it very easy for hackers to guess this is what you are using. Please use a different password."
msgstr "La contraseña que intenta usar está presente en filtraciones de contraseñas en línea, lo que facilita mucho que los atacantes adivinen que es la que usa. Por favor, utilice una contraseña diferente."

#, phpformat
msgctxt "PANOPTICON_TASKTYPE_CORECHECKSUMS"
msgid "Core File Integrity Check"
msgstr "Verificación de integridad de archivos del núcleo"

#, phpformat
msgctxt "PANOPTICON_TASKTYPE_REGISTRATIONCLEANUP"
msgid "Clean up expired user registrations"
msgstr "Limpiar registros de usuario expirados"

#, phpformat
msgctxt "PANOPTICON_TASKTYPE_EXTENSIONINSTALL"
msgid "Remote Extension Installation"
msgstr "Instalación remota de extensiones"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_CANNOTCONNECT_TIPS"
msgid "Tips to connect Akeeba Panopticon to Akeeba Backup Professional"
msgstr "Consejos para conectar Akeeba Panopticon a Akeeba Backup Professional"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_CANNOTCONNECT_TIP_1"
msgid "Make sure that you have installed and enabled the Akeeba Backup Professional component, and the Web Services - Akeeba Backup plugin on your site. Akeeba Backup Core <em>is not</em> compatible with Akeeba Panopticon."
msgstr "Asegúrese de haber instalado y activado el componente Akeeba Backup Professional en su sitio Joomla!."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_CANNOTCONNECT_TIP_1_WP"
msgid "Make sure that you have installed and enabled the Akeeba Backup Professional plugin on your site. Akeeba Backup Core <em>is not</em> compatible with Akeeba Panopticon."
msgstr "Asegúrese de haber instalado y activado el plugin Akeeba Backup Professional en su sitio WordPress."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_CANNOTCONNECT_TIP_2"
msgid "Log into your site\'s backend. Go to Components, Akeeba Backup, Control Panel. Click on Options, Front-end Backup and set “Enable JSON API (remote backup)” to Yes. Enter a new “Secret Word”; you can create a new, random, secure secret word at <a href=\\\"https://www.random.org/passwords/?num=1&len=32&format=html&rnd=new\\\">random.org</a>. Then, click on Save &amp Close in the toolbar."
msgstr "Inicie sesión en el backend de su sitio. Vaya a Componentes, Akeeba Backup, Panel de control. Configure la clave de API JSON para que Panopticon pueda conectarse."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_CANNOTCONNECT_TIP_2_WP"
msgid "Log into your site\'s backend. Go to Akeeba Backup, System Configuration, Public API and set “Enable JSON API (remote backup)” to Yes. Enter a new “Secret Key”; you can create a new, random, secure key at <a href=\\\"https://www.random.org/passwords/?num=1&len=32&format=html&rnd=new\\\">random.org</a>. Then, click on Save &amp Close in the toolbar."
msgstr "Inicie sesión en el backend de su sitio. Vaya a Akeeba Backup, Configuración del sistema, API pública para que Panopticon pueda conectarse."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_CANNOTCONNECT_TIP_3"
msgid "Make sure that no third party extensions (especially security extensions) and/or server configuration settings prevent access to your site\'s <code>api</code> folder. Also check that the responses from that file are <em>not</em> cached by any third party plugins on your site, your web server, or any CDN / caching proxy which may be configured to be in front of your site."
msgstr "Asegúrese de que ninguna extensión de terceros (especialmente extensiones de seguridad) y/o configuración del servidor bloquee las solicitudes de la API."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_CANNOTCONNECT_TIP_3_WP"
msgid "Make sure that no third party plugins (especially security plugins) and/or server configuration settings prevent access to your site\'s <code>wp-admin/admin-ajax.php</code> file. Also check that the responses from that file are <em>not</em> cached by any third party plugins on your site, your web server, or any CDN / caching proxy which may be configured to be in front of your site."
msgstr "Asegúrese de que ningún plugin de terceros (especialmente plugins de seguridad) y/o configuración del servidor bloquee las solicitudes de la API."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_CORECHECKSUMS_HEAD"
msgid "Core File Integrity"
msgstr "Integridad de archivos del núcleo"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_CORECHECKSUMS_NEVER_RUN"
msgid "No core file integrity check has been run yet."
msgstr "Aún no se ha ejecutado ninguna verificación de integridad de archivos del núcleo."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_CORECHECKSUMS_CLEAN"
msgid "All core files are intact. Last checked: %s"
msgstr "Todos los archivos del núcleo están intactos. Última comprobación: %s"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_CORECHECKSUMS_MODIFIED"
msgid "%d modified core file(s) detected. Last checked: %s"
msgstr "%d archivo(s) del núcleo modificado(s) detectado(s). Última comprobación: %s"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_CORECHECKSUMS_BTN_DETAILS"
msgid "View Modified Files"
msgstr "Ver archivos modificados"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_CORECHECKSUMS_BTN_RUN"
msgid "Run Check"
msgstr "Ejecutar comprobación"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_CORECHECKSUMS_BTN_SCHEDULE"
msgid "Schedule"
msgstr "Programar"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WPAPI403_HEAD"
msgid "The WordPress JSON API application is blocked (HTTP error 403)"
msgstr "La aplicación API JSON de WordPress está bloqueada (error HTTP 403)"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WPAPI403_CHECK1"
msgid "Does your host, or your server configuration file (e.g. <code>.htaccess</code>), block access to the WordPress API Application endpoint (<span class=\"font-monospace\">%s</span>) altogether?"
msgstr "¿Su proveedor de alojamiento, o su archivo de configuración del servidor (p.ej. <code>.htaccess</code>), bloquea el acceso a determinadas rutas URL?"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WPAPI403_CHECK2"
msgid "Does your host have a server–side protection solution (such as Apache\'s mod_security2) which might be blocking the WordPress API Application endpoint (<span class=\"font-monospace\">%s</span>), your API token (<span class=\"font-monospace\">%s</span>), or the User-Agent of Panopticon (<span class=\"font-monospace\">panopticon/%s</span>)?"
msgstr "¿Su proveedor de alojamiento tiene una solución de protección a nivel de servidor (como mod_security de Apache) que puede estar bloqueando solicitudes de API?"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WPAPI403_CHECK3"
msgid "Do you have a security, SEO, or other similar plugin which may be blocking the above?"
msgstr "¿Tiene un plugin de seguridad, SEO u otro similar que pueda estar bloqueando el acceso a la API?"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_DIRTYOUTPUTWP_HEAD"
msgid "The WordPress JSON API Application response includes non-API output"
msgstr "La respuesta de la aplicación API JSON de WordPress incluye salida que no es de la API"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_DIRTYOUTPUTWP_BLAH1"
msgid "The response from the API is preceded and / or followed by other text content such as PHP messages (e.g. deprecation notices, warnings, or fatal errors), or output from third party plugins. As a result, the API response cannot be decoded, meaning that Panopticon cannot understand your site\'s response."
msgstr "La respuesta de la API está precedida y/o seguida por otro contenido de texto como mensajes de error de PHP o salida de depuración."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_DIRTYOUTPUTWP_BLAH2"
msgid "Make sure PHP on your server is configured with <code>display_errors</code> disabled, and that you have not enabled <code>WP_DEBUG</code> in your site\'s <code>wp-config.php</code> file. This prevents PHP from printing messages which pollute the API response."
msgstr "Asegúrese de que PHP en su servidor esté configurado con <code>display_errors</code> desactivado."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_DIRTYOUTPUTWP_BLAH3"
msgid "If this is not enough, it is possible that a third party plugin is causing an error in the API application. Check if there are any third party plugins, including any must-use plugins (<code>mu-plugins</code>), which may be accidentally breaking the API plugin and contact their author."
msgstr "Si eso no es suficiente, es posible que un plugin de terceros esté causando un error que produzca salida adicional. Deshabilite los plugins de terceros temporalmente para diagnosticar el problema."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WPNOTJSON_HEAD"
msgid "The WordPress JSON API application responded with non-JSON data"
msgstr "La aplicación API JSON de WordPress respondió con datos no JSON"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WPNOTJSON_BLAH1"
msgid "The WordPress JSON API application is supposed to respond with JSON data. Your server returned non-JSON data. This means that something is broken on your site."
msgstr "Se supone que la aplicación API JSON de WordPress debe responder con datos JSON. Su sitio no está respondiendo correctamente a las solicitudes de la API."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WPNOTJSON_BLAH2"
msgid "Please make sure that there is no .htaccess code, third party plugins, or custom code (including in your theme\'s <code>functions.php</code> file) which block or otherwise limit WordPress\' JSON API – either at all, or for unauthenticated (guest) access."
msgstr "Por favor, asegúrese de que no haya código .htaccess, plugins de terceros o código personalizado que intercepte las solicitudes de la API y devuelva una respuesta no JSON."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WP_HTTPERROR_HEAD"
msgid "The WordPress JSON API Application responded with an unexpected HTTP status code (%s)"
msgstr "La aplicación API JSON de WordPress respondió con un código de estado HTTP inesperado"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WP_HTTPERROR_5XX"
msgid "The HTTP status code %s means there has been a server error. Check if there are any third party plugins which may be accidentally breaking the WordPress JSON API application and contact their author."
msgstr "El código de estado HTTP %s significa que ha habido un error del servidor. Compruebe si hay errores en los registros del servidor."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WP_HTTPERROR_400"
msgid "The HTTP status code 400 usually means that your site can only be accessed by a limited number of domain names; the one you tried using (<span class=\"font-monospace\">%s</span>) may not be one of them. Please contact your host if you are unsure why you are receiving this message."
msgstr "El código de estado HTTP 400 generalmente significa que solo se puede acceder a su sitio desde una IP o rango de IPs específico, y la IP de Panopticon está bloqueada."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WP_401_HEAD"
msgid "WordPress believes that your API Token is incorrect, corrupt, or otherwise cannot log you in."
msgstr "WordPress considera que su token de API es incorrecto, está corrupto o no puede ser validado"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WP_401_BLAH1"
msgid "Make sure that the API Token you are using is up-to-date, and that you have not accidentally truncated it, or copied any whitespace around it."
msgstr "Asegúrese de que el token de API que está usando esté actualizado y de que no haya caducado."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WP_401_BLAH2"
msgid "Make sure that the plugin “Akeeba Panopticon Connector for WordPress” is enabled on your site."
msgstr "Asegúrese de que el plugin \"Akeeba Panopticon Connector para WordPress\" esté habilitado."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WP_401_BLAH3"
msgid "It is also possible that something on your server, or a plugin on your site, is corrupting the API Token as it is transmitted to your site."
msgstr "También es posible que algo en su servidor, o un plugin en su sitio, esté modificando la solicitud que enviamos, lo que hace que la autenticación falle."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WP_401_BLAH4"
msgid "Please check your installed plugins. Kindly note that no, Admin Tools Professional for WordPress <em>does not</em> interfere with the Panopticon API Token. If this does not help please contact your host."
msgstr "Por favor, revise sus plugins instalados. Cabe señalar que Admin Tools Professional no bloquea la API de WordPress."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_HUH_WPGENERIC"
msgid "Most likely a plugin on your server modified the request we sent, resulting in an error. Please check your installed plugins."
msgstr "Lo más probable es que un plugin en su sitio haya modificado la solicitud que enviamos, lo que resultó en una respuesta inesperada."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WPAPITOKEN_HEAD"
msgid "Your site believes that your API Token is incorrect, corrupt, or otherwise cannot log you in."
msgstr "Su sitio considera que su token de API es incorrecto, está corrupto o no puede ser validado"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WPAPITOKEN_BLAH1"
msgid "Make sure that the API Token you are using is up-to-date, and that you have not accidentally truncated it, or copied any whitespace around it."
msgstr "Asegúrese de que el token de API que está usando esté actualizado y de que no haya caducado."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WPAPITOKEN_BLAH2"
msgid "Make sure that the plugin “Akeeba Panopticon Connector for WordPress” is enabled on your site."
msgstr "Asegúrese de que el plugin \"Akeeba Panopticon Connector para WordPress\" esté habilitado."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WPAPITOKEN_BLAH3"
msgid "It is also possible that something on your server, or a plugin on your site, is corrupting the API Token as it is transmitted to your site."
msgstr "También es posible que algo en su servidor, o un plugin en su sitio, esté modificando la solicitud que enviamos, lo que hace que la autenticación falle."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WPAPITOKEN_BLAH4"
msgid "Please check your installed plugins. Kindly note that no, Admin Tools Professional for WordPress <em>does not</em> interfere with the Panopticon API Token. If this does not help please contact your host."
msgstr "Por favor, revise sus plugins instalados. Cabe señalar que Admin Tools Professional no bloquea la API de WordPress."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_CURL_BLAH2"
msgid "Please consult the <a href=\"https://curl.se/libcurl/c/libcurl-errors.html\" target=\"_blank\">cURL library error code reference</a> for more information about the error. In most cases the problem is a network or server configuration issue - either the server you have installed Panopticon on, or the server your site is on - which requires contacting the respective host to help you address."
msgstr "Consulte la <a href=\"https://curl.se/libcurl/c/libcurl-errors.html\" target=\"_blank\">documentación de errores de libcurl</a> para obtener más información sobre este error."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_CURL_BLAH3"
msgid "In rare circumstances the problem may be caused by a third party plugin –especially security, cache, and SEO plugins– or an external CDN, proxy, or firewall which may modify or redirect the API request, even if they are not supposed to do so."
msgstr "En circunstancias raras, el problema puede ser causado por un plugin de terceros, especialmente plugins de seguridad."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WPCONNECTOR_HEAD"
msgid "The Akeeba Panopticon Connector for WordPress plugin is not enabled on your site"
msgstr "El plugin Akeeba Panopticon Connector para WordPress no está habilitado en su sitio"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WPCONNECTOR_BLAH"
msgid "Your WordPress site needs to have the Akeeba Panopticon Connector for WordPress plugin installed and enabled for Akeeba Panopticon to work with it."
msgstr "Su sitio WordPress necesita tener el plugin Akeeba Panopticon Connector para WordPress instalado y habilitado."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WPCONNECTOR_CHECK"
msgid "Please check the following:"
msgstr "Por favor, compruebe lo siguiente:"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WPCONNECTOR_CHECK1"
msgid "Have you installed the Akeeba Panopticon Connector for WordPress plugin on your site?"
msgstr "¿Ha instalado el plugin Akeeba Panopticon Connector para WordPress en su sitio?"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_WPCONNECTOR_CHECK2"
msgid "Go to wp-admin, Plugins. Is the “Akeeba Panopticon Connector for WordPress” plugin installed <em>and</em> activated?"
msgstr "Vaya a wp-admin, Plugins. ¿Está el plugin \"Akeeba Panopticon Connector para WordPress\" habilitado?"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_PLUGIN_J3_HEAD"
msgid "Cannot communicate with the “System - Panopticon Connector for Joomla 3” plugin on your site"
msgstr "No se puede comunicar con el plugin \"Sistema - Conector Panopticon para Joomla 3\""

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_PLUGIN_WP_HEAD"
msgid "Cannot communicate with the “Akeeba Panopticon Connector for WordPress” plugin on your site"
msgstr "No se puede comunicar con el plugin \"Akeeba Panopticon Connector para WordPress\""

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_PLUGIN_WP_BLAH1"
msgid "Panopticon uses its own plugin, “Akeeba Panopticon Connector for WordPress”, to provide the necessary API through WordPress\' JSON services API (<code>wp-json</code>)."
msgstr "Panopticon usa su propio plugin, \"Akeeba Panopticon Connector para WordPress\", para comunicarse con su sitio WordPress."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_TROUBLESHOOT_PLUGIN_WP_BLAH2"
msgid "Please go to your site\'s wp-admin backend and click on Plugins. Search for the “Akeeba Panopticon Connector for WordPress” plugin and enable it."
msgstr "Por favor, vaya al backend wp-admin de su sitio y haga clic en Plugins. Busque el plugin \"Akeeba Panopticon Connector para WordPress\" y actívelo."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_SUBHEAD_REGISTRATION"
msgid "User Registration"
msgstr "Registro de usuarios"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_SUBHEAD_PASSKEY"
msgid "Passkey login"
msgstr "Inicio de sesión con clave de paso"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_PWRESET"
msgid "Self-service Password Reset"
msgstr "Restablecimiento de contraseña de autoservicio"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_ACCURATE_PHP_CLI"
msgid "Accurate PHP-CLI path"
msgstr "Ruta exacta de PHP-CLI"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_ACCURATE_PHP_CLI_HELP"
msgid "Enable to have Akeeba Panopticon try to detect the accurate PHP-CLI path on your server. Disable if your server does not allow you to do that, locking your IP address out of your site for several minutes to hours when this happens (for example IONOS)."
msgstr "Active esta opción para que Akeeba Panopticon intente detectar la ruta exacta de PHP-CLI en su servidor."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PASSKEY_LOGIN"
msgid "Login with passkey"
msgstr "Inicio de sesión con clave de paso"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PASSKEY_LOGIN_NO_MFA"
msgid "Bypass MFA when using a passkey"
msgstr "Omitir MFA al usar una clave de paso"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PASSKEY_LOGIN_NO_PASSWORD"
msgid "Disable password login when login with passkey is set up"
msgstr "Desactivar inicio de sesión con contraseña cuando se configure inicio de sesión con clave de paso"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PASSKEY_LOGIN_NO_PASSWORD_OPT_USER"
msgid "Let the user decide"
msgstr "Que el usuario decida"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PASSKEY_LOGIN_FORCE_GROUPS"
msgid "Force passkey login for these groups"
msgstr "Forzar inicio de sesión con clave de paso para estos grupos"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PASSKEY_LOGIN_FORCE_SUPERUSER"
msgid "Force passkey login for Superusers"
msgstr "Forzar inicio de sesión con clave de paso para superusuarios"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PASSKEY_LOGIN_FORCE_ADMIN"
msgid "Force passkey login for Administrators"
msgstr "Forzar inicio de sesión con clave de paso para administradores"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PWRESET"
msgid "Allow self-service password reset"
msgstr "Permitir restablecimiento de contraseña de autoservicio"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PWRESET_MINTIME"
msgid "Minimum time between password reset requests (seconds)"
msgstr "Tiempo mínimo entre solicitudes de restablecimiento de contraseña (segundos)"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PWRESET_MAXFAILS"
msgid "Maximum failed password reset attempts"
msgstr "Intentos fallidos máximos de restablecimiento de contraseña"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PWRESET_MFA"
msgid "Password reset removes MFA"
msgstr "El restablecimiento de contraseña elimina MFA"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PWRESET_COMMON_SECURITY_NOTE"
msgid "<em>Caution</em>: Enabling this option will reduce the security of your installation."
msgstr "<em>Precaución</em>: Activar esta opción reducirá la seguridad de su instalación."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PWRESET_PASSKEYS"
msgid "Password reset removes passkeys"
msgstr "El restablecimiento de contraseña elimina claves de paso"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PWRESET_SUPERUSER"
msgid "Password reset allowed for Superusers"
msgstr "Restablecimiento de contraseña permitido para superusuarios"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PWRESET_ADMIN"
msgid "Password reset allowed for Administrators"
msgstr "Restablecimiento de contraseña permitido para administradores"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PWRESET_GROUPS"
msgid "Password reset allowed for these groups"
msgstr "Restablecimiento de contraseña permitido para estos grupos"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PWRESET_GROUPS_HELP"
msgid "Leaving empty will allow users in any user group to reset their password. Superuser and administrator restrictions take precedence over this option."
msgstr "Dejar vacío permitirá a los usuarios de cualquier grupo restablecer su contraseña. Los superusuarios y administradores tienen sus propias opciones de configuración."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_USER_REGISTRATION"
msgid "User registration"
msgstr "Registro de usuarios"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_USER_REGISTRATION_HELP"
msgid "Controls whether new users can create their own accounts. In \'Admin approval\' mode, an administrator must approve new accounts. In \'Self-approval\' mode, users activate their account via an email link."
msgstr "Controla si los nuevos usuarios pueden crear sus propias cuentas. En el modo \"Aprobación de administrador\", las cuentas requieren aprobación manual."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_OPT_REGISTRATION_DISABLED"
msgid "Disabled"
msgstr "Desactivado"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_OPT_REGISTRATION_ADMIN"
msgid "Admin approval"
msgstr "Aprobación de administrador"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_OPT_REGISTRATION_SELF"
msgid "Self-approval (email activation)"
msgstr "Autoaprobación (activación por correo electrónico)"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_REGISTRATION_ALLOWED_DOMAINS"
msgid "Allowed email domains"
msgstr "Dominios de correo electrónico permitidos"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_REGISTRATION_ALLOWED_DOMAINS_HELP"
msgid "Only email addresses from these domains will be allowed to register. Separate with commas or newlines. Leave empty to allow all domains."
msgstr "Solo se permitirán registros con direcciones de correo electrónico de estos dominios. Separe con comas."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_REGISTRATION_DISALLOWED_DOMAINS"
