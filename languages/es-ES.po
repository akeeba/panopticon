#, phpformat
msgctxt "PANOPTICON_DBTOOLS_LBL_INFO_BODY"
msgid "The database backups are SQL files, either plain or compressed with Gzip. Both file types can be restored with common database tools provided by your host such as phpMyAdmin, Adminer, or even the command-line <code>mysql</code> command."
msgstr "Las copias de seguridad de la base de datos son archivos SQL, ya sea simples o comprimidos con Gzip. Ambos tipos de archivo pueden restaurarse con herramientas de base de datos comunes proporcionadas por su proveedor de alojamiento, como phpMyAdmin, Adminer, o incluso el comando <code>mysql</code> desde la línea de comandos."

