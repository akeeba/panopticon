msgid "Unknown PHP %s"
msgstr "PHP %s desconocido"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_PHP_UNKNOWN_INFO"
msgid "Your version of PHP is not known to Panopticon. Try clearing the <code>cache</code> folder."
msgstr "Su versión de PHP no es conocida por Panopticon. Intente vaciar la <code>caché</code> y vuelva a intentarlo."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_PHP_EOL"
msgid "End-of-Life PHP %s"
msgstr "PHP %s al fin de vida útil"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_PHP_EOL_INFO"
msgid "PHP %s reached its End-of-Life on %s. You should upgrade your site to PHP %s or later."
msgstr "PHP %s llegó a su fin de vida útil el %s. Debería actualizar su sitio a PHP %s o superior."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_PHP_LTS_HEAD"
msgid "Note about “long term support” Linux distributions"
msgstr "Nota sobre las distribuciones Linux de \"soporte a largo plazo\""

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_PHP_LTS_P1"
msgid "Some Linux Distributions, such as RedHat Enterprise Linux and Ubuntu Server, may offer “long term support” for certain PHP versions past their End of Life date."
msgstr "Algunas distribuciones Linux, como RedHat Enterprise Linux y Ubuntu Server, pueden incluir versiones de PHP que ya han llegado al fin de vida útil según el proyecto PHP."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_PHP_LTS_P2"
msgid "Please note that this typically requires an additional, often expensive, per-server license. Moreover, some security fixes which require changes in the internal PHP architecture cannot be applied in these old PHP versions. Finally, functional issues (‘bugs’) and compatibility with newer Internet standards and best practices are <em>never</em> addressed."
msgstr "Tenga en cuenta que esto generalmente requiere un servicio adicional, a menudo costoso, por servidor."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_PHP_LTS_P3"
msgid "While these Long Term Support distributions are useful for specific use cases - such as company intranets and extranets - they are ultimately not suitable for long term use on a publicly accessible website. We strongly recommend installing and using one of the actively supported PHP branches (currently, PHP versions %s and %s)."
msgstr "Si bien estas distribuciones de soporte a largo plazo son útiles para casos de uso específicos, el mantenimiento de seguridad que ofrecen tiene un alcance limitado."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_PHP_PHP"
msgid "PHP %s"
msgstr "PHP %s"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_WHERE_DID_I_GET_DATA"
msgid "Data source"
msgstr "Fuente de datos"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_PHP_UPDATE_AVAILABLE"
msgid "The latest PHP %s version is %s. You need to update PHP on your server."
msgstr "La versión más reciente de PHP %s es %s. Necesita actualizar PHP en su servidor."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_PHP_SECURITY_ONLY"
msgid "This version of PHP receives security updates, but no bug fixes. It will become End of Life on %s."
msgstr "Esta versión de PHP recibe actualizaciones de seguridad, pero no correcciones de errores. Llegará al fin de vida útil el %s."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_PHP_SHOULD_UPGRADE"
msgid "You should upgrade to PHP %s as soon as possible."
msgstr "Debería actualizar a PHP %s lo antes posible."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_PHP_VERSION_INFO"
msgid "This version of PHP receives security updates and bug fixes until %s. It will become End of Life on %s."
msgstr "Esta versión de PHP recibe actualizaciones de seguridad y correcciones de errores hasta %s. Llegará al fin de vida útil el %s."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_PHP_NEWER_BRANCH_AVAILABLE"
msgid "There is a newer PHP version family available, PHP %s. It is strongly recommended that you update to this version before %s."
msgstr "Hay disponible una familia de versiones de PHP más nueva, PHP %s. Se recomienda encarecidamente planificar una actualización."

