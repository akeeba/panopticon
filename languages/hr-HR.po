msgstr "Potvrdite prijavu pristupnim ključem"

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_LBL_CONFIGURED"
msgid "You have already configured this Passkey. Please note that you can only modify its title from this page."
msgstr "Već ste konfigurirali ovaj pristupni ključ. Napominjemo da s ove stranice možete izmijeniti samo njegov naslov."

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_LBL_INSTRUCTIONS"
msgid "Follow the instructions on your device\'s screen to use your preferred Passkey."
msgstr "Slijedite upute na zaslonu vašeg uređaja za korištenje preferiranog pristupnog ključa."

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_ERR_NOTAVAILABLE_HEAD"
msgid "Your browser lacks support for Passkeys"
msgstr "Vaš preglednik ne podržava pristupne ključeve"

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_ERR_NOTAVAILABLE_BODY"
msgid "Your browser doesn\'t support Passkeys, or your site does not meet the minimum requirements (HTTPS-only, with an SSL/TLS certificate signed by a commercial Certification Authority)."
msgstr "Vaš preglednik ne podržava pristupne ključeve, ili vaše web-mjesto ne ispunjava minimalne zahtjeve (samo HTTPS, s SSL/TLS certifikatom potpisanim od strane komercijalnog certifikacijskog tijela)."

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_ERR_NO_STORED_CREDENTIAL"
msgid "You have not configured a Passkey yet or the Passkey you are trying to use is unknown to this site."
msgstr "Još niste konfigurirali pristupni ključ ili pristupni ključ koji pokušavate koristiti nije poznat ovom web-mjestu."

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_ERR_CREATE_NO_PK"
msgid "The server has not issued a Public Key for Passkey registration but somehow received an authenticator registration request from the browser. This means that someone tried to hack you, or something is terribly broken."
msgstr "Poslužitelj nije izdao javni ključ za registraciju pristupnog ključa, ali je nekako primio zahtjev za registraciju autentikatora od preglednika. To znači da vas je netko pokušao hakirati ili je nešto ozbiljno pokvareno."

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_ERR_CREATE_INVALID_PK"
msgid "The Passkey registration has failed. The response received from the browser does not match the Public Key issued by the server. This means that someone tried to hack you, or something is terribly broken."
msgstr "Registracija pristupnog ključa nije uspjela. Odgovor primljen od preglednika ne odgovara javnom ključu koji je izdao poslužitelj. To znači da vas je netko pokušao hakirati ili je nešto ozbiljno pokvareno."

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_ERR_CREATE_INVALID_USER"
msgid "For security reasons you are not allowed to register Passkeys on behalf of another user."
msgstr "Iz sigurnosnih razloga nije vam dopušteno registrirati pristupne ključeve u ime drugog korisnika."

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_ERR_CREATE_NO_ATTESTED_DATA"
msgid "Something went wrong but no further information about the error is available at this time. Please retry registering your Passkey."
msgstr "Nešto je pošlo po zlu, ali trenutno nisu dostupne daljnje informacije o pogrešci. Molimo pokušajte ponovo registrirati vaš pristupni ključ."

#, phpformat
msgctxt "PANOPTICON_MFA_PASSKEYS_ERR_CREATE_INVALID_LOGIN_REQUEST"
msgid "Invalid authentication request."
msgstr "Nevažeći zahtjev za autentičnost."

