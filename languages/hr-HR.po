msgstr "Depurar sistema"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_LOGIN_FAILURE_ENABLE"
msgid "Automatic IP block on failed login attempts"
msgstr "Bloqueo automático de IP en intentos fallidos de inicio de sesión"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_LOGIN_MAX_FAILURES"
msgid "Maximum login failures"
msgstr "Número máximo de fallos de inicio de sesión"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_LOGIN_FAILURE_WINDOW"
msgid "Login failure window"
msgstr "Ventana de tiempo para fallos de inicio de sesión"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_LOGIN_LOCKOUT"
msgid "IP block time"
msgstr "Tiempo de bloqueo de IP"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_LOGIN_LOCKOUT_EXTEND"
msgid "Extend IP lockout time"
msgstr "Extender el tiempo de bloqueo de IP"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_LOGIN_LOCKOUT_EXTEND_HELP"
msgid "When enabled, every time a blocked IP address tries to access Akeeba Panopticon it will have its lockout time reset, i.e. the lockout will be extended for another “IP lockout time” seconds. This penalises some bots, but it comes at the expense of slowing down legitimate access to Akeeba Panopticon."
msgstr "Cuando está habilitado, cada vez que una IP bloqueada intenta acceder a Akeeba Panopticon se extiende el tiempo de bloqueo."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PASSWORD_HIBP"
msgid "Forbid using leaked passwords"
msgstr "Prohibir el uso de contraseñas filtradas"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PASSWORD_HIBP_HELP"
msgid "Prevent users from using passwords which are found in online password leaks. Powered by the third party service <a href=\'https://haveibeenpwned.com/\' _target=\'blank\'>Have I Been Pwned</a>."
msgstr "Evita que los usuarios usen contraseñas encontradas en filtraciones de contraseñas en línea. Funciona gracias al servicio Have I Been Pwned."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_STATS_COLLECTION"
msgid "Anonymous Usage Statistics Collection"
msgstr "Recopilación de estadísticas de uso anónimas"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_STATS_COLLECTION_HELP"
msgid "Akeeba Panopticon collects anonymous information about the Panopticon, PHP, and database server version. This aggregated information allows Akeeba to determine which versions of PHP and database servers to support in future releases."
msgstr "Akeeba Panopticon recopila información anónima sobre el entorno de Panopticon, PHP y la base de datos. Esta información se usa para mejorar el software."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_STATS_COLLECTION_HELP_LEARN_MORE"
msgid "Details of the information collected."
msgstr "Detalles de la información recopilada."

#, phpformat
