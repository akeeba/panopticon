#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_NOTFOUND_HEAD"
msgid "Akeeba Backup not found."
msgstr "Akeeba Backup nije pronađen."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_NOTFOUND_BODY"
msgid "You need to install Akeeba Backup Professional on your site to schedule and execute backups through Panopticon."
msgstr "Trebate instalirati Akeeba Backup Professional na vaše web-mjesto kako biste zakazali i izveli sigurnosne kopije putem Panopticona."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_NOTFOUND_NOTE_FOR_AFTERWARDS"
msgid "After installing Akeeba Backup Professional please go back to the site overview page to link Akeeba Backup with Panopticon."
msgstr "Nakon instalacije Akeeba Backup Professional molimo se vratite na stranicu pregleda web-mjesta kako biste povezali Akeeba Backup s Panopticonom."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_NOTFOUND_SOLUTION"
msgid "After installing Akeeba Backup Professional please click the button below to tell Panopticon to relink with the Akeeba Backup installation on your site."
msgstr "Nakon instalacije Akeeba Backup Professional kliknite na gumb ispod kako biste rekli Panopticonu da se ponovo poveže s Akeeba Backup instalacijom na vašem web-miestu."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_CORE_HEAD"
msgid "Akeeba Backup Core is not compatible with Panopticon."
msgstr "Akeeba Backup Core nije kompatibilan s Panopticonom."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_CORE_BODY"
msgid "You need to install Akeeba Backup Professional on your site to schedule and execute backups through Panopticon."
msgstr "Trebate instalirati Akeeba Backup Professional na vaše web-mjesto kako biste zakazali i izveli sigurnosne kopije putem Panopticona."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_CANNOTCONNECT_HEAD"
msgid "Cannot find a way to connect to Akeeba Backup."
msgstr "Nije moguće pronaći način za spajanje na Akeeba Backup."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_CANNOTCONNECT_BODY"
msgid "Panopticon cannot find a way to connect to your site\'s Akeeba Backup JSON API."
msgstr "Panopticon ne može pronaći način za spajanje na Akeeba Backup JSON API vašeg web-mjesta."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_NOTLINKED_HEAD"
msgid "Akeeba Backup is not linked."
msgstr "Akeeba Backup nije povezan."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_NOTLINKED_BODY"
msgid "This may happen if Akeeba Backup was installed after adding the site to Akeeba Panopticon, the Panopticon Connector installed on the site is too old, or if there\'s been an error communicating with the site."
msgstr "To se može dogoditi ako je Akeeba Backup instaliran nakon dodavanja web-mjesta u Akeeba Panopticon, ako je Panopticon Connector instaliran na web-miestu prestar, ili ako je došlo do pogreške u komunikaciji s web-mjestom."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_NOTLINKED_SOLUTION_ADMIN"
msgid "Please click the button below to try relinking Akeeba Backup with Panopticon. If this doesn\'t work please update the Akeeba Panopticon Connector on your site, make sure its plugin is published, and check if you can communicate with the site correctly."
msgstr "Kliknite na gumb ispod da pokušate ponovo povezati Akeeba Backup s Panopticonom. Ako to ne uspije, ažurirajte Akeeba Panopticon Connector na vašem web-miestu, provjerite je li mu dodatak objavljen i provjerite možete li ispravno komunicirati s web-mjestom."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_NOTLINKED_SOLUTION_NONADMIN"
msgid "Please contact an administrator to relink Akeeba Backup with Panopticon."
msgstr "Kontaktirajte administratora za ponovno povezivanje Akeeba Backupa s Panopticonom."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_COMSERROR_HEAD"
msgid "There has been a communication error with the Akeeba Panopticon Connector on the remote site."
msgstr "Došlo je do pogreške u komunikaciji s Akeeba Panopticon Connectorom na udaljenom web-miestu."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_GUZZLE"
msgid "We tried asking the Panopticon API on your site to provide information about the installation status of Akeeba Backup, but we received an error instead."
msgstr "Pokušali smo zatražiti od Panopticon API-ja na vašem web-miestu informacije o statusu instalacije Akeeba Backupa, ali smo umjesto toga dobili pogrešku."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_INVALIDAPI_HEAD"
msgid "Invalid response from the API when checking for the status of Akeeba Backup"
msgstr "Nevažeći odgovor od API-ja pri provjeri statusa Akeeba Backupa"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_INVALIDAPI"
msgid "We tried asking the Panopticon API on your site to provide information about the installation status of Akeeba Backup, but it did not respond correctly."
msgstr "Pokušali smo zatražiti od Panopticon API-ja na vašem web-miestu informacije o statusu instalacije Akeeba Backupa, ali nije odgovorio ispravno."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_INVALIDAPI_PLEASE_CHECK_VERSION"
msgid "Please make sure you have a version of Akeeba Backup newer than 9.6.0."
msgstr "Provjerite imate li verziju Akeeba Backupa noviju od 9.6.0."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_INVALIDAPI_PLEASE_CHECK_VERSION_J3"
msgid "Please make sure you have a version of Akeeba Backup newer than 8.3.0."
msgstr "Provjerite imate li verziju Akeeba Backupa noviju od 8.3.0."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_INVALIDAPI_OR_CHECK_ERRORS"
msgid "If that does not help, please check below for any errors, or irregular response from the API."
msgstr "Ako to ne pomogne, provjerite ispod ima li pogrešaka ili nepravilnih odgovora od API-ja."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_JSONAPI_ERROR_HEAD"
msgid "There has been a communication error with the Akeeba Backup JSON API on your site"
msgstr "Došlo je do pogreške u komunikaciji s Akeeba Backup JSON API-jem na vašem web-miestu"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_JSONAPI_ERROR"
msgid "The API indicated there is an error. Please make sure that you have entered the correct API Token, and that your site\'s server does not block or otherwise interfere with the request."
msgstr "API je označio da postoji pogreška. Provjerite jeste li unijeli ispravni API Token i da poslužitelj vašeg web-mjesta ne blokira niti na drugi način ne ometa zahtjev."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_CONNECTOR_VERSION"
msgid "Panopticon Connector v.%s"
msgstr "Panopticon Connector v.%s"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_CONNECTOR_API"
