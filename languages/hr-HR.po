msgstr "Broj <code>1</code> do <code>12</code>, raspon npr. <code>1-6</code>, odvojen zarezom npr. <code>1,4,7,10</code>, svaki mjesec kao <code>*</code>, svakih X mjeseci s kosom crtom npr. <code>*/3</code> (svakih 3 mjeseca)."

#, phpformat
msgctxt "PANOPTICON_CHECKSUMTASKS_LBL_DOW"
