msgid "Batch process the selected sites"
msgstr "Skupna obrada odabranih web-mjesta"

#, phpformat
msgctxt "PANOPTICON_SITES_BATCH_PROCESS"
msgid "Process"
msgstr "Obrada"

#, phpformat
