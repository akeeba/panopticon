msgstr "<p>Unesite lozinku ispod. Ova lozinka bit će potrebna za unos nakon prijave prije nego što budete mogli koristiti web-mjesto.</p>"

#, phpformat
msgctxt "PANOPTICON_MFA_FIXED_LBL_SETUP_POSTMESSAGE"
msgid "<p class=\"alert alert-info\">The messages appearing above and below the setup area can be customized by overriding the language strings <code>PANOPTICON_MFA_FIXED_LBL_SETUP_PREMESSAGE</code> and <code>PANOPTICON_MFA_FIXED_LBL_SETUP_POSTMESSAGE</code></p>"
msgstr "<p class=\"alert alert-info\">Poruke koje se pojavljuju iznad i ispod područja za postavljanje mogu se prilagoditi prepisivanjem jezičnih nizova <code>PANOPTICON_MFA_FIXED_LBL_SETUP_PREMESSAGE</code> i <code>PANOPTICON_MFA_FIXED_LBL_SETUP_POSTMESSAGE</code></p>"

