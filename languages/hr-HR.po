msgstr "Dan u tjednu"

#, phpformat
msgctxt "PANOPTICON_CHECKSUMTASKS_LBL_DOW_HELP"
msgid "Number <code>0</code> to <code>7</code> (0 or 7 is Sunday), contiguous range e.g. <code>1-5</code>, comma–separated list of values e.g. <code>1,3,5</code>, every day as <code>*</code>."
msgstr "Broj <code>0</code> do <code>7</code> (0 ili 7 je nedjelja), raspon npr. <code>1-5</code>, odvojen zarezom npr. <code>1,3,5</code>, svaki dan kao <code>*</code>."

