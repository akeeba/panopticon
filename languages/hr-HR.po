msgctxt "PANOPTICON_CHECKSUMTASKS_LBL_DOM"
msgid "Day of the Month"
msgstr "Dan u mjesecu"

#, phpformat
msgctxt "PANOPTICON_CHECKSUMTASKS_LBL_DOM_HELP"
msgid "Number <code>1</code> to <code>31</code>, contiguous range e.g. <code>5-15</code>, comma–separated list of values e.g. <code>1,15</code>, every day as <code>*</code>, every X days using slash e.g. <code>*/2</code> (every 2 days)."
msgstr "Broj <code>1</code> do <code>31</code>, raspon npr. <code>5-15</code>, odvojen zarezom npr. <code>1,15</code>, svaki dan kao <code>*</code>, svakih X dana s kosom crtom npr. <code>*/2</code> (svakih 2 dana)."

