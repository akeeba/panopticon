#, phpformat
msgctxt "PANOPTICON_SITE_LBL_PHP_SECURITY_ONLY"
msgid "This version of PHP receives security updates, but no bug fixes. It will become End of Life on %s."
msgstr "Ova verzija PHP-a prima sigurnosna ažuriranja, ali nema ispravki grešaka. Postati će End of Life %s."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_PHP_SHOULD_UPGRADE"
