msgstr "Ostavljanjem praznog bit će dopušteno korisnicima u bilo kojoj grupi resetiranje lozinke. Superuporabnici i administratori uvijek se zasebno konfiguriraju."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_USER_REGISTRATION"
msgid "User registration"
msgstr "Registracija korisnika"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_USER_REGISTRATION_HELP"
msgid "Controls whether new users can create their own accounts. In \'Admin approval\' mode, an administrator must approve new accounts. In \'Self-approval\' mode, users activate their account via an email link."
msgstr "Kontrolira mogu li novi korisnici stvoriti vlastite račune. U načinu \"Odobrenje administratora\", administrator mora odobriti svaki novi račun."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_OPT_REGISTRATION_DISABLED"
