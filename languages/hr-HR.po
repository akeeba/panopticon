msgstr "Ponovo učitaj informacije o ažuriranju za web-mjesto \"%s\""

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SCHEDULE_OK"
msgid "Scheduled the Joomla core update."
msgstr "Ažuriranje Joomla jezgre je zakazano."

#, phpformat
msgctxt "PANOPTICON_SITE_ERR_JUPDATE_SCHEDULE_FAILED"
