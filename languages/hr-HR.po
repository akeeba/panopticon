#, phpformat
msgctxt "PANOPTICON_MFA_LBL_BACKUPCODES_DESCRIPTION"
msgid "Single-use codes to let you login to the site if none of the other methods can be used."
msgstr "Jednokratni kodovi koji vam omogućuju prijavu na web-mjesto ako se ne mogu koristiti nijedna druga metoda."

#, phpformat
msgctxt "PANOPTICON_MFA_LBL_BACKUPCODES_PRINT_PROMPT"
msgid "<strong><a href=\"%s\">Print these codes</a> and keep them in your wallet</strong>. <span class=\"text-muted\">Backup codes let you log into the site if your regular Multi-factor Authentication method does not work or you no longer have access to it. Each code can be used <em>only once</em>.</span>"
msgstr "<strong><a href=\"%s\">Ispišite ove kodove</a> i čuvajte ih u novčaniku</strong>. <span class=\"text-muted\">Rezervni kodovi omogućuju vam prijavu na web-mjesto ako vaša uobičajena metoda višefaktorske autentičnosti ne funkcionira ili više nemate pristup njoj. Svaki kod može biti korišten <em>samo jednom</em>.</span>"

#, phpformat
msgctxt "PANOPTICON_MFA_LBL_BACKUPCODES_INSTRUCTIONS"
msgid "Print this page and keep it in your wallet. Each of the following codes below can be used only once. Use them in case of emergency, when none of the other Multi-factor Authentication methods you\'ve set up can be used. For example, if your phone is out of battery or misplaced."
msgstr "Ispišite ovu stranicu i čuvajte je u novčaniku. Svaki od sljedećih kodova može se koristiti samo jednom. Upotrijebite ih u slučaju nužde, kada se ne može koristiti nijedna druga metoda višefaktorske autentičnosti koju ste postavili. Na primjer, ako vam je telefon prazan ili ste ga izgubili."

#, phpformat
