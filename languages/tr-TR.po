msgstr "Planlanan güncelleme zaten çalışıyor."

msgctxt "PANOPTICON_SITE_ERR_WPUPDATE_UNSCHEDULE_FAILED"
msgid "Could not cancel the WordPress core update."
msgstr "WordPress çekirdek güncellemesi iptal edilemedi."

msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_HEAD"
msgid "WordPress Update"
msgstr "WordPress Güncellemesi"

msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_NO_VERSION_HEAD"
msgid "Version information missing"
msgstr "Sürüm bilgileri eksik"

msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_NO_VERSION_BODY"
msgid "Your site has not reported the version of WordPress it is running on."
msgstr "Siteniz, üzerinde çalıştığı WordPress sürümünü bildirmemiş."

msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_AVAILABLE_UPDATE"
msgid "WordPress %s is available"
msgstr "WordPress %s mevcut"

msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_CURRENT_VERSION"
msgid "Your site is currently using WordPress %s."
msgstr "Siteniz şu anda WordPress %s kullanıyor."

msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_IS_PATCH_RELEASE"
msgid "This is a patch (point) update which is almost always safe."
msgstr "Bu, neredeyse her zaman güvenli olan bir yama (özellik) güncellemesidir."

msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_IS_MINOR_RELEASE"
msgid ""
"This is a minor (version family) update which may affect your plugins, and "
"themes."
msgstr ""
"Bu, eklentilerinizi ve temalarınızı etkileyebilecek küçük bir güncellemedir "
"(sürüm ailesi)."

msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_MINOR_RELEASE_ADMONISHMENT"
msgid ""
"It is a good idea to take a backup of your site, and test this update on a copy "
"of your site first."
msgstr ""
"Sitenizin yedeğini almanız ve bu güncellemeyi önce sitenizin bir kopyası "
"üzerinde denemeniz iyi bir fikirdir."

msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_IS_MAJOR_RELEASE"
msgid ""
"This is a major version update which will most likely affect your plugins, and "
"themes."
msgstr ""
"Bu, eklentilerinizi ve temalarınızı büyük olasılıkla etkileyecek önemli bir "
"sürüm güncellemesidir."

msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_MAJOR_RELEASE_ADMONISHMENT"
msgid ""
"It is very strongly recommended that you take a backup of your site, and test "
"this update on a copy of your site first."
msgstr ""
"Sitenizin yedeğini almanız ve bu güncellemeyi önce sitenizin bir kopyası "
"üzerinde denemeniz şiddetle tavsiye edilir."

msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_EOL"
msgid "WordPress %s is unsupported"
msgstr "WordPress %s desteklenmiyor"

msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_CANNOT_INSTALL"
msgid ""
"The newer WordPress version %s is available but cannot be installed because of "
"your site preferences."
msgstr ""
"Daha yeni WordPress sürümü %s mevcuttur ancak site ayarlarınız nedeniyle "
"yüklenemiyor."

msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_EOL_DATE"
