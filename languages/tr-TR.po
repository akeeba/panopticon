msgctxt "PANOPTICON_TASKTYPE_USAGESTATS"
msgid "Usage statistics collection"
msgstr "Kullanım İstatistikleri Koleksiyonu"

msgctxt "PANOPTICON_TASKTYPE_DATABASEBACKUP"
msgid "Database backup"
msgstr "Veritabanı Yedeklemesi"

msgctxt "PANOPTICON_TASKTYPE_UPDATESUMMARYEMAIL"
msgid "Update summary email"
msgstr "Özet E-Postası Güncellemesi"

msgctxt "PANOPTICON_TASKTYPE_SSLTLSEXPIRATION"
msgid "Send emails about SSL/TLS certificate expiration"
msgstr "SSL/TLS sertifikasının süresinin dolması hakkında e-posta gönder"

msgctxt "PANOPTICON_TASKTYPE_UPTIMEMONITOR"
msgid "Monitors sites' uptime"
msgstr "Sitelerin Çalışma Sürelerinin İzlenmesi"

msgctxt "PANOPTICON_TASKTYPE_ACTIONSUMMARYEMAIL"
msgid "Sends a Site Action Summary email"
msgstr "Site Eylemleri Özet E-Postası Gönderilmesi"

msgctxt "PANOPTICON_TASKTYPE_WORDPRESSUPDATE"
msgid "Update WordPress core"
msgstr "WordPress Çekirdeğini Güncelle"

msgctxt "PANOPTICON_TASKTYPE_WORDPRESSUPDATEDIRECTOR"
msgid "Schedule Automatic WordPress Update"
msgstr "Otomatik Wordpress Güncellemesini Planlanlama"

msgctxt "PANOPTICON_TASKTYPE_PLUGINSUPDATE"
msgid "Update installed WordPress plugins and themes"
msgstr "Yüklü WordPress eklentilerini ve temalarını güncelle"

msgctxt "PANOPTICON_TASKTYPE_PLUGINUPDATESDIRECTOR"
msgid "Schedule automatic WordPress plugin and theme updates"
msgstr "WordPress eklenti ve tema güncellemelerini otomatik olarak planlayın"

msgctxt "PANOPTICON_TASKTYPE_DOMAINEXPIRATION"
msgid "Send emails about domain expiration"
msgstr "Alan adının süresinin dolmasıyla ilgili e-postalar gönder"

msgctxt "PANOPTICON_TASKTYPE_REGISTRATIONCLEANUP"
msgid "Clean up expired user registrations"
msgstr "Süresi dolmuş kullanıcı kayıtlarını temizle"

msgctxt "PANOPTICON_TASKTYPE_EXTENSIONINSTALL"
msgid "Remote Extension Installation"
msgstr "Uzaktan Eklenti Kurulumu"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_ERR_SITE_DISABLED"
msgid "Site %d is disabled"
msgstr "%d sitesi devre dışı bırakıldı"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_ERR_SITE_INVALIDID"
msgid "Invalid site ID"
msgstr "Geçersiz site kimliği"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_ERR_SITE_NOT_EXIST"
msgid "Site %d does not exist"
msgstr "%d sitesi mevcut değil"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_ERR_DOWNLOAD_FAILED"
msgid "Downloading the update package has failed"
msgstr "Güncelleme paketinin indirilmesi başarısız oldu"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_ERR_INVALID_CHECKSUM"
msgid "The downloaded update package has an invalid checksum."
msgstr "İndirilen güncelleme paketinde geçersiz bir sağlama toplamı var."

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_ERR_ENABLE_FAILED"
msgid "Enabling the Joomla Update extraction script has failed"
msgstr ""
"Joomla Güncelleme dosya ayıklama komut dosyasının etkinleştirilmesi başarısız "
"oldu"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_ERR_UPDATE_DISAPPEARED"
msgid ""
"The update package has disappeared from the site. Is a plugin, or your host, "
"clearing your site's temporary directory automatically?"
msgstr ""
"Güncelleme paketi siteden kayboldu. Bir eklenti veya sunucunuz sitenizin geçici "
"dizinini otomatik olarak temizliyor mu?"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_ERR_NO_PASSWORD"
msgid "Could not get the password for the Joomla Update extraction script"
msgstr "Joomla Güncelleme dosya ayıklama komut dosyasının şifresi alınamadı"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_ERR_FINALISE_FAILED"
msgid ""
"Finalising the update has failed. You may want to go to System, Maintenance, "
"Database and check if Joomla itself appears as up-to-date."
msgstr ""
"Güncellemenin sonlandırılması başarısız oldu. Sistem, Bakım, Veri Tabanı'na "
"gidip Joomla'nın güncel görünüp görünmediğini kontrol etmek isteyebilirsiniz."

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_ERR_NOT_J40"
msgid ""
"This is not a Joomla 4.0.0 to 4.0.3 (inclusive) site; cannot use restore.php for "
"updates."
msgstr ""
"Bu bir Joomla 4.0.0 ila 4.0.3 (dahil) sitesi değildir; güncellemeler için "
"restore.php'yi kullanamazsınız."

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_ERR_NOT_J404"
msgid ""
"This is not a Joomla 4.0.4 or later site; cannot use extract.php for updates."
msgstr ""
"Bu bir Joomla 4.0.4 veya üzeri site değildir; güncellemeler için extract.php'yi "
"kullanamazsınız."

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_ERR_UNEXPECTED_HTTP"
msgid "Unexpected HTTP %d while extracting the update; the site may be broken."
msgstr "Güncelleme dosyası ayıklanırken beklenmeyen HTTP %d; site bozuk olabilir."

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_ERR_HTTP_401"
msgid ""
"HTTP status 401 while extracting the update. Your site's administrator folder is "
"password protected. Please edit the site and enter the Administrator Directory "
"Username and Password in the Connection tab. Then, retry scheduling an update "
"for this site."
msgstr ""
"Güncelleme çıkarılırken HTTP durumu 401. Sitenizin yönetici klasörü parola "
"korumalıdır. Lütfen siteyi düzenleyin ve Bağlantı sekmesine Yönetici Dizini "
"Kullanıcı Adı ve Parolasını girin. Ardından, bu site için bir güncelleme "
"planlamayı yeniden deneyin."

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_ERR_INVALID_JSON"
msgid ""
"Invalid JSON response from the update extraction script; the site may be broken."
msgstr ""
"Güncelleme dosyası ayıkama komut dosyasından geçersiz JSON yanıtı; site bozuk "
"olabilir."

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_ERR_EXTRACTION_FAILED"
msgid ""
"The update extraction has failed; the site may be broken. Returned error "
"message: “%s”"
msgstr ""
"Güncelleme dosyası ayıklama işlemi başarısız oldu; site bozuk olabilir. "
"Döndürülen hata mesajı: “%s”"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_ERR_NO_FACTORY"
msgid ""
"The update extraction script did not return its internal state; the site may be "
"broken."
msgstr ""
"Güncelleme dosyası ayıklama komut dosyası dahili durumunu döndürmedi; site bozuk "
"olabilir."

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_ERR_FACTORY_GONE"
msgid ""
"Internal error extracting the update: we lost the internal state of the update "
"extraction script. The site may be broken."
msgstr ""
"Güncelleme dosyasını ayıklamada dahili hata: Güncelleme dosyasını ayıklama komut "
"dosyasının dahili durumunu kaybettik. Site bozulmuş olabilir."

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_ERR_RELOAD_UPDATES_FAILED"
msgid ""
"Could not reload the Joomla update information after applying the update; the "
"site may be broken."
msgstr ""
"Güncelleme uygulandıktan sonra joomla güncelleme bilgileri yeniden yüklenemedi; "
"site bozuk olabilir."

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_ERR_NO_UPDATE_AVAILABLE"
msgid ""
"The site %s (%s) is on Joomla %s. The latest available version is %s. Therefore, "
"it cannot be updated."
msgstr ""
"%s (%s) sitesi Joomla %s'da. Mevcut en son sürüm: %s. Bu nedenle güncellenemiyor."

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LBL_UNKNOWN_VERSION"
msgid "(Unknown)"
msgstr "(Bilinmeyen)"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LBL_UNKNOWN_SITE"
msgid "(Unknown Site)"
msgstr "(Bilinmeyen Site)"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LBL_UNKNOWN_TIME"
msgid "(Unknown)"
msgstr "(Bilinmeyen)"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LBL_UNKNOWN_DURATION"
msgid "(Unknown)"
msgstr "(Bilinmeyen)"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_PREPARING"
msgid "Preparing to update site %d (%s)"
msgstr "%d (%s) sitesi güncellenmeye hazırlanıyor"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_DOWNLOADING"
msgid "Downloading update package to site %d (%s)"
msgstr "Güncelleme paketi %d (%s) sitesine indiriliyor"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_DOWNLOADING_CHUNK_START"
msgid "Beginning multi-part download of the update package to site %d (%s)"
msgstr "Güncelleme paketinin %d (%s) sitesine çok parçalı indirilmesine başlanıyor"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_DOWNLOADING_CHUNK_CONTINUE"
msgid ""
"Continuing multi-part download of the update package to site %d (%s) from offset "
"%d"
msgstr ""
"Güncelleme paketinin %d (%s) sitesine %d konumundan çok parçalı olarak "
"indirilmesine devam ediliyor"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_DOWNLOADING_CHUNK_END"
msgid "Finished multi-part download of the update package to site %d (%s)"
msgstr ""
"Güncelleme paketinin %d (%s) sitesine çok parçalı olarak indirilmesi tamamlandı"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_DOWNLOADING_CHUNK_FAILED"
msgid ""
"The multi-part download of the update package to site %d (%s) has failed; will "
"try a single-part download instead"
msgstr ""
"Güncelleme paketinin %d (%s) sitesine çok parçalı indirilmesi başarısız oldu; "
"bunun yerine tek parçalı indirmeyi deneyeceğiz"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_PREUPDATE_EVENTS"
msgid "Executing pre-update events for site %d (%s)"
msgstr "%d (%s) sitesi için güncelleme öncesi etkinlikler yürütülüyor"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_PREUPDATE_WILL_CONTINUE"
msgid "Will continue executing pre-update events for site %d (%s)"
msgstr "%d (%s) sitesi için güncelleme öncesi etkinlikleri yürütmeye devam edecek"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_PREUPDATE_FINISHED"
msgid "Finished executing pre-update events for site %d (%s)"
msgstr "%d (%s) sitesi için güncelleme öncesi etkinliklerin yürütülmesi tamamlandı"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_BACKUP_DONE"
msgid "Done backing up before updating site %d (%s)"
msgstr "%d (%s) sitesi güncellenmeden önce yedekleme tamamlandı"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_BACKUP_DESCRIPTION"
msgid "Automatic backup taken by Panopticon before upgrading to Joomla! %s"
msgstr ""
"Joomla %s sürümüne yükseltmeden önce Panopticon tarafından alınan otomatik "
"yedekleme"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_BACKUP_NOT"
msgid "I will NOT take a backup before updating site %d (%s)"
msgstr "%d (%s) sitesini güncellemeden önce yedekleme ALMAYACAĞIM"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_BACKUP_START"
msgid "Starting a backup before updating site %d (%s)"
msgstr "%d (%s) sitesini güncellemeden önce yedekleme başlatılıyor"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_BACKUP_RESUME"
msgid "Continuing the backup before updating site %d (%s)"
msgstr "%d (%s) sitesi güncellenmeden önce yedeklemeye devam ediliyor"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_BACKUP_FAIL"
msgid "Failed to take a backup before updating site %d (%s); update canceled"
msgstr ""
"%d (%s) sitesi güncellenmeden önce yedekleme alınamadı; güncelleme iptal edildi"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_ENABLE_EXTRACT"
msgid "Enabling Joomla Update\\'s extraction script for site %d (%s)"
msgstr ""
"%d (%s) sitesi için Joomla Güncellemesinin dosya ayıklama komut dosyası "
"etkinleştiriliyor"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_EXTRACT_START"
msgid "Starting the update package extraction for site %d (%s)"
msgstr "%d (%s) sitesi için güncelleme paketi ayıklama işlemi başlatılıyor"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_EXTRACT_CONTINUE"
msgid "Continuing the update package extraction for site %d (%s)"
msgstr "%d (%s) sitesi için güncelleme paketinin ayıklanmasına devam ediliyor"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_EXTRACT_FINISH"
msgid "Finished the update package extraction for site %d (%s)"
msgstr "%d (%s) sitesi için güncelleme paketinin ayıklanması tamamlandı"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_POSTEXTRACT"
msgid "Cleaning up old files after extracting the update for site %d (%s)"
msgstr ""
"%d (%s) sitesi için güncelleme dosyası ayıklandıktan sonra eski dosyalar "
"temizleniyor"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_FINALISE"
msgid "Finalising the update for site %d (%s)"
msgstr "%d (%s) sitesi için güncelleme tamamlanıyor"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_POSTUPDATE_EVENTS"
msgid "Executing post-update events for site %d (%s)"
msgstr "%d (%s) sitesi için güncelleme sonrası etkinlikler yürütülüyor"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_POSTUPDATE_WILL_CONTINUE"
msgid "Will continue executing post-update events for site %d (%s)"
msgstr "%d (%s) sitesi için güncelleme sonrası etkinlikleri yürütmeye devam edecek"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_POSTUPDATE_FINISHED"
msgid "Finished executing post-update events for site %d (%s)"
msgstr ""
"%d (%s) sitesi için güncelleme sonrası etkinliklerin yürütülmesi tamamlandı"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_RELOAD_UPDATES"
msgid "Reloading Joomla update information on site %d (%s)"
msgstr "Joomla güncelleme bilgileri %d (%s) sitesine yeniden yükleniyor"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_RELOAD_SITEINFO"
msgid "Refreshing the site information for the just updated site %d (%s)"
msgstr "Yeni güncellenen %d (%s) sitesi için site bilgileri yenileniyor"

msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_LOG_WILL_BE_UPDATED"
msgid "Site %d (%s) will be updated from Joomla! %s to Joomla! %s."
msgstr "%d (%s) sitesi Joomla %s'den Joomla %s'ye güncellenecek."

msgctxt "PANOPTICON_TASK_WORDPRESSUPDATE_ERR_NO_UPDATE_AVAILABLE"
msgid ""
"The site %s (%s) is on WordPress %s. The latest available version is %s. "
"Therefore, it cannot be updated."
msgstr ""
"%s (%s) sitesi WordPress %s sürümünde çalışıyor. Mevcut en son sürüm %s'dir. Bu "
"nedenle site güncellenemiyor."

msgctxt "PANOPTICON_TASK_WORDPRESSUPDATE_LOG_WILL_BE_UPDATED"
msgid "Site %d (%s) will be updated from WordPress %s to WordPress %s."
msgstr ""
"%d (%s) sitesi, WordPress %s sürümünden WordPress %s sürümüne güncellenecektir."

msgctxt "PANOPTICON_TASK_WORDPRESSUPDATE_LOG_BACKUP_DESCRIPTION"
msgid "Automatic backup taken by Panopticon before upgrading to WordPress %s"
msgstr ""
"WordPress %s sürümüne yükseltme işleminden önce Panopticon tarafından alınan "
"otomatik yedek"

msgctxt "PANOPTICON_TASK_WORDPRESSUPDATE_LOG_INSTALLING"
msgid "Installing WordPress update on site #%d (%s) starts now"
msgstr ""
"%d numaralı sitede (%s) WordPress güncellemesinin yüklenmesi şimdi başlıyor"

msgctxt "PANOPTICON_TASK_WORDPRESSUPDATE_ERR_HTTP"
msgid "Installing WordPress update on site #%d (%s) has failed with HTTP error %d"
msgstr ""
"#%d (%s) sitesinde WordPress güncellemesinin yüklenmesi HTTP hatası %d ile "
"başarısız oldu"

msgctxt "PANOPTICON_TASK_WORDPRESSUPDATE_ERR_WORDPRESS"
msgid ""
"Installing WordPress update on site #%d (%s) has failed with WordPress error %d: "
"%s"
msgstr ""
"Site #%d (%s) üzerinde WordPress güncellemesi yükleme işlemi, WordPress hatası "
"%d: %s nedeniyle başarısız oldu"

msgctxt "PANOPTICON_TASK_WORDPRESSUPDATE_ERR_STATUS_FALSE"
msgid ""
"Installing WordPress update on site #%d (%s) has failed. The site provided no "
"other error information."
msgstr ""
"#%d (%s) sitesinde WordPress güncellemesi yükleme işlemi başarısız oldu. Site "
"başka bir hata bilgisi sağlamadı."

msgctxt "PANOPTICON_TASK_WORDPRESSUPDATE_ERR_NOT_FOUND"
msgid ""
"Installing WordPress update on site #%d (%s) has failed. The site claims no "
"update has been found. Did you turn on automatic updates in WordPress, or have a "
"different service update the site?"
msgstr ""
"Site #%d (%s) üzerinde WordPress güncellemesi yükleme başarısız oldu. Site, "
"herhangi bir güncelleme bulunmadığını belirtiyor. WordPress'te otomatik "
"güncellemeleri etkinleştirdiniz mi, yoksa farklı bir servis mi siteyi güncelledi?"

msgctxt "PANOPTICON_TASK_WORDPRESSUPDATE_ERR_INVALID_JSON"
msgid ""
"Installing WordPress update on site #%d (%s) has failed. The server's response "
"is not valid JSON."
msgstr ""
"#%d (%s) numaralı sitede WordPress güncellemesi yükleme işlemi başarısız oldu. "
"Sunucunun yanıtı geçerli bir JSON değil."

msgctxt "PANOPTICON_SETUP_TITLE"
msgid "Installation"
msgstr "Kurulum"

msgctxt "PANOPTICON_SETUP_SUBTITLE_PRECHECK"
msgid "Check Requirements"
msgstr "Gereksinimleri Kontrol Edin"

msgctxt "PANOPTICON_SETUP_SUBTITLE_DATABASE"
msgid "Database Configuration"
msgstr "Veritabanı Yapılandırması"

msgctxt "PANOPTICON_SETUP_SUBTITLE_SETUP"
msgid "User Setup"
msgstr "Kullanıcı Ayarı"

msgctxt "PANOPTICON_SETUP_SUBTITLE_CRON"
msgid "CRON Job Setup"
msgstr "CRON Job Ayarı"

msgctxt "PANOPTICON_SETUP_SUBTITLE_FINISH"
msgid "Finished"
msgstr "Tamamlanmış"

msgctxt "PANOPTICON_SETUP_LBL_HEAD_WELCOME"
msgid "Welcome to %s"
msgstr "%s'e hoş geldiniz"

msgctxt "PANOPTICON_SETUP_LBL_WELCOME_HERO_TEXT"
msgid ""
"You can use Panopticon to monitor your Joomla!&reg; sites. But first, we need to "
"make sure your server meets the minimum requirements."
msgstr ""
"Joomla™ sitelerinizi izlemek için Panopticon'u kullanabilirsiniz. Ancak "
"öncelikle sunucunuzun en düşük gereksinimleri karşıladığından emin olmamız "
"gerekiyor."

msgctxt "PANOPTICON_SETUP_BTN_LETS_GO"
msgid "Let's go!"
msgstr "Hadi gidelim!"

msgctxt "PANOPTICON_SETUP_SESSION_LBL_WARNING_HEADER"
msgid "Create a new session save path"
msgstr "Yeni bir oturum kaydetme yolu oluşturun"

msgctxt "PANOPTICON_SETUP_SESSION_LBL_WARNING_BODY"
msgid ""
"The session write path configured in PHP cannot be written to, making logging in "
"impossible. To address this problem, Panopticon will attempt to create a session "
"save path in the <code>%s</code> directory. For this to be possible, you need to "
"enter the FTP or SFTP connection details to your site's root. If you are unsure "
"about these settings, please ask your host."
msgstr ""
"PHP'de yapılandırılan oturum yazma yoluna yazılamadığından oturum açmayı "
"imkansız hale getirir. Bu sorunu çözmek için Panopticon <code>%s</code> "
"dizininde bir oturum kaydetme yolu oluşturmaya çalışacaktır. Bunun mümkün "
"olabilmesi için sitenizin kök dizinine FTP veya SFTP bağlantı ayrıntılarını "
"girmeniz gerekmektedir. Bu ayarlardan emin değilseniz lütfen barındırıcınıza "
"sorun."

msgctxt "PANOPTICON_SETUP_SESSION_LBL_ERROR_HEADER"
msgid "An error occurred while trying to create a session save path"
msgstr "Oturum kaydetme yolu oluşturulmaya çalışılırken bir hata oluştu"

msgctxt "PANOPTICON_SETUP_LBL_FS_DRIVER_SESSION"
msgid "Connection method"
msgstr "Bağlanma Yöntemi"

msgctxt "PANOPTICON_SETUP_BTN_MAKE_SESSION_FOLDER"
msgid "Create a session path"
msgstr "Bir oturum yolu oluşturun"

msgctxt "PANOPTICON_SETUP_BTN_SESSION_FIXED_IT"
msgid "I fixed it myself; check again"
msgstr "Kendim düzelttim; tekrar kontrol edin"

msgctxt "PANOPTICON_SETUP_LBL_FS_DRIVER"
msgid "Filesystem driver"
msgstr "Dosya sistemi sürücüsü"

msgctxt "PANOPTICON_SETUP_LBL_FS_DRIVER_FILE"
msgid "Direct File Writes"
msgstr "Doğrudan Dosya Yazma"

msgctxt "PANOPTICON_SETUP_LBL_FS_DRIVER_FTP"
msgid "FTP - File Transfer Protocol"
msgstr "FTP - Dosya Aktarım Protokolü"

msgctxt "PANOPTICON_SETUP_LBL_FS_DRIVER_HELP"
msgid ""
"On some shared hosting environments you need to use FTP or SFTP to be able to "
"write to your site's files."
msgstr ""
"Bazı paylaşılan barındırma ortamlarında, sitenizin dosyalarına yazabilmek için "
"FTP veya SFTP kullanmanız gerekir."

msgctxt "PANOPTICON_SETUP_LBL_FS_DRIVER_SFTP"
msgid "SFTP - Secure File Transfer Protocol (over SSH)"
msgstr "SFTP - Güvenli Dosya Aktarım Protokolü (SSH üzerinden)"

msgctxt "PANOPTICON_SETUP_LBL_FS_FTP_DIRECTORY"
msgid "(S)FTP directory"
msgstr "(S)FTP Dizini"

msgctxt "PANOPTICON_SETUP_LBL_FS_FTP_DIRECTORY_HELP"
msgid ""
"The (S)FTP directory to the Panopticon installation. On FTP servers this is not "
"the same as the filesystem path. If unsure, ask your host."
msgstr ""
"Panopticon kurulumunun (S)FTP dizini. FTP sunucularında bu, dosya sistemi yolu "
"ile aynı değildir. Emin değilseniz barındırıcınıza sorun."

msgctxt "PANOPTICON_SETUP_LBL_FS_FTP_HOST"
msgid "(S)FTP server hostname"
msgstr "(S)FTP sunucusu ana bilgisayar adı"

msgctxt "PANOPTICON_SETUP_LBL_FS_FTP_HOST_HELP"
msgid ""
"The hostname or IP address of your (S)FTP server, e.g. <code>ftp.example.com</"
"code> or <code>127.0.0.1</code>. You MUST enter this <em>without</em> the "
"<code>ftp://</code>, <code>sftp://</code> or <code>ssh://</code> prefix. If "
"unsure about this and the other FTP settings please ask your host."
msgstr ""
"(S)FTP sunucunuzun ana bilgisayar adı veya IP adresi, örneğin "
"<code>ftp.example.com</code> veya <code>127.0.0.1</code>. Bunu <code>ftp://,</"
"code> <code>sftp://</code> veya <code>ssh://</code> öneki <em>olmadan</em> "
"girmelisiniz. Bu ve diğer FTP ayarları hakkında emin değilseniz lütfen "
"barındırıcınıza sorun."

msgctxt "PANOPTICON_SETUP_LBL_FS_FTP_PASSIVE"
msgid "Use Passive mode"
msgstr "Pasif kipi kullanın"

msgctxt "PANOPTICON_SETUP_LBL_FS_FTP_PASSIVE_HELP"
msgid ""
"Only applicable for FTP. When selected, Panopticon will use the FTP Passive "
"mode. Most FTP servers require it. If your host requires FTP Active mode uncheck "
"this box. If unsure, please ask your host."
msgstr ""
"Yalnızca FTP için geçerlidir. Panopticon seçildiğinde FTP Pasif kipini "
"kullanacaktır. Çoğu FTP sunucusu bunu gerektirir. Ana makineniz FTP Etkin kipini "
"gerektiriyorsa bu kutunun işaretini kaldırın. Emin değilseniz lütfen "
"barındırıcınıza sorun."

msgctxt "PANOPTICON_SETUP_LBL_FS_FTP_PASSWORD"
msgid "(S)FTP password"
msgstr "(S)FTP Şifresi"

msgctxt "PANOPTICON_SETUP_LBL_FS_FTP_PASSWORD_HELP"
msgid ""
"The password you use to connect to your (S)FTP server. If unsure, ask your host."
msgstr ""
"(S)FTP sunucunuza bağlanmak için kullandığınız şifre. Emin değilseniz "
"barındırıcınıza sorun."

msgctxt "PANOPTICON_SETUP_LBL_FS_FTP_PORT"
msgid "(S)FTP server port"
msgstr "(S)FTP sunucu bağlantı noktası"

msgctxt "PANOPTICON_SETUP_LBL_FS_FTP_PORT_HELP"
msgid ""
"The port number your (S)FTP server listens to. Usually it's 21 for FTP and 22 "
"for SFTP. If unsure, ask your host."
msgstr ""
"(S)FTP sunucunuzun dinlediği bağlantı noktası numarası. Genellikle FTP için 21 "
"ve SFTP için 22'dir. Emin değilseniz barındırıcınıza sorun."

msgctxt "PANOPTICON_SETUP_LBL_FS_FTP_SSL"
msgid "Use SSL"
msgstr "SSL Kullanılsın"

msgctxt "PANOPTICON_SETUP_LBL_FS_FTP_SSL_HELP"
msgid ""
"Only applicable for FTP, ignored for SFTP. When selected, Panopticon will use "
"FTP over Explicit SSL (FTP/S). Please note that this is not to be confused with "
"SFTP which is an entirely different thing."
msgstr ""
"Yalnızca FTP için geçerlidir, SFTP için yoksayılır. Seçildiğinde Panopticon Açık "
"SSL (FTP/S) üzerinden FTP kullanacaktır. Lütfen bunun tamamen farklı bir şey "
"olan SFTP ile karıştırılmaması gerektiğini unutmayın."

msgctxt "PANOPTICON_SETUP_LBL_FS_FTP_USERNAME"
msgid "(S)FTP username"
msgstr "(S)FTP Kullanıcı Adı"

msgctxt "PANOPTICON_SETUP_LBL_FS_FTP_USERNAME_HELP"
msgid ""
"The username you use to connect to your (S)FTP server. If unsure, ask your host."
msgstr ""
"(S)FTP sunucunuza bağlanmak için kullandığınız kullanıcı adı. Emin değilseniz "
"barındırıcınıza sorun."

msgctxt "PANOPTICON_SETUP_LBL_NOSCRIPT_HEAD"
msgid "JavaScript is disabled"
msgstr "JavaScript devre dışı"

msgctxt "PANOPTICON_SETUP_LBL_NOSCRIPT_EXPLAIN"
msgid "You need to enable JavaScript in your browser to use Panopticon."
msgstr ""
"Panopticon'u kullanabilmeniz için tarayıcınızda JavaScript'i etkinleştirmeniz "
"gerekmektedir."

msgctxt "PANOPTICON_SETUP_LBL_BROKEN_JS_HEAD"
msgid "Required JavaScript does not load"
msgstr "Gerekli JavaScript yüklenmiyor"

msgctxt "PANOPTICON_SETUP_LBL_BROKEN_JS_EXPLAIN"
msgid ""
"The JavaScript files for Panopticon are not loading properly. Make sure you "
"installation is not missing files, check permissions, and clear your browser's "
"cache."
msgstr ""
"Panopticon'un JavaScript dosyaları düzgün yüklenmiyor. Kurulumda dosyaların "
"eksik olmadığından emin olun, izinleri kontrol edin ve tarayıcınızın önbelleğini "
"temizleyin."

msgctxt "PANOPTICON_SETUP_LBL_PRECHECK_HEAD_OK"
msgid "All systems go!"
msgstr "Tüm sistemler uygun!"

msgctxt "PANOPTICON_SETUP_LBL_PRECHECK_REQUIREMENTS_OK"
msgid "Your server meets all requirements."
msgstr "Sunucunuz tüm gereksinimleri karşılıyor."

msgctxt "PANOPTICON_SETUP_LBL_PRECHECK_RECOMMENDED_IMPROVE"
msgid "Some optional settings can be improved (see below)."
msgstr "Bazı isteğe bağlı ayarlar geliştirilebilir (aşağıya bakın)."

msgctxt "PANOPTICON_SETUP_LBL_PRECHECK_YOU_MAY_CONTINUE"
msgid "You may continue installing Panopticon."
msgstr "Panopticon kurulumuna devam edebilirsiniz."

msgctxt "PANOPTICON_SETUP_LBL_PRECHECK_BTN_SHOW_OPTIONAL_SETTINGS"
msgid "Show optional settings"
msgstr "İsteğe bağlı ayarları göster"

msgctxt "PANOPTICON_SETUP_LBL_PRECHECK_HEAD_FAIL"
msgid "Some requirements are not met"
msgstr "Bazı gereksinimler karşılanmıyor"

msgctxt "PANOPTICON_SETUP_LBL_PRECHECK_REQUIREMENTS_FAIL"
msgid "Your server does not meet all minimum requirements."
msgstr "Sunucunuz tüm en düşük gereksinimleri karşılamıyor."

msgctxt "PANOPTICON_SETUP_LBL_PRECHECK_RECOMMENDED_FAIL"
msgid "Moreover, some optional settings can be improved (see below)."
msgstr "Ayrıca bazı isteğe bağlı ayarlar geliştirilebilir (aşağıya bakın)."

msgctxt "PANOPTICON_SETUP_LBL_PRECHECK_CANNOT_CONTINUE"
msgid "You need to address those issues before installing Panopticon."
msgstr "Panopticon'u kurmadan önce bu sorunları çözmeniz gerekiyor."

msgctxt "PANOPTICON_SETUP_BTN_RETRY_PRECHECK"
msgid "Check again"
msgstr "Tekrar denetleyin"

msgctxt "PANOPTICON_SETUP_BTN_IGNORE_AND_NEXT"
msgid "Ignore the errors <em>at your own risk</em>"
msgstr "Hataları göz ardı edin <em>riski size ait olmak üzere</em>"

msgctxt "PANOPTICON_SETUP_LBL_REQUIRED"
msgid "Requirements"
msgstr "Gereksinimler"

msgctxt "PANOPTICON_SETUP_LBL_REQ_PHP_VERSION"
msgid "PHP version >= %s"
msgstr "PHP Sürümü >= %s"

msgctxt "PANOPTICON_SETUP_LBL_REQ_REGGLOBALS"
msgid "Register Globals Off"
msgstr "Genel Kaydetmeler Kapalı"

msgctxt "PANOPTICON_SETUP_LBL_REQ_XML"
msgid "PHP XML extension"
msgstr "PHP XML Eklentisi"

msgctxt "PANOPTICON_SETUP_LBL_REQ_CURL"
msgid "PHP cURL extension"
msgstr "PHP cURL Eklentisi"

msgctxt "PANOPTICON_SETUP_LBL_REQ_DATABASE"
msgid "PHP MySQLi or PDO MySQL extension"
msgstr "PHP MySQLi veya PDO MySQL Eklentisi"

msgctxt "PANOPTICON_SETUP_LBL_REQ_MBLANGISDEFAULT"
msgid "MB Language is Default"
msgstr "MB Dili Varsayılandır"

msgctxt "PANOPTICON_SETUP_LBL_REQ_MBSTRINGOVERLOAD"
msgid "MB String Overload Off"
msgstr "MB String Aşırı Yük Kapalı"

msgctxt "PANOPTICON_SETUP_LBL_REQ_INIPARSER"
msgid "INI Parser Support"
msgstr "INI Ayrıştırıcı Desteği"

msgctxt "PANOPTICON_SETUP_LBL_REQ_JSON"
msgid "JSON Support"
msgstr "JSON Desteği"

msgctxt "PANOPTICON_SETUP_LBL_REQ_CONFIGJSON"
msgid "Configuration file is writeable"
msgstr "Yapılandırma dosyası yazılabilir"

msgctxt "PANOPTICON_SETUP_LBL_RECOMMENDED"
msgid "Optional Settings"
msgstr "İsteğe Bağlı Ayarlar"

msgctxt "PANOPTICON_SETUP_LBL_SETTING"
msgid "Setting"
msgstr "Ayarla"

msgctxt "PANOPTICON_SETUP_LBL_RECOMMENDED_VALUE"
msgid "Recommended"
msgstr "Önerilen"

msgctxt "PANOPTICON_SETUP_LBL_CURRENT_SETTING"
msgid "Current"
msgstr "Geçerli"

msgctxt "PANOPTICON_SETUP_LBL_REC_DISPERRORS"
msgid "Display Errors"
msgstr "Hatalar Görüntülensin"

msgctxt "PANOPTICON_SETUP_LBL_REC_OUTBUF"
msgid "Output Buffering"
msgstr "Çıktı Arabelleğe Alma"

msgctxt "PANOPTICON_SETUP_LBL_REC_SESSIONAUTO"
msgid "Session Auto Start"
msgstr "Oturum Otomatik Başlatma"

msgctxt "PANOPTICON_SETUP_LBL_REC_FTP"
msgid "PHP FTP Extension"
msgstr "PHP FTP Eklentisi"

msgctxt "PANOPTICON_SETUP_LBL_REC_SSH2"
msgid "SFTP Support"
msgstr "PHP Desteği"

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_HEAD_TEXT"
msgid ""
"Panopticon needs a database to work. First, create a database - and a database "
"user - on your server. Then enter the connection information to the database "
"below. If something is unclear please check with the company hosting your site."
msgstr ""
"Panopticon'un çalışması için bir veritabanına ihtiyacı var. Öncelikle "
"sunucunuzda bir veritabanı ve bir veritabanı kullanıcısı oluşturun. Daha sonra "
"aşağıdaki veritabanına bağlantı bilgilerini giriniz. Eğer bir şey net değilse, "
"lütfen sitenizi barındıran şirkete danışın."

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_DRIVER"
msgid "Database type"
msgstr "Veritabanı Türü"

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_DRIVER_HELP"
msgid "This is usually MySQLi (<em>with</em> the trailing \"i\")"
msgstr "Bu genellikle MySQLi'dir (sondaki \"i\" <em>ile</em>)"

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_DRIVER_MYSQL"
msgid "MySQL (obsolete driver for MySQL - avoid using)"
msgstr "MySQL (MySQL için eski sürücü - kullanmaktan kaçının)"

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_DRIVER_MYSQLI"
msgid "MySQLi (preferred driver for MySQL)"
msgstr "MySQLi (MySQL için tercih edilen sürücü)"

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_DRIVER_PDO"
msgid "PDO"
msgstr "PDO"

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_DRIVER_PDOMYSQL"
msgid "MySQL (PDO)"
msgstr "MySQL (PDO)"

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_DRIVER_SQLAZURE"
msgid "Windows Azure SQL Database"
msgstr "Windows Azure SQL Veritabanı"

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_DRIVER_SQLITE"
msgid "SQLite"
msgstr "SQLite"

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_HOST"
msgid "Database server host name"
msgstr "Veritabanı sunucusu ana bilgisayar adı"

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_HOST_HELP"
msgid ""
"The host name or IP address of the database server (usually: localhost). Please "
"note that localhost and 127.0.0.1 are <em>very</em> different as far as MySQL is "
"concerned; you may have to try both to see which works with your database "
"server. If your server is using a non-standard port, append it after the "
"hostname prefixed with a colon, e.g. 127.0.0.1:1234 to use a database server on "
"127.0.0.1 listening to port 1234."
msgstr ""
"Veritabanı sunucusunun ana bilgisayar adı veya IP adresi (genellikle: "
"localhost). Lütfen localhost ve 127.0.0.1'in MySQL söz konusu olduğunda <em>çok</"
"em> farklı olduğunu unutmayın; veritabanı sunucunuzla hangisinin çalıştığını "
"görmek için her ikisini de denemeniz gerekebilir. Sunucunuz standart olmayan bir "
"bağlantı noktası kullanıyorsa, ana bilgisayar adından sonra iki nokta üst üste "
"ekleyin, örneğin 127.0.0.1:1234, 127.0.0.1 üzerinde 1234 numaralı bağlantı "
"noktasını dinleyen bir veritabanı sunucusu kullanmak için."

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_NAME"
msgid "Database name"
msgstr "Veritabanı Adı"

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_NAME_HELP"
msgid ""
"The name of your database. Most hosts using cPanel, Plesk and other major "
"hosting panels will give database names like abcdef_username, where abcdef is "
"your hosting control panel username. If unsure, please ask your host."
msgstr ""
"Veritabanınızın adı. cPanel, Plesk ve diğer büyük barındırma panellerini "
"kullanan çoğu ana bilgisayar, abcdef_username gibi veritabanı adları verecektir; "
"burada abcdef, barındırma kontrol paneli kullanıcı adınızdır. Emin değilseniz "
"lütfen barındırıcınıza sorun."

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_PASS"
msgid "Password"
msgstr "Parola"

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_PASS_HELP"
msgid "The password you use to connect to your database."
msgstr "Veritabanınıza bağlanmak için kullandığınız şifre."

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_PREFIX"
msgid "Database table name prefix"
msgstr "Veritabanı tablosu adı öneki"

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_PREFIX_HELP"
msgid ""
"The common table name prefix of all database tables belonging to this Panopticon "
"installation."
msgstr ""
"Bu Panopticon kurulumuna ait tüm veritabanı tablolarının ortak tablo adı öneki."

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_USER"
msgid "User name"
msgstr "Kullanıcı Adı"

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_USER_HELP"
msgid ""
"The username you use to connect to your database. Most hosts using cPanel, Plesk "
"and other major hosting panels will give usernames like abcdef_username, where "
"abcdef is your hosting control panel username. If unsure, please ask your host."
msgstr ""
"Veritabanınıza bağlanmak için kullandığınız kullanıcı adı. cPanel, Plesk ve "
"diğer büyük barındırma panellerini kullanan çoğu ana bilgisayar, abcdef_username "
"gibi kullanıcı adları verecektir; burada abcdef, barındırma kontrol paneli "
"kullanıcı adınızdır. Emin değilseniz lütfen barındırıcınıza sorun."

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_DBENCRYPTION"
msgid "Connect with an SSL certificate"
msgstr "SSL sertifikasıyla bağlanın"

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_DBENCRYPTION_HELP"
msgid ""
"Should we connect to the database using an SSL certificate? This can be used "
"instead of username and password authentication (encrypted connection with "
"certificate authentication) or <em>on top of</em> username and password "
"authentication (encrypted connection with password authentication). If you don't "
"know what this means set this option to No and ignore the next few options as "
"well."
msgstr ""
"Veritabanına bir SSL sertifikası kullanarak bağlanmalı mıyız? Bu, kullanıcı adı "
"ve parola kimlik doğrulaması yerine (sertifika kimlik doğrulaması ile şifreli "
"bağlantı) veya kullanıcı adı ve parola kimlik doğrulamasının <em>üstünde</em> "
"(parola kimlik doğrulaması ile şifreli bağlantı) kullanılabilir. Bunun ne anlama "
"geldiğini bilmiyorsanız bu seçeneği Hayır olarak ayarlayın ve sonraki birkaç "
"seçeneği de göz ardı edin."

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_DBSSLCIPHER"
msgid "SSL/TLS Encryption Methods"
msgstr "SSL/TLS Encryption Yöntemleri"

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_DBSSLCIPHER_HELP"
msgid ""
"Enter a list of encryption methods for connecting with SSL certificates, "
"separated by colons. If left empty the default list (<code>AES128-GCM-"
"SHA256:AES256-GCM-SHA384:AES128-CBC-SHA256:AES256-CBC-SHA384:DES-CBC3-SHA</"
"code>) will be used (recommended)."
msgstr ""
"SSL sertifikaları ile bağlanmak için şifreleme yöntemlerinin listesini iki nokta "
"üst üste ile ayırarak girin. Boş bırakılırsa varsayılan liste<code>(AES128-GCM-"
"SHA256:AES256-GCM-SHA384:AES128-CBC-SHA256:AES256-CBC-SHA384:DES-CBC3-SHA</"
"code>) kullanılır (önerilir)."

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_DBSSLCA"
msgid "Certification Authority (CA) file"
msgstr "Sertifika Yetkilisi (CA) Dosyası"

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_DBSSLCA_HELP"
msgid ""
"Absolute file path to the Certification Authority (CA) certificate PEM file of "
"your database server, e.g. <code>/home/myuser/ca.pem</code>"
msgstr ""
"Veritabanı sunucunuzun Sertifika Yetkilisi (CA) sertifikası PEM dosyasının "
"mutlak dosya yolu, örneğin <code>/home/myuser/ca.pem</code>"

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_DBSSLKEY"
msgid "Database user's Private Key file"
msgstr "Veritabanı kullanıcısının Özel Anahtar dosyası"

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_DBSSLKEY_HELP"
msgid ""
"Absolute file path to the private key PEM file of your database user, e.g. "
"<code>/home/myuser/myuser-key.pem</code>"
msgstr ""
"Veritabanı kullanıcınızın özel anahtar PEM dosyasının mutlak dosya yolu, örneğin "
"<code>/home/myuser/myuser-key.pem</code>"

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_DBSSLCERT"
msgid "Database user's Public Key (Certificate) file"
msgstr "Veritabanı kullanıcısının Genel Anahtar (Sertifika) dosyası"

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_DBSSLCERT_HELP"
msgid ""
"Absolute file path to the public key (certificate) PEM file of your database "
"user, e.g. <code>/home/myuser/myuser.pem</code>"
msgstr ""
"Veritabanı kullanıcınızın ortak anahtar (sertifika) PEM dosyasının mutlak dosya "
"yolu, örneğin <code>/home/myuser/myuser.pem</code>"

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_DBSSLVERIFYSERVERCERT"
msgid "Verify server certificate"
msgstr "Sunucu sertifikasını doğrulama"

msgctxt "PANOPTICON_SETUP_LBL_DATABASE_DBSSLVERIFYSERVERCERT_HELP"
msgid ""
"Set to Yes to verify the certificate the server sends back to us. This is "
"verified against the Certification Authority (CA) file you specified. If you get "
"connection errors set this to No; some setups (especially those generated by the "
"<code>mysql_ssl_rsa_setup</code>) may disallow a connection if certification "
"verification is enabled. If you enable verification and the CA file field is "
"left blank the server's certificate will be checked against the Certification "
"Authority files your server knows about, see the <code>openssl.cafile</code> and "
"<code>openssl.capath</code> PHP options."
msgstr ""
"Sunucunun bize geri gönderdiği sertifikayı doğrulamak için Evet olarak "
"ayarlayın. Bu, belirttiğiniz Sertifika Yetkilisi (CA) dosyasına göre doğrulanır. "
"Bağlantı hataları alırsanız bunu Hayır olarak ayarlayın; bazı kurulumlar "
"(özellikle <code>mysql_ssl_rsa_setup</code> tarafından oluşturulanlar) sertifika "
"doğrulaması etkinleştirilirse bağlantıya izin vermeyebilir. Doğrulamayı "
"etkinleştirirseniz ve CA dosyası alanı boş bırakılırsa, sunucunun sertifikası "
"sunucunuzun bildiği Sertifika Yetkilisi dosyalarına karşı denetlenecektir, "
"<code>openssl.cafile</code> ve openssl <code>.capath</code> PHP seçeneklerine "
"bakınız."

msgctxt "PANOPTICON_SETUP_DIRECTFTP_HOST_TITLE"
msgid "Host name"
msgstr "Sunucu Adı"

msgctxt "PANOPTICON_SETUP_DIRECTFTP_HOST_DESCRIPTION"
msgid ""
"The FTP server's host name, without the protocol. Do not use <s><code>ftp://"
"example.com</code></s>; use <code>example.com</code> instead."
msgstr ""
"Protokol olmadan FTP sunucusunun ana bilgisayar adı. Kullanmayın <s><code>ftp://"
"example.com</code></s>yerine <code>example.com</code> adresini kullanın."

msgctxt "PANOPTICON_SETUP_DIRECTFTP_PORT_TITLE"
msgid "Port"
msgstr "Bağlantı Noktası"

msgctxt "PANOPTICON_SETUP_DIRECTFTP_PORT_DESCRIPTION"
msgid "FTP server's TCP/IP port. Usually 21. Please ask your host."
msgstr ""
"FTP sunucusunun TCP/IP bağlantı noktası. Genellikle 21. Lütfen barındırıcınıza "
"sorun."

msgctxt "PANOPTICON_SETUP_DIRECTFTP_USER_TITLE"
msgid "User name"
msgstr "Kullanıcı Adı"

msgctxt "PANOPTICON_SETUP_DIRECTFTP_USER_DESCRIPTION"
msgid "Username, case-sensitive."
msgstr "Kullanıcı adı, büyük/küçük harfe duyarlı."

msgctxt "PANOPTICON_SETUP_DIRECTFTP_PASSWORD_TITLE"
msgid "Password"
msgstr "Parola"

msgctxt "PANOPTICON_SETUP_DIRECTFTP_PASSWORD_DESCRIPTION"
msgid ""
"Password, case-sensitive. Best use passwords consisting only of a-z, A-Z, 0-9, "
"dashes, dots, underscores, and exclamation points. Other characters may trigger "
"your web server's anti-hacking protection."
msgstr ""
"Parola, büyük/küçük harfe duyarlıdır. En iyisi yalnızca a-z, A-Z, 0-9, tire, "
"nokta, alt çizgi ve ünlem işaretlerinden oluşan parolalar kullanın. Diğer "
"karakterler web sunucunuzun anti-hack korumasını tetikleyebilir."

msgctxt "PANOPTICON_SETUP_DIRECTFTP_FTPS_TITLE"
msgid "Use FTP over SSL (FTPS)"
msgstr "SSL üzerinden FTP kullanın (FTPS)"

msgctxt "PANOPTICON_SETUP_DIRECTFTP_FTPS_DESCRIPTION"
msgid ""
"Connect to your FTP server using an SSL-encrypted connection. <strong>This is "
"not the same as SFTP, SCP or \"Secure FTP\"</strong>. If your server doesn't "
"support this method you will get connection errors."
msgstr ""
"SSL şifreli bir bağlantı kullanarak FTP sunucunuza bağlanın. <strong>Bu, SFTP, "
"SCP veya \"Güvenli FTP\" ile aynı değildir</strong>. Sunucunuz bu yöntemi "
"desteklemiyorsa bağlantı hataları alırsınız."

msgctxt "PANOPTICON_SETUP_DIRECTFTP_INITDIR_TITLE"
msgid "Initial directory"
msgstr "Başlangıç ​​Dizini"

msgctxt "PANOPTICON_SETUP_DIRECTFTP_INITDIR_DESCRIPTION"
msgid ""
"The absolute FTP path to the directory where the files will be uploaded. If "
"unsure, connect to your server with FileZilla, browse to the intended directory "
"and copy the path appearing on the right-hand pane above the directory list. "
"Usually, it's something like <code>/public_html</code> or <code>/httpdocs</code>."
msgstr ""
"Dosyaların yükleneceği dizine giden mutlak FTP yolu. Emin değilseniz FileZilla "
"ile sunucunuza bağlanın, istediğiniz dizine göz atın ve sağdaki bölmede dizin "
"listesinin üzerinde görünen yolu kopyalayın. Genellikle <code>/public_html</"
"code> veya <code>/httpdocs</code> gibi bir şeydir."

msgctxt "PANOPTICON_SETUP_DIRECTFTP_PASSIVE_TITLE"
msgid "Passive mode"
msgstr "Pasif Kip"

msgctxt "PANOPTICON_SETUP_DIRECTFTP_PASSIVE_DESCRIPTION"
msgid ""
"Uses FTP passive mode when transferring data. Should be enabled on all servers "
"with a port firewall, which is practically all servers nowadays."
msgstr ""
"Veri aktarırken FTP pasif kipini kullanır. Bağlantı noktası güvenlik duvarına "
"sahip tüm sunucularda etkinleştirilmelidir; günümüzde hemen hemen tüm "
"sunucularda bu etkinleştirilmelidir."

msgctxt "PANOPTICON_SETUP_DIRECTFTP_TEST_DESCRIPTION"
msgid "Tests the FTP connection."
msgstr "FTP bağlantısını test eder."

msgctxt "PANOPTICON_SETUP_DIRECTFTP_TEST_FAIL"
msgid "Could not connect to the FTP server."
msgstr "FTP sunucusuna bağlanılamadı."

msgctxt "PANOPTICON_SETUP_DIRECTFTP_TEST_OK"
msgid "Successful connection to the FTP server."
msgstr "FTP sunucusuna başarılı bağlantı."

msgctxt "PANOPTICON_SETUP_DIRECTFTP_TEST_TITLE"
msgid "Test FTP connection"
msgstr "FTP bağlantısını test edin"

msgctxt "PANOPTICON_SETUP_DIRECTSFTP_HOST_TITLE"
msgid "Host name"
msgstr "Sunucu Adı"

msgctxt "PANOPTICON_SETUP_DIRECTSFTP_HOST_DESCRIPTION"
msgid ""
"SFTP server's hostname, without the protocol. Do not use <s><code>sftp://"
"example.com</code></s>; use <code>example.com</code> instead."
msgstr ""
"SFTP sunucusunun ana bilgisayar adı, protokol olmadan. <s><code>sftp://"
"example.com</code></s> kullanmayın; bunun yerine <code>example.com</code>'u "
"kullanın."

msgctxt "PANOPTICON_SETUP_DIRECTSFTP_PORT_TITLE"
msgid "Port"
msgstr "Bağlantı Noktası"

msgctxt "PANOPTICON_SETUP_DIRECTSFTP_PORT_DESCRIPTION"
msgid "TCP/IP port for SFTP. Usually 22. If unsure, please ask your host."
msgstr ""
"SFTP için TCP/IP bağlantı noktası. Genellikle 22. Emin değilseniz lütfen "
"barındırıcınıza sorun."

msgctxt "PANOPTICON_SETUP_DIRECTSFTP_USER_TITLE"
msgid "Username"
msgstr "Kullanıcı Adı"

msgctxt "PANOPTICON_SETUP_DIRECTSFTP_USER_DESCRIPTION"
msgid ""
"Username, case-sensitive. Your SFTP server must allow username/password "
"authentication."
msgstr ""
"Kullanıcı adı, büyük/küçük harfe duyarlı. SFTP sunucunuz kullanıcı adı/şifre "
"kimlik doğrulamasına izin vermelidir."

msgctxt "PANOPTICON_SETUP_DIRECTSFTP_PASSWORD_TITLE"
msgid "Password"
msgstr "Parola"

msgctxt "PANOPTICON_SETUP_DIRECTSFTP_PASSWORD_DESCRIPTION"
msgid "SFTP password, case-sensitive."
msgstr "SFTP şifresi, büyük/küçük harfe duyarlıdır."

msgctxt "PANOPTICON_SETUP_DIRECTSFTP_INITDIR_TITLE"
msgid "Initial directory"
msgstr "Başlangıç ​​Dizini"

msgctxt "PANOPTICON_SETUP_DIRECTSFTP_INITDIR_DESCRIPTION"
msgid ""
"SFTP directory of the site's root. If unsure, use an SFTP desktop client, "
"connect to your server, navigate to the directory and copy the path displayed in "
"here. The must be absolute, e.g. <code>/home/myuser/public_html</code>, not just "
"<s><code>public_html</code></s>."
msgstr ""
"Sitenin kökünün SFTP dizini. Emin değilseniz bir SFTP masaüstü istemcisi "
"kullanın, sunucunuza bağlanın, dizine gidin ve burada görüntülenen yolu "
"kopyalayın. Mutlak olmalıdır, ör. <code>/home/myuser/public_html</code>, "
"yalnızca <s><code>public_html</code></s> değil."

msgctxt "PANOPTICON_SETUP_DIRECTSFTP_TEST_DESCRIPTION"
msgid "Test the connection to the SFTP server."
msgstr "SFTP sunucusuna olan bağlantıyı test edin."

msgctxt "PANOPTICON_SETUP_DIRECTSFTP_TEST_FAIL"
msgid "Could not connect to the SFTP server. The error message was:"
msgstr "SFTP sunucusuna bağlanılamadı. Hata mesajı:"

msgctxt "PANOPTICON_SETUP_DIRECTSFTP_TEST_OK"
msgid "Successful connection to the SFTP server."
msgstr "SFTP sunucusuna başarılı bağlantı."

msgctxt "PANOPTICON_SETUP_DIRECTSFTP_TEST_TITLE"
msgid "Test SFTP connection"
msgstr "SFTP bağlantısını test edin"

msgctxt "PANOPTICON_SETUP_LBL_SETUP_HEAD_TEXT"
msgid ""
"Access to Panopticon is protected behind a login. You will now create a user "
"account with full administrator privileges. You can modify this user, and create "
"more users, after you complete the installation process."
msgstr ""
"Panopticon'a erişim, oturum açma işlemiyle korunur. Artık tam yönetici "
"ayrıcalıklarına sahip bir kullanıcı hesabı oluşturacaksınız. Kurulum işlemini "
"tamamladıktan sonra bu kullanıcıyı değiştirebilir ve daha fazla kullanıcı "
"oluşturabilirsiniz."

msgctxt "PANOPTICON_SETUP_LBL_USER_NAME"
msgid "Full name"
msgstr "İsim"

msgctxt "PANOPTICON_SETUP_LBL_USER_NAME_HELP"
msgid ""
"Please enter your full name. It will be used whenever your Panopticon "
"installation has to send you an email."
msgstr ""
"Lütfen tam adınızı giriniz. Panopticon kurulumunuzun size bir e-posta göndermesi "
"gerektiğinde kullanılacaktır."

msgctxt "PANOPTICON_SETUP_LBL_USER_USERNAME"
msgid "Username"
msgstr "Kullanıcı Adı"

msgctxt "PANOPTICON_SETUP_LBL_USER_USERNAME_HELP"
msgid ""
"The username you will use to log in to Panopticon. It's best to only use "
"lowercase letters a-z and numbers 0-9."
msgstr ""
"Panopticon'a giriş yapmak için kullanacağınız kullanıcı adı. Yalnızca a'dan z'ye "
"küçük harfleri ve 0-9 arasındaki rakamları kullanmak en iyisidir."

msgctxt "PANOPTICON_SETUP_LBL_USER_PASSWORD"
msgid "Password"
msgstr "Parola"

msgctxt "PANOPTICON_SETUP_LBL_USER_PASSWORD_HELP"
msgid ""
"The password you will use to log in to Panopticon. The password is case "
"sensitive, meaning that abc, Abc and ABC are three <em>different</em> passwords."
msgstr ""
"Panopticon'a giriş yaparken kullanacağınız şifre. Şifre büyük/küçük harfe "
"duyarlıdır; yani abc, Abc ve ABC üç <em>farklı</em> şifredir."

msgctxt "PANOPTICON_SETUP_LBL_USER_PASSWORD2"
msgid "Repeat Password"
msgstr "Şifreyi tekrar girin"

msgctxt "PANOPTICON_SETUP_LBL_USER_PASSWORD2_HELP"
msgid ""
"Please repeat the password you entered above. We want to make sure you didn't "
"accidentally mistype it."
msgstr ""
"Lütfen yukarıda girdiğiniz şifreyi tekrarlayınız. Yanlışlıkla yanlış "
"yazmadığınızdan emin olmak istiyoruz."

msgctxt "PANOPTICON_SETUP_LBL_USER_EMAIL"
msgid "Email Address"
msgstr "E-Posta Adresi"

msgctxt "PANOPTICON_SETUP_LBL_USER_EMAIL_HELP"
msgid ""
"Please enter your email address. It will be used whenever your Panopticon "
"installation has to send you an email. This email address, as well as all of the "
"user information, is <em>not</em> transmitted to the authors of Panopticon."
msgstr ""
"Lütfen e-posta adresinizi giriniz. Panopticon kurulumunuzun size bir e-posta "
"göndermesi gerektiğinde kullanılacaktır. Bu e-posta adresi ve tüm kullanıcı "
"bilgileri Panopticon yazarlarına <em>aktarılmaz</em>."

msgctxt "PANOPTICON_SETUP_LBL_TIMEZONE"
msgid "Time Zone"
msgstr "Saat Dilimi"

msgctxt "PANOPTICON_SETUP_LBL_TIMEZONE_HELP"
msgid "All dates and times will be expressed in this timezone."
msgstr "Tüm tarihler ve saatler bu saat diliminde ifade edilecektir."

msgctxt "PANOPTICON_SETUP_LBL_NO_CONFIG_WRITTEN_ALERT_HEAD"
msgid "Panopticon is not ready yet"
msgstr "Panoptikon henüz hazır değil"

msgctxt "PANOPTICON_SETUP_LBL_NO_CONFIG_WRITTEN_ALERT_BODY"
msgid ""
"Saving the configuration file <code>config.php</code> in the folder you are "
"installing Panopticon has failed. You will need to create this file manually."
msgstr ""
"<code>config.php</code> yapılandırma dosyasını Panopticon'u kurduğunuz klasöre "
"kaydetme işlemi başarısız oldu. Bu dosyayı elle oluşturmanız gerekecektir."

msgctxt "PANOPTICON_SETUP_LBL_NOCONF_INSTRUCTIONS_HEAD"
msgid "Create the configuration file"
msgstr "Yapılandırma dosyasını oluşturun"

msgctxt "PANOPTICON_SETUP_LBL_NOCONF_INSTRUCTIONS_STEP1"
msgid ""
"Create a file named <code>config.php</code> and keep it open in your editor."
msgstr ""
"<code>config.php</code> adında bir dosya oluşturun ve onu düzenleyicinizde açık "
"tutun."

msgctxt "PANOPTICON_SETUP_LBL_NOCONF_INSTRUCTIONS_STEP1_DETAIL"
msgid ""
"Use a plain text editor such as Notepad on Windows, BBEdit on macOS, gEdit or "
"Kate on Linux."
msgstr ""
"Windows'ta Notepad, macOS'ta BBEdit, Linux'ta gEdit veya Kate gibi bir düz metin "
"düzenleyici kullanın."

msgctxt "PANOPTICON_SETUP_LBL_NOCONF_INSTRUCTIONS_STEP2"
msgid "Come back to this window and click on the “Copy to Clipboard” button."
msgstr "Bu pencereye geri gelin ve “Panoya Kopyala” düğmesine tıklayın."

msgctxt "PANOPTICON_SETUP_LBL_NOCONF_INSTRUCTIONS_STEP3"
msgid "Switch back to your editor and paste. Then, save the file."
msgstr "Düzenleyicinize geri dönün ve yapıştırın. Daha sonra dosyayı kaydedin."

msgctxt "PANOPTICON_SETUP_LBL_NOCONF_INSTRUCTIONS_STEP4"
msgid "Upload the <code>config.php</code> file to your Panopticon installation."
msgstr "<code>config.php</code> dosyasını Panopticon kurulumunuza yükleyin."

msgctxt "PANOPTICON_SETUP_LBL_NOCONF_INSTRUCTIONS_STEP4_DETAIL"
msgid ""
"Upload into the folder you're installing Panopticon. That's the folder with the "
"Panopticon <code>index.php</code> file in it."
msgstr ""
"Panopticon'u kurduğunuz klasöre yükleyin. Bu, içinde Panopticon <code>index.php</"
"code> dosyasının bulunduğu klasördür."

msgctxt "PANOPTICON_SETUP_LBL_NOCONF_INSTRUCTIONS_STEP5"
msgid "Come back to this window and click on the “Continue” button."
msgstr "Bu pencereye geri dönün ve “Devam Et” düğmesine tıklayın."

msgctxt "PANOPTICON_SETUP_BTN_COPY_TO_CLIPBOARD"
msgid "Copy to Clipboard"
msgstr "Panoya Kopyala"

msgctxt "PANOPTICON_SETUP_LBL_CRON_HEAD"
msgid "Set up a CRON job"
msgstr "Bir CRON İşlevi Ayarlayın"

msgctxt "PANOPTICON_SETUP_LBL_CRON_SUBHEAD"
msgid ""
"Panopticon uses a lot of automation to make your life easier. For this, you need "
"to set up a CRON job to run every minute."
msgstr ""
"Panopticon hayatınızı kolaylaştırmak için birçok otomasyon kullanıyor. Bunun "
"için her dakika çalışacak bir CRON işlevi kurmanız gerekiyor."

msgctxt "PANOPTICON_SETUP_LBL_CRON_SUBHEAD_CTA"
msgid ""
"Set up a CRON job using one of the methods below. Then, wait for up to a minute "
"for this page to change."
msgstr ""
"Aşağıdaki yöntemlerden birini kullanarak bir CRON işlevi ayarlayın. Daha sonra "
"bu sayfanın değişmesi için bir dakika kadar bekleyin."

msgctxt "PANOPTICON_SETUP_LBL_CRON_SUBHEAD_BREATHE"
msgid "Take a breath. This is the last installation step. You're almost done."
msgstr "Nefes alın. Bu son kurulum adımıdır. Neredeyse bitti."

msgctxt "PANOPTICON_SETUP_LBL_CRON_CLI_TABHEAD"
msgid "CLI"
msgstr "CLI"

msgctxt "PANOPTICON_SETUP_LBL_CRON_WEB_TABHEAD"
msgid "Web"
msgstr "Web"

msgctxt "PANOPTICON_SETUP_LBL_CRON_LBL_INSTRUCTIONS"
msgid "Instructions"
msgstr "Yönergeler"

msgctxt "PANOPTICON_SETUP_LBL_CRON_LBL_TROUBLESHOOTING"
msgid "Problem? Meet solution!"
msgstr "Sorun? Çözümle tanışın!"

msgctxt "PANOPTICON_SETUP_LBL_CRON_LBL_IS_THIS_RIGHT_FOR_ME"
msgid "Is this method the right one for me?"
msgstr "Bu yöntem benim için doğru yöntem mi?"

msgctxt "PANOPTICON_SETUP_LBL_CRON_LBL_PROS"
msgid "Pros"
msgstr "Artılar"

msgctxt "PANOPTICON_SETUP_LBL_CRON_LBL_CONS"
msgid "Cons"
msgstr "Eksiler"

msgctxt "PANOPTICON_SETUP_LBL_CRON_LBL_TARGET_AUDIENCE"
msgid "Target Audience"
msgstr "Hedef Kitle"

msgctxt "PANOPTICON_SETUP_LBL_CRON_LBL_EVERY_MINUTE_ALERT_HEAD"
msgid "Make sure the CRON job runs <em>every minute</em>."
msgstr "CRON işlevinin <em>her dakika</em> çalıştığından emin olun."

msgctxt "PANOPTICON_SETUP_LBL_CRON_LBL_EVERY_MINUTE_ALERT_BODY"
msgid ""
"Running the CRON job less frequently results in outdated information and "
"unreliability, including broken sites due to incomplete Joomla!&reg; core "
"updates."
msgstr ""
"CRON işlevini daha seyrek çalıştırmak, eksik Joomla!™ çekirdek güncellemeleri "
"nedeniyle bozuk siteler de dahil olmak üzere eski bilgilere ve güvenilmezliğe "
"neden olur."

msgctxt "PANOPTICON_SETUP_LBL_CRON_CLI_CREATE_A_JOB"
msgid ""
"Go to your hosting control panel. Create a new CRON job. Set it to run "
"<strong>every minute</strong>. Use the following command line."
msgstr ""
"Barındırma kontrol panelinize gidin. Yeni bir CRON işlevi oluşturun. <strong>Her "
"dakika</strong> çalışacak şekilde ayarlayın. Aşağıdaki komut satırını kullanın."

msgctxt "PANOPTICON_SETUP_LBL_CRON_REPLACE_PHP_CLI"
msgid ""
"Replace <i>/path/to/php</i> with the path to the PHP %s CLI executable. Make "
"sure it's the PHP CLI executable, <strong>not</strong> the PHP CGI/FastCGI "
"executable."
msgstr ""
"<i>/path/to/php</i> yerine PHP %s CLI çalıştırılabilir dosyasının yolunu yazın. "
"Bunun PHP CGI/FastCGI çalıştırılabiliri <strong>değil</strong>, PHP CLI "
"çalıştırılabiliri olduğundan emin olun."

msgctxt "PANOPTICON_SETUP_LBL_CRON_IF_UNSURE"
msgid "If unsure what some or any of the above means, please ask your host."
msgstr ""
"Yukarıdakilerden bazılarının veya herhangi birinin ne anlama geldiğinden emin "
"değilseniz, lütfen barındırıcınıza sorun."

msgctxt "PANOPTICON_SETUP_LBL_CRON_TROUBLE_NOT_RUN_HEAD"
msgid "The CRON job does not run"
msgstr "CRON işlevi çalışmıyor"

msgctxt "PANOPTICON_SETUP_LBL_CRON_TROUBLE_NOT_RUN_INFO_1"
msgid ""
"Remove the <code>2>&1</code> from the CRON command line. When the CRON command "
"executes again you will receive an email with an error (as long as your hosting "
"account is configured to email you the output of CRON jobs). Using that, you can "
"find out what is going on."
msgstr ""
"CRON komut satırından <code>2&gt;&amp;1</code> 'i kaldırın. CRON komutu tekrar "
"çalıştırıldığında hata içeren bir e-posta alacaksınız (barındırma hesabınız CRON "
"işlevinin çıktısını size e-posta ile gönderecek şekilde yapılandırıldığı "
"sürece). Bunu kullanarak neler olup bittiğini öğrenebilirsiniz."

msgctxt "PANOPTICON_SETUP_LBL_CRON_TROUBLE_NOT_RUN_INFO_2"
msgid ""
"If even then nothing seems to happen, please contact your host. Either your "
"account is not receiving the output of the CRON jobs, or the CRON jobs are not "
"executing at all (while unlikely, we've seen that happen a few times)."
msgstr ""
"Bu durumda bile hiçbir şey olmuyorsa, lütfen ana bilgisayarınızla iletişime "
"geçin. Ya hesabınız CRON işlevinin çıktısını almıyor ya da CRON işlevi hiç "
"yürütülmüyor (pek olası olmasa da, bunun birkaç kez olduğunu gördük)."

msgctxt "PANOPTICON_SETUP_LBL_CRON_TROUBLE_FORBIDDEN_HEAD"
msgid "I get “Status: 403 Forbidden” running the CRON job"
msgstr "CRON görevini çalıştırdığımda “Durum: 403 Erişim Yasak” hatası alıyorum"

msgctxt "PANOPTICON_SETUP_LBL_CRON_TROUBLE_FORBIDDEN_INFO_1"
msgid ""
"You are using the PHP-CGI/FastCGI executable. As noted above, you need to "
"replace <em>/path/to/php</em> with the path to the <strong>PHP CLI</strong> "
"executable."
msgstr ""
"PHP-CGI/FastCGI yürütülebilir dosyasını kullanıyorsunuz. Yukarıda belirtildiği "
"gibi, <em>/path/to/php</em> yerine <strong>PHP CLI</strong> yürütülebilir "
"dosyasının yolunu koymanız gerekir."

msgctxt "PANOPTICON_SETUP_LBL_CRON_TROUBLE_FORBIDDEN_INFO_2"
msgid ""
"Please ask your host for the correct path. If your host gave you this path to "
"begin with, escalate your support ticket with your host, asking to speak with a "
"server engineer. It's trivial for them to give you that path."
msgstr ""
"Lütfen barındırma sağlayıcınıza doğru yolu sorun. Eğer barındırma sağlayıcınız "
"size başlangıçta bu yolu vermişse, destek talebinizi bir üst düzeye taşıyın ve "
"bir sunucu mühendisiyle görüşmek istediğinizi belirtin. Onlar için size bu yolu "
"vermek çok kolaydır."

msgctxt "PANOPTICON_SETUP_LBL_CRON_TROUBLE_WRONG_PHP_HEAD"
msgid "I get “Akeeba Panopticon requires PHP %s or later”."
msgstr ""
"Akeeba Panopticon için “PHP %s veya üstü sürümü gereklidir” uyarısı alıyorum."

msgctxt "PANOPTICON_SETUP_LBL_CRON_TROUBLE_WRONG_PHP_INFO_1"
msgid ""
"You are using the PHP CLI executable for the wrong PHP version in your CRON job."
msgstr ""
"CRON işlevibde yanlış PHP sürümü için PHP CLI yürütülebilir dosyasını "
"kullanıyorsunuz."

msgctxt "PANOPTICON_SETUP_LBL_CRON_TROUBLE_WRONG_PHP_INFO_2"
msgid ""
"Most servers have multiple versions of PHP installed. You need to ask your host "
"to give you the path to the PHP CLI executable for PHP %s and use that in your "
"CRON job's command line."
msgstr ""
"Çoğu sunucuda PHP'nin birden fazla sürümü yüklüdür. Sunucunuzdan PHP %s için PHP "
"CLI çalıştırılabilir dosyasının yolunu vermesini istemeniz ve CRON işlevinin "
"komut satırında bunu kullanmanız gerekir."

msgctxt "PANOPTICON_SETUP_LBL_CRON_TROUBLE_URL_CRON_HEAD"
msgid "The host only allows URLs in CRON"
msgstr "Ana bilgisayar CRON'da yalnızca bağlantılara izin veriyor"

msgctxt "PANOPTICON_SETUP_LBL_CRON_TROUBLE_URL_CRON_INFO"
msgid "Click on the <strong>Web</strong> tab above."
msgstr "Yukarıdaki <strong>Web</strong> sekmesine tıklayın."

msgctxt "PANOPTICON_SETUP_LBL_CRON_TROUBLE_NO_CRON_HEAD"
msgid "The host does not have a CRON feature"
msgstr "Ana bilgisayarın CRON özelliği yok"

msgctxt "PANOPTICON_SETUP_LBL_CRON_TROUBLE_NO_CRON_INFO_1"
msgid "We <strong>very strongly</strong> recommend that you use a different host."
msgstr ""
"Farklı bir barındırıcı kullanmanızı <strong>şiddetle</strong> tavsiye ederiz."

msgctxt "PANOPTICON_SETUP_LBL_CRON_TROUBLE_NO_CRON_INFO_2"
msgid ""
"Panopticon is only useful when its automation features run consistently and "
"reliably. This requires its CRON job executing every minute - <em>1440 times a "
"day</em>. This can get expensive with a third party service; about $10 per day! "
"You can instead spend as much money <em>per month</em> on a decent host which "
"support real, command-line CRON jobs."
msgstr ""
"Panopticon yalnızca otomasyon özellikleri tutarlı ve güvenilir bir şekilde "
"çalıştığında kullanışlıdır. Bu, CRON işlevinin her dakika - <em>günde 1440 kez</"
"em>- yürütülmesini gerektirir. Bu, üçüncü taraf bir hizmetle pahalıya mal "
"olabilir; günde yaklaşık 10 dolar! Bunun yerine gerçek, komut satırı CRON "
"işlevini destekleyen iyi bir ana bilgisayara <em>aylık</em> aynı miktarda para "
"harcayabilirsiniz."

msgctxt "PANOPTICON_SETUP_LBL_CRON_TROUBLE_NO_CRON_INFO_3"
msgid ""
"If you have a cheaper way executing CRON jobs remotely (e.g. another server "
"under your control), please click on the <strong>Web</strong> tab to find out "
"how to do it."
msgstr ""
"CRON işlevini uzaktan yürütmek için daha ucuz bir yolunuz varsa (örneğin, "
"kontrolünüz altındaki başka bir sunucu), nasıl yapılacağını öğrenmek için lütfen "
"<strong>Web</strong> sekmesine tıklayın."

msgctxt "PANOPTICON_SETUP_LBL_CRON_TROUBLE_NO_CRON_INFO_4"
msgid ""
"<strong>Do not “cheap out” on CRON job frequency!</strong> Running CRON jobs "
"less frequently will make Panopticon unreliable and could even break your sites "
"due to incomplete Joomla&reg; core updates."
msgstr ""
"<strong>CRON işlev sıklığı konusunda \"ucuza kaçmayın\"!</strong> CRON işlevini "
"daha az sıklıkta çalıştırmak Panopticon'u güvenilmez hale getirecek ve hatta "
"eksik Joomla™ çekirdek güncellemeleri nedeniyle sitelerinizi bozabilir."

msgctxt "PANOPTICON_SETUP_LBL_CRON_CLI_PROS_1"
msgid "More reliable"
