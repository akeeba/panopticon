msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_APIERROR_HEAD"
msgid "Akeeba Backup JSON API Error"
msgstr "Akeeba Backup JSON API Hatası"

msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_APIERROR_BODY"
msgid "There was an error connecting to your site's Akeeba Backup JSON API."
msgstr "Sitenizin Akeeba Backup JSON API'sine bağlanırken bir hata oluştu."

msgctxt "PANOPTICON_SITES_LBL_AKEEBABACKUP_APIERROR_TYPE"
