msgstr "Hesabınızı Etkinleştirin"

msgctxt "PANOPTICON_USERS_LBL_ACTIVATE_INFO"
msgid ""
"Enter your username, password, and the activation token from your email to "
"activate your account."
msgstr ""
"Hesabınızı etkinleştirmek için kullanıcı adınızı, şifrenizi ve e-postanızda "
"bulunan etkinleştirme kodunu girin."

msgctxt "PANOPTICON_USERS_LBL_ACTIVATE_TOKEN"
