msgctxt "PANOPTICON_PRIVILEGE_SUPER"
msgid "Superuser"
msgstr "Süper Kullanıcı"

msgctxt "PANOPTICON_PRIVILEGE_SUPER_HELP"
msgid ""
"Gives access to application-level configuration and automatically grants all "
"other permissions on all sites."
msgstr ""
"Uygulama düzeyinde yapılandırmaya erişim sağlar ve tüm sitelerdeki diğer tüm "
"izinleri otomatik olarak verir."

msgctxt "PANOPTICON_PRIVILEGE_VIEW"
msgid "View"
msgstr "Görünüm"

msgctxt "PANOPTICON_PRIVILEGE_VIEW_HELP"
msgid "Allows viewing site overview pages."
msgstr "Siteye genel bakış sayfalarını görüntülemenizi sağlar."

msgctxt "PANOPTICON_PRIVILEGE_ADMIN"
msgid "Administration"
msgstr "Yönetici"

msgctxt "PANOPTICON_PRIVILEGE_ADMIN_HELP"
msgid "Allows (re)configuring any sites."
msgstr "Herhangi bir sitenin (yeniden) yapılandırılmasına izin verir."

msgctxt "PANOPTICON_PRIVILEGE_RUN"
msgid "Execute"
msgstr "Yürüt"

msgctxt "PANOPTICON_PRIVILEGE_RUN_HELP"
msgid "Allows scheduling updates, taking backups, etc."
msgstr "Güncellemeleri planlamaya, yedekleme almaya vb. izin verir."

msgctxt "PANOPTICON_PRIVILEGE_ADDOWN"
msgid "Add Own"
msgstr "Kendisi Eklesin"

msgctxt "PANOPTICON_PRIVILEGE_ADDOWN_HELP"
msgid ""
"Allows adding new sites, owned by the user. To view and edit the sites the user "
"additionally needs either the View and Administration privileges, or the Edit "
"Own privilege."
msgstr ""
"Kullanıcının sahip olduğu yeni sitelerin eklenmesine izin verir. Kullanıcının "
"siteleri görüntülemek ve düzenlemek için ayrıca Görüntüleme ve Yönetme "
"ayrıcalıklarına ya da Kendisi Düzenlesin ayrıcalığına ihtiyacı vardır."

msgctxt "PANOPTICON_PRIVILEGE_EDITOWN"
msgid "Edit Own"
msgstr "Kendisi Düzenlesin"

msgctxt "PANOPTICON_PRIVILEGE_EDITOWN_HELP"
msgid ""
"Allows viewing and editing any site owned by the user, even if the user does not "
"have the View or Administration privilege respectively."
msgstr ""
"Kullanıcının sırasıyla Görüntüleme veya Yönetme ayrıcalığı olmasa bile, "
"kullanıcıya ait herhangi bir sitenin görüntülenmesine ve düzenlenmesine olanak "
"tanır."

