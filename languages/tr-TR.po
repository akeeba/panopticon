msgstr "Joomla!&reg; Güncelleme Bilgilerini Yenile"

msgctxt "PANOPTICON_SITE_BTN_JUPDATE_RELOAD_SR"
msgid "Reload Joomla!&reg; Update information for site “%s”"
msgstr "“%s” sitesi için Joomla!&reg; Güncelleme bilgilerini yenile"

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_LAST_CHECKED"
msgid "Last checked:"
msgstr "Son Denetim:"

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_ERR_JOOMLA_FILES_EXT_MISSING"
msgid ""
"The Joomla! extension record is missing from your site. Joomla! cannot detect "
"whether updates to itself are available."
msgstr ""
"Sitenizde Joomla eklenti kaydı eksik. Joomla, kendisine yönelik güncellemelerin "
"mevcut olup olmadığını tespit edemiyor."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SEEK_HELP_JFORUM"
msgid ""
"Try asking for help on the <a href=\"https://forum.joomla.org\" "
"target=\"_blank\">Joomla! Forum</a>."
msgstr ""
"<a href=\"https://forum.joomla.org\" target=\"_blank\">Joomla! Forum</a>'da "
"yardım istemeyi deneyin."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_ALT_FIX"
msgid "Alternatively, try clicking the button below."
msgstr "Alternatif olarak aşağıdaki düğmeye tıklamayı deneyin."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_ERR_UPDATESITE_MISSING"
msgid ""
"The Joomla! Update Site record is missing from your site. Joomla! cannot detect "
"whether updates to itself are available."
msgstr ""
"Joomla Güncelleme Sitesi kaydı sitenizde eksik. Joomla, kendisine yönelik "
"güncellemelerin mevcut olup olmadığını tespit edemiyor."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_UPDATESITE_FIX_J4"
msgid ""
"Go to your site's administrator backend, System, Update, Update Sites, and click "
"on the Rebuild button."
msgstr ""
"Sitenizin yönetici arka ucuna gidin, Sistem, Güncelle, Siteleri Güncelle ve "
"Yeniden Oluştur düğmesine tıklayın."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_UPDATESITE_FIX_J3"
msgid ""
"Go to your site's administrator backend, Extensions, Manage, Update Sites, and "
"click on the Rebuild button."
msgstr ""
"Sitenizin yönetici arka ucuna, Eklentiler, Yönet, Siteleri Güncelle'ye gidin ve "
"Yeniden Oluştur düğmesine tıklayın."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_COREUPDATESITEFIX_BTN"
msgid "Attempt an automatic fix"
msgstr "Otomatik Düzeltmeyi Deneyin"

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_AVAILABLE_UPDATE"
msgid "Joomla! %s is available"
msgstr "Joomla %s mevcut"

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_CURRENT_VERSION"
msgid "Your site is currently using Joomla! %s."
msgstr "Siteniz şu anda Joomla %s kullanıyor."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_IS_PATCH_RELEASE"
msgid "This is a patch (point) update which is almost always safe."
msgstr "Bu, neredeyse her zaman güvenli olan bir yama (özellik) güncellemesidir."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_IS_MINOR_RELEASE"
msgid ""
"This is a minor (version family) update which may affect your template "
"overrides, templates, and some third party extensions."
msgstr ""
"Bu, şablon geçersiz kılmalarınızı, şablonlarınızı ve bazı üçüncü taraf "
"eklentilerinizi etkileyebilecek küçük (sürüm ailesi) bir güncellemedir."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_MINOR_RELEASE_ADMONISHMENT"
msgid ""
"It is a good idea to take a backup of your site, and test this update on a copy "
"of your site first."
msgstr ""
"Sitenizin yedeğini almanız ve bu güncellemeyi öncelikle sitenizin bir kopyasında "
"test etmeniz iyi bir fikirdir."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_IS_MAJOR_RELEASE"
msgid ""
"This is a major version update which will most likely affect your template "
"overrides, templates, and possibly some third party extensions."
msgstr ""
"Bu büyük olasılıkla şablon geçersiz kılmalarınızı, şablonlarınızı ve muhtemelen "
"bazı üçüncü taraf eklentilerinizi etkileyecek büyük bir sürüm güncellemesidir."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_MAJOR_RELEASE_ADMONISHMENT"
msgid ""
"It is very strongly recommended that you take a backup of your site, and test "
"this update on a copy of your site first."
msgstr ""
"Sitenizin bir yedeğini almanız ve bu güncellemeyi önce sitenizin bir kopyasında "
"test etmeniz şiddetle tavsiye edilir."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_UP_TO_DATE"
msgid "Joomla! %s is up-to-date"
msgstr "Joomla %s güncel"

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_EOL"
msgid "Joomla! %s is unsupported"
msgstr "Joomla %s desteklenmiyor"

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_EOL_MAJOR"
msgid "The Joomla! %s series is End-of-Life"
msgstr "Joomla %s serisinin kullanım ömrü sonu"

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_EOL_MINOR"
msgid "The Joomla! %s version family is End-of-Life"
msgstr "Joomla %s sürüm ailesinin kullanım ömrü sonu"

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_EOL_DATE"
msgid "Joomla! %s became End of Life on %s"
msgstr "Joomla %s, %s tarihinde kullanım ömrü doldu"

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SECURITY_DATE"
msgid ""
"Joomla! %s receives security updates only since %s and will become End-of-Life "
"on %s."
msgstr ""
"Joomla %s yalnızca %s tarihinden itibaren güvenlik güncellemeleri almaktadır ve "
"%s tarihindekullanım ömrü dolacaktır."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_STABLE_DATE"
msgid ""
"Joomla! %s receives security updates and bug fixes until %s. It will become End-"
"of-Life and superseded by a new minor version on %s."
msgstr ""
"Joomla %s, %s tarihine kadar güvenlik güncellemelerini ve hata düzeltmelerini "
"alacak %starihinde kullanım ömrü dolacak ve yeni bir küçük "
"sürümledeğiştirilecektir."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_LAST_STABLE_DATE"
msgid ""
"Joomla! %s receives security updates and bug fixes until %s. It will become End-"
"of-Life on %s. It is superseded by a new major version."
msgstr ""
"Joomla! %s, %s tarihine kadar güvenlik güncellemelerini ve hata "
"düzeltmelerinialacak. %s tarihinde kullanım ömrü dolacak. Yeni bir ana "
"sürümledeğiştirilir."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_CANNOT_INSTALL"
msgid ""
"The newer Joomla! version %s is available but cannot be installed because of "
"your site preferences."
msgstr ""
"Daha yeni Joomla! sürümü %s mevcuttur ancak site tercihleriniz nedeniyle "
"yüklenemez."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_FIX_TO_INSTALL_NEXT_VERSION"
msgid ""
"Go to your site's administrator backend, System, Update, Joomla, click on "
"Options, and change the update channel to Joomla Next. Please check Joomla's "
"requirements, especially the database version and PHP version requirements. Note "
"that your site is currently using PHP %s."
msgstr ""
"Sitenizin yönetici arka ucuna gidin, Sistem, Güncelleme, Joomla, Seçenekler'e "
"tıklayın ve güncelleme kanalını Joomla Sonraki olarak değiştirin. Lütfen "
"Joomla'nın gereksinimlerini, özellikle de veritabanı sürümü ve PHP sürümü "
"gereksinimlerini kontrol edin. Sitenizin şu anda PHP %s kullandığını unutmayın."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_NOT_SCHEDULED"
msgid ""
"The update is <span class=\"text-danger fw-semibold\">not scheduled</span> to "
"run automatically. You can run the update manually on your site, or click on the "
"button below."
msgstr ""
"Güncelleme <span class=\"text-danger fw-semibold\">otomatik olarak çalışacak "
"şekilde planlanmadı</span>. Güncellemeyi sitenizde elle çalıştırabilir veya "
"aşağıdaki düğmeye tıklayabilirsiniz."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SCHEDULED"
msgid ""
"The update is <span class=\"fw-semibold text-success\">scheduled</span> to run "
"automatically after %s."
msgstr ""
"Güncelleme %s sonrasında otomatik olarak çalışacak şekilde <span class=\"fw-"
"semibold text-success\">planlandı</span>."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SCHEDULED_ASAP"
msgid ""
"The update is <span class=\"fw-semibold text-success\">scheduled</span> to run "
"automatically as soon as possible."
msgstr ""
"Güncelleme, mümkün olan en kısa sürede otomatik olarak çalışacak şekilde <span "
"class=\"fw-semibold text-success\">planlandı</span>."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_RUNNING"
msgid ""
"The update is <span class=\"fw-semibold text-success\">currently taking place</"
"span>"
msgstr ""
"Güncelleme <span class=\"fw-semibold text-success\">şu anda gerçekleştiriliyor</"
"span>"

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_ERRORED"
msgid "The update was scheduled to run automatically but ran into an error:"
msgstr ""
"Güncellemenin otomatik olarak çalışması planlandı ancak bir hatayla karşılaştı:"

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_THE_ERROR_REPORTED_WAS"
msgid "The error reported was:"
msgstr "Bildirilen hata şuydu:"

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_ERROR_TRACE"
msgid "Error trace (for debugging):"
msgstr "Hata izleme (hata ayıklama için):"

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SCHEDULE_UPDATE"
msgid "Schedule Automatic Update to Joomla! %s"
msgstr "Joomla %s için Otomatik Güncelleme Planla"

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_UNSCHEDULE_UPDATE"
msgid "Cancel Automatic Update"
msgstr "Otomatik Güncellemeyi İptal Et"

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_UNSCHEDULE_ERR_NOT_SCHEDULED"
msgid "There is no scheduled update."
msgstr "Planlanmış bir güncelleme yok."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_UNSCHEDULE_ERR_RUNNING"
msgid "The scheduled update is already running."
msgstr "Planlanan güncelleme zaten çalışıyor."

msgctxt "PANOPTICON_SITE_ERR_JUPDATE_UNSCHEDULE_FAILED"
msgid "Could not cancel the Joomla core update."
msgstr "Joomla çekirdek güncellemesi iptal edilemedi."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SCHEDULE_CLEAR_ERROR"
msgid "Clear Error"
msgstr "Hatayı Temizle"

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_REFRESH_CORE_PROMPT"
msgid "Site woes? Try refreshing the Joomla! core files."
msgstr "Site sorunları mı var? Joomla çekirdek dosyalarını yenilemeyi deneyin."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_BTN_REFRESH_CORE_PROMPT"
msgid "Schedule Joomla! %s Files Refresh"
msgstr "Joomla %s Dosyalarını Yenilemeyi Planlayın"

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_REFRESH_CORE_NOTE"
msgid ""
"Refreshing the Joomla! core files is <em>always safe</em>. Your site contents "
"will not be changed. Use this to undo changes to the Joomla! core files (“core "
"hacks”), or if you suspect that your site does not work correctly because of a "
"failed update."
msgstr ""
"Joomla çekirdek dosyalarını yenilemek <em>her zaman güvenlidir</em>. Site "
"içeriğiniz değişmez. Joomla'da yapılan değişiklikleri geri almak için bunu "
"kullanın. Joomla çekirdek dosyalarındaki değişiklikleri geri almak için (“core "
"hacks”) veya sitenizin başarısız bir güncelleme nedeniyle düzgün çalışmadığından "
"kuşkulanıyorsanız bunu kullanın."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_REFRESH_SCHEDULED"
msgid ""
"The core files refresh is <span class=\"fw-semibold text-success\">scheduled</"
"span> to run automatically after %s."
msgstr ""
"Çekirdek dosyaların yenilenmesi %s sonrasında otomatik olarak çalışacak şekilde "
"<span class=\"fw-semibold text-success\">planlandı</span>."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_REFRESH_SCHEDULED_ASAP"
msgid ""
"The core files refresh is <span class=\"fw-semibold text-success\">scheduled</"
"span> to run automatically as soon as possible."
msgstr ""
"Çekirdek dosyaların yenilenmesi, mümkün olan en kısa sürede otomatik olarak "
"çalışacak şekilde <span class=\"fw-semibold text-success\">planlandı</span>."

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_REFRESH_RUNNING"
msgid ""
"The core files refresh is <span class=\"fw-semibold text-success\">currently "
"taking place</span>"
msgstr ""
"Çekirdek dosyaların yenilenmesi <span class=\"fw-semibold text-success\">şu anda "
"gerçekleştiriliyor</span>"

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_REFRESH_ERRORED"
msgid "The core files refresh ran into an error:"
msgstr "Çekirdek dosyaların yenilenmesinde bir hata oluştu:"

msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SOURCE_INFO"
msgid ""
"The Joomla! update availability information is provided by your site. Joomla! "
"End-of-Life and security-only support dates are manually collected from the "
"information published by the Joomla! project."
msgstr ""
"Joomla güncelleme kullanılabilirlik bilgileri siteniz tarafından sağlanır. "
"Joomla Kullanım Ömrü Sonu ve yalnızca güvenlikle ilgili destek tarihleri, Joomla "
"projesi tarafından yayımlanan bilgilerden elle toplanır."

msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_SCHEDULE_OK"
msgid "Scheduled the WordPress core update."
msgstr "WordPress çekirdek güncellemesi planlandı."

msgctxt "PANOPTICON_SITE_ERR_WPUPDATE_SCHEDULE_FAILED"
msgid "Scheduling the WordPress core update has failed."
msgstr "WordPress çekirdek güncellemesinin planlanması başarısız oldu."

msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_SCHEDULE_ERROR_CLEARED"
msgid "The scheduling error has been cleared."
msgstr "Planlama hatası giderildi."

msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_SCHEDULE_ERROR_NOT_CLEARED"
msgid "The scheduling error could not be cleared: %s"
msgstr "Planlama hatası temizlenemedi: %s"

msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_UNSCHEDULE_ERR_NOT_SCHEDULED"
msgid "There is no scheduled update."
msgstr "Planlanmış bir güncelleme yok."

msgctxt "PANOPTICON_SITE_LBL_WPUPDATE_UNSCHEDULE_ERR_RUNNING"
