msgstr "Etkinleştirme Belirteci"

msgctxt "PANOPTICON_USERS_LBL_ACTIVATE_SUBMIT_BUTTON"
msgid "Activate Account"
msgstr "Hesabı Etkinleştir"

msgctxt "PANOPTICON_USERS_LBL_ACTIVATE_SUCCESS"
msgid "Your account has been activated. You can now log in."
msgstr "Hesabınız etkinleştirildi. Artık giriş yapabilirsiniz."

msgctxt "PANOPTICON_USERS_LBL_ACTIVATE_FAILED"
msgid "Activation failed. Please check your username, password, and token."
msgstr ""
"Etkinleştirme işlemi başarısız oldu. Lütfen kullanıcı adınızı, şifrenizi ve "
"belirtecinizi kontrol edin."

msgctxt "PANOPTICON_USERS_LBL_ACTIVATE_EXPIRED"
