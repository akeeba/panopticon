msgstr "Dies ist keine Joomla 4.0.0 bis 4.0.3 (einschließlich) Website; restore.php kann nicht für Aktualisierungen verwendet werden."

#, phpformat
msgctxt "PANOPTICON_TASK_JOOMLAUPDATE_ERR_NOT_J404"
