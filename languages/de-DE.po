msgstr "Wann sollen Aktualisierungen installiert werden"

#, phpformat
msgctxt "PANOPTICON_SITES_OPT_CONFIG_EXTENSIONS_UPDATE_WHEN_IMMEDIATELY"
msgid "Immediately"
msgstr "Sofort"

#, phpformat
msgctxt "PANOPTICON_SITES_OPT_CONFIG_EXTENSIONS_UPDATE_WHEN_TIME"
msgid "Time of Day"
msgstr "Tageszeit"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_EXTENSIONS_UPDATE_TIME"
msgid "Time Of The Day to Install Extension Updates On (Hour:Minute)"
msgstr "Uhrzeit für die Installation von Erweiterungsaktualisierungen (Stunde:Minute)"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_EXTENSIONS_UPDATE_TIME_HELP"
msgid "The time expressed in the %s timezone. If updates are found <em>after</em> this time of the day the update installation will take place on the next calendar day. Avoid using the Daylight Savings Time changeover time of the day (usually: between 2am and 4am); otherwise, update scheduling will act in what you perceive to be a “weird” or “wrong” way if an update is found on the day of the Daylight Savings Time changeover. Manually-triggered updates always run immediately, regardless of this setting."
msgstr "Die Zeit wird in der Zeitzone %s angegeben. Wenn Aktualisierungen <em>nach</em> diesem Zeitpunkt gefunden werden, erfolgt die Installation am nächsten Kalendertag. Vermeiden Sie die Verwendung des Zeitpunkts der Zeitumstellung (in der Regel zwischen 2:00 und 4:00 Uhr); andernfalls verhält sich die Aktualisierungsplanung am Tag der Zeitumstellung auf eine Weise, die Sie als „seltsam\" oder „falsch\" empfinden könnten. Manuell ausgelöste Aktualisierungen werden unabhängig von dieser Einstellung immer sofort ausgeführt."

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_CORE_UPDATE_EMAIL_CC"
msgid "CC the Following Email Addresses"
msgstr "Folgende E-Mail-Adressen in CC setzen"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_CORE_UPDATE_EMAIL_CC_HELP"
msgid "A comma-separated list of additional email addresses to Carbon Copy when sending emails about the site update. Addresses can be in the format <code>foo@example.com</code> (only email address) or <code>Mr. Foo Bar &lt;foo@example.com&gt;</code> (name and address)."
msgstr "Eine kommagetrennte Liste zusätzlicher E-Mail-Adressen, die beim Versand von E-Mails über Website-Aktualisierungen in Kopie (CC) gesetzt werden. Adressen können im Format <code>foo@example.com</code> (nur E-Mail-Adresse) oder <code>Max Mustermann &lt;foo@example.com&gt;</code> (Name und Adresse) angegeben werden."

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_CORE_UPDATE_EMAIL_ERROR"
msgid "Send Email after Update Failure"
msgstr "E-Mail nach Aktualisierungsfehler senden"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_CORE_UPDATE_EMAIL_AFTER"
msgid "Send Email after Update Success"
msgstr "E-Mail nach erfolgreicher Aktualisierung senden"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_CORE_UPDATE_EMAIL_LOG_GROUPS"
msgid "Attach Log File for These Groups"
msgstr "Protokolldatei für diese Gruppen anhängen"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_CORE_UPDATE_EMAIL_LOG_GROUPS_HELP"
msgid "Override the global setting: select which user groups receive the task log file as an email attachment on failure. Leave empty to use the global Panopticon setting."
msgstr "Globale Einstellung überschreiben: Wählen Sie aus, welche Benutzergruppen die Aufgaben-Protokolldatei bei einem Fehler als E-Mail-Anhang erhalten. Leer lassen, um die globale Panopticon-Einstellung zu verwenden."

#, phpformat
msgctxt "PANOPTICON_LBL_SITE_SAVED"
msgid "The Site definition has been saved."
msgstr "Die Website-Definition wurde gespeichert."

#, phpformat
msgctxt "PANOPTICON_LBL_SITE_COPIED"
msgid "The selected Site definition(s) have been copied."
msgstr "Die ausgewählten Website-Definitionen wurden kopiert."

#, phpformat
msgctxt "PANOPTICON_LBL_SITE_DELETED"
msgid "The selected Site definition(s) have been deleted."
msgstr "Die ausgewählten Website-Definitionen wurden gelöscht."

#, phpformat
msgctxt "PANOPTICON_LBL_FIELD_ENABLED_HELP"
msgid "Controls whether the site is shown in the Overview page, whether its information is automatically refreshed, and whether it participates in any kind of scheduled (automatic) actions such as updates."
msgstr "Steuert, ob die Website auf der Übersichtsseite angezeigt wird, ob ihre Informationen automatisch aktualisiert werden und ob sie an geplanten (automatischen) Aktionen wie Aktualisierungen teilnimmt."

#, phpformat
msgctxt "PANOPTICON_LBL_SITE_OWNERSHIP"
msgid "Site Ownership"
msgstr "Website-Eigentümerschaft"

#, phpformat
msgctxt "PANOPTICON_LBL_SITE_OWNERSHIP_NON_SUPER"
msgid "If you need the site ownership information modified please contact a user with administration or superuser privileges."
msgstr "Wenn Sie die Informationen zur Website-Eigentümerschaft ändern möchten, wenden Sie sich bitte an einen Benutzer mit Administrator- oder Superbenutzerrechten."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_GROUPS_INFO"
msgid "This section is only relevant to multi–user installations with different access per site; please consult the documentation for more information. If you are managing a single–user installation, or if all users have equal access to all sites, you can ignore it."
msgstr "Dieser Abschnitt ist nur für Mehrbenutzerinstallationen mit unterschiedlichem Zugriff pro Website relevant. Weitere Informationen finden Sie in der Dokumentation. Wenn Sie eine Einzelbenutzerinstallation verwalten oder alle Benutzer gleichen Zugriff auf alle Websites haben, können Sie diesen Abschnitt ignorieren."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_GROUPS"
msgid "Groups"
msgstr "Gruppen"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_GROUPS_PLACEHOLDER"
msgid "Select one or more groups (optional)"
msgstr "Eine oder mehrere Gruppen auswählen (optional)"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_DLKEY_EDIT_TITLE"
msgid "Edit a Download Key"
msgstr "Download-Schlüssel bearbeiten"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_DLKEY"
msgid "Download Key"
msgstr "Download-Schlüssel"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_CONNECTION_DOCTOR_TITLE"
msgid "Connection Doctor"
msgstr "Verbindungsdiagnose"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_CONNECTION_DOCTOR_OKAY"
msgid "All good!"
msgstr "Alles in Ordnung!"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_CONNECTION_DOCTOR_OKAY_MORE"
msgid "The connection to your site was tested, and found to be working fine."
msgstr "Die Verbindung zu Ihrer Website wurde getestet und funktioniert einwandfrei."

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_SSL_WARNING"
msgid "SSL/TLS Expiration First Warning"
msgstr "Erste Warnung vor SSL/TLS-Ablauf"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_SSL_WARNING_HELP"
msgid "Panopticon will warn you that your site\'s SSL/TLS certificate is expiring this many days before it expires. 0 disables the warning."
msgstr "Panopticon warnt Sie, dass das SSL/TLS-Zertifikat Ihrer Website in dieser Anzahl von Tagen abläuft. 0 deaktiviert die Warnung."

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_DOMAIN_WARNING"
msgid "Domain Expiration First Warning"
msgstr "Erste Warnung vor Domainablauf"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_DOMAIN_WARNING_HELP"
msgid "Panopticon will warn you that your site\'s domain name is expiring this many days before it expires. 0 disables the warning."
msgstr "Panopticon warnt Sie, dass der Domainname Ihrer Website in dieser Anzahl von Tagen abläuft. 0 deaktiviert die Warnung."

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_BACKUP_MAX_AGE"
msgid "Maximum Backup Age"
msgstr "Maximales Sicherungsalter"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_BACKUP_MAX_AGE_HELP"
msgid "Successful backups will be considered “too old” after this many hours. Use 0 to disable this feature."
msgstr "Erfolgreiche Sicherungen gelten nach dieser Anzahl von Stunden als „zu alt\". Verwenden Sie 0, um diese Funktion zu deaktivieren."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSL_TLS_CERT_INFO"
msgid "SSL/TLS (HTTPS) Certificate Information"
msgstr "SSL/TLS (HTTPS)-Zertifikatsinformationen"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_TABLE_CAPTION"
msgid "Table of SSL/TLS certificate information"
msgstr "Tabelle mit SSL/TLS-Zertifikatsinformationen"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_SERIAL"
msgid "Serial"
msgstr "Seriennummer"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_SIG_TYPE"
msgid "Signature Type"
msgstr "Signaturtyp"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_FROM"
msgid "Valid From"
msgstr "Gültig ab"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_TO"
msgid "Valid To"
msgstr "Gültig bis"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_CN"
msgid "Common Names (domains)"
msgstr "Allgemeine Namen (Domains)"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_ISSUER"
msgid "Issued By"
msgstr "Ausgestellt von"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_ERR_DATE_INVALID_HEAD"
msgid "Unknown Validity"
msgstr "Unbekannte Gültigkeit"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_ERR_DATE_INVALID"
msgid "The SSL/TLS certificate lacks valid from/to dates, making it impossible to determine whether it is valid."
msgstr "Das SSL/TLS-Zertifikat verfügt über keine gültigen Gültigkeitsdaten, sodass nicht festgestellt werden kann, ob es gültig ist."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_TOOSOON_HEAD"
msgid "Invalid (Too Soon)"
msgstr "Ungültig (zu früh)"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_TOOSOON"
msgid "The SSL/TLS certificate has a Valid From date in the future. Browsers will report it as invalid as it\'s not meant to be used just yet."
msgstr "Das SSL/TLS-Zertifikat hat ein Gültigkeitsdatum in der Zukunft. Browser melden es als ungültig, da es noch nicht verwendet werden soll."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_EXPIRING_HEAD"
msgid "Imminent Expiration"
msgstr "Unmittelbar bevorstehender Ablauf"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_EXPIRING"
msgid "The SSL/TLS certificate will expire soon. You need to replace it with a new one to prevent problems with your site."
msgstr "Das SSL/TLS-Zertifikat läuft bald ab. Sie müssen es durch ein neues ersetzen, um Probleme mit Ihrer Website zu vermeiden."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_EXPIRED_HEAD"
msgid "Expired"
msgstr "Abgelaufen"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_EXPIRED"
msgid "The SSL/TLS certificate has a Valid To date in the past. Browsers will report it as invalid as it\'s not meant to be used any more."
msgstr "Das SSL/TLS-Zertifikat hat ein Ablaufdatum in der Vergangenheit. Browser melden es als ungültig, da es nicht mehr verwendet werden soll."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_INVALID_CN_HEAD"
msgid "Invalid Domain"
msgstr "Ungültige Domain"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_INVALID_CN"
msgid "The SSL/TLS certificate is issued for a different domain name than the one you are using it for. Browsers will report it as invalid."
msgstr "Das SSL/TLS-Zertifikat wurde für einen anderen Domainnamen ausgestellt als den, für den Sie es verwenden. Browser melden es als ungültig."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_INVALID_SIG_HEAD"
msgid "Invalid or Self-signed Certificate"
msgstr "Ungültiges oder selbstsigniertes Zertifikat"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_INVALID_SIG"
msgid "The signature of your SSL/TLS certificate cannot be verified against the Certification Authorities known to the server. This usually means that you are using a self-signed certificate which will be rejected by browsers."
msgstr "Die Signatur Ihres SSL/TLS-Zertifikats kann nicht gegen die dem Server bekannten Zertifizierungsstellen verifiziert werden. Dies bedeutet in der Regel, dass Sie ein selbstsigniertes Zertifikat verwenden, das von Browsern abgelehnt wird."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO"
msgid "Domain Information"
msgstr "Domain-Informationen"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_ERR_DATE_INVALID_HEAD"
msgid "Unknown Validity"
msgstr "Unbekannte Gültigkeit"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_ERR_DATE_INVALID"
msgid "We could not retrieve the domain\'s expiration date. Either the domain name does not appear in the WHOIS database, or you are using a domain name which only resolves locally."
msgstr "Das Ablaufdatum der Domain konnte nicht abgerufen werden. Entweder erscheint der Domainname nicht in der WHOIS-Datenbank, oder Sie verwenden einen Domainnamen, der nur lokal auflöst."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_TOOSOON_HEAD"
msgid "Invalid (Too Soon)"
msgstr "Ungültig (zu früh)"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_TOOSOON"
msgid "The domain registrar claims the domain name was registered in a future date. This does not seem right."
msgstr "Der Domain-Registrar gibt an, dass der Domainname in einem zukünftigen Datum registriert wurde. Das scheint nicht korrekt zu sein."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_EXPIRING_HEAD"
msgid "Imminent Expiration"
msgstr "Unmittelbar bevorstehender Ablauf"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_EXPIRING"
msgid "The domain name will expire soon. You need to renew it with your registrar to avoid losing it."
msgstr "Der Domainname läuft bald ab. Sie müssen ihn bei Ihrem Registrar verlängern, um ihn nicht zu verlieren."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_EXPIRED_HEAD"
msgid "Expired"
msgstr "Abgelaufen"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_EXPIRED"
msgid "The domain name has expired. You might still be able to access the domain due to your registrar\'s grace period, but <strong>you must renew this domain name immediately with your registrar</strong> to avoid losing it."
msgstr "Der Domainname ist abgelaufen. Möglicherweise können Sie die Domain noch aufgrund der Kulanzfrist Ihres Registrars aufrufen, aber <strong>Sie müssen diesen Domainnamen sofort bei Ihrem Registrar verlängern</strong>, um ihn nicht zu verlieren."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_NONAMESERVERS_HEAD"
msgid "Missing nameservers"
msgstr "Fehlende Nameserver"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_NONAMESERVERS"
msgid "There are no nameservers reported in the WHOIS database. A site without valid nameservers will not be accessible on the Internet. If you recently assigned nameservers to the domain don\'t panic; it may take up to 5 days for this information to propagate."
msgstr "In der WHOIS-Datenbank sind keine Nameserver eingetragen. Eine Website ohne gültige Nameserver ist im Internet nicht erreichbar. Wenn Sie der Domain kürzlich Nameserver zugewiesen haben, keine Panik – es kann bis zu 5 Tage dauern, bis diese Informationen verbreitet sind."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_TABLE_CAPTION"
msgid "Table of domain information"
msgstr "Tabelle mit Domain-Informationen"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_DOMAIN"
msgid "Domain"
msgstr "Domain"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_REGISTERED"
msgid "Registered On"
msgstr "Registriert am"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_EXPIRES"
msgid "Expires On"
msgstr "Läuft ab am"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_REGISTRAR"
msgid "Registrar"
msgstr "Registrar"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_NAMESERVERS"
msgid "Nameservers"
msgstr "Nameserver"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_CACHING_NOTICE"
msgid "Domain registration information may be cached in the WHOIS servers for a period ranging from a few hours to a few days. As a result, the information above may be out of date."
msgstr "Domain-Registrierungsinformationen können in den WHOIS-Servern für einen Zeitraum von einigen Stunden bis zu einigen Tagen zwischengespeichert sein. Daher können die obigen Informationen veraltet sein."

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_UPTIME_TITLE"
msgid "Very Basic Site Uptime Monitoring"
msgstr "Einfaches Website-Verfügbarkeitsmonitoring"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_UPTIME_NOTE"
msgid "This is <em>very basic</em> uptime monitoring through Panopticon itself. It only notifies you by email when your site goes down and comes back up. It does not integrate with third party services, it does not offer history, it does not have a public uptime page. We strongly recommend using a third party service or software to monitor your sites\' uptime instead of using this feature."
msgstr "Dies ist ein <em>sehr einfaches</em> Verfügbarkeitsmonitoring durch Panopticon selbst. Es benachrichtigt Sie nur per E-Mail, wenn Ihre Website nicht erreichbar ist und wenn sie wieder erreichbar ist. Es lässt sich nicht mit Drittanbieterdiensten integrieren, bietet keine Historie und keine öffentliche Verfügbarkeitsseite. Wir empfehlen dringend, einen Drittanbieterdienst oder eine entsprechende Software zum Überwachen der Verfügbarkeit Ihrer Websites zu verwenden, anstatt diese Funktion zu nutzen."

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_UPTIME_ENABLED"
msgid "Monitor Uptime"
msgstr "Verfügbarkeit überwachen"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_UPTIME_ENABLED_HELP"
msgid "Disabling this option will no longer send you emails, log site actions, or display badges when your site goes down and comes back up."
msgstr "Wenn Sie diese Option deaktivieren, werden keine E-Mails mehr gesendet, keine Website-Aktionen protokolliert und keine Badges angezeigt, wenn Ihre Website nicht erreichbar ist oder wieder erreichbar wird."

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_UPTIME_PATH"
msgid "URL Path To Monitor"
msgstr "Zu überwachender URL-Pfad"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_UPTIME_STRING"
msgid "Look For This String"
msgstr "Nach dieser Zeichenkette suchen"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_UPTIME_STRING_HELP"
msgid "The site will be considered up if the page contains this string. Do <em>NOT</em> use HTML; all tags and multiple whitespaces are removed before evaluating this string. Leave blank to consider any HTTP 2xx response as adequate proof the site is up."
msgstr "Die Website gilt als verfügbar, wenn die Seite diese Zeichenkette enthält. Verwenden Sie <em>KEIN</em> HTML; alle Tags und mehrfache Leerzeichen werden vor der Auswertung dieser Zeichenkette entfernt. Leer lassen, um jede HTTP-2xx-Antwort als ausreichenden Beweis für die Verfügbarkeit der Website zu akzeptieren."

#, phpformat
msgctxt "PANOPTICON_SITES_BATCH_TITLE"
msgid "Batch process the selected sites"
msgstr "Ausgewählte Websites im Stapel verarbeiten"

#, phpformat
msgctxt "PANOPTICON_SITES_BATCH_PROCESS"
msgid "Process"
msgstr "Verarbeiten"

#, phpformat
msgctxt "PANOPTICON_SITES_BATCH_LBL_ADD_TO_GROUP"
msgid "Add to group"
msgstr "Zur Gruppe hinzufügen"

#, phpformat
msgctxt "PANOPTICON_SITES_BATCH_LBL_REMOVE_FROM_GROUP"
msgid "Remove from group"
msgstr "Aus Gruppe entfernen"

#, phpformat
msgctxt "PANOPTICON_SITES_BATCH_COMPLETED"
msgid "The group membership of sites you selected has been processed."
msgstr "Die Gruppenzugehörigkeit der ausgewählten Websites wurde verarbeitet."

#, phpformat
msgctxt "PANOPTICON_SITES_BATCH_ERR_NO_IDS"
msgid "You have not selected any sites to process the group membership of."
msgstr "Sie haben keine Websites für die Verarbeitung der Gruppenzugehörigkeit ausgewählt."

#, phpformat
msgctxt "PANOPTICON_SITES_TITLE_READ"
msgid "Site Information"
msgstr "Website-Informationen"

#, phpformat
msgctxt "PANOPTICON_ERR_SITES_NOTFOUND"
msgid "Site Record Not Found"
msgstr "Website-Datensatz nicht gefunden"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_REFRESHED_OK"
