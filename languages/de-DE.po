msgstr "⚠️ Einmal ausführen, dann diesen Zeitplan LÖSCHEN"

#, phpformat
msgctxt "PANOPTICON_BACKUPTASKS_LBL_TIMEZONE_NOTICE"
msgid "The backup schedule is a <a href=\'%s\' target=\'_blank\'>CRON expression</a>. It uses the %s time zone."
msgstr "Der Sicherungszeitplan ist ein <a href=\'%s\' target=\'_blank\'>CRON-Ausdruck</a>. Er verwendet die Zeitzone %s."

