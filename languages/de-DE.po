#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DASHBOARD_RELOAD_TIMER_HELP"
msgid "Dashboard views will reload every this many seconds, unless manually paused."
msgstr "Dashboard-Ansichten werden alle diese Anzahl von Sekunden neu geladen, sofern nicht manuell pausiert."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DASHBOARD_MAX_ITEMS"
msgid "Maximum Displayed Items"
msgstr "Maximal angezeigte Einträge"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DASHBOARD_MAX_ITEMS_HELP"
msgid "Panopticon always loads up to 50 sites per HTTP request. This is the maximum number of sites to be displayed <em>in total</em>."
msgstr "Panopticon lädt immer bis zu 50 Websites pro HTTP-Anfrage. Dies ist die maximale Anzahl der <em>insgesamt</em> anzuzeigenden Websites."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PHPWARNINGS"
