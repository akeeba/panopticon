msgid "Maximum Execution Time"
msgstr "Maximale Ausführungszeit"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_EXECUTION_BIAS"
msgid "Execution Time Bias"
msgstr "Ausführungszeitanpassung"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_ACCURATE_PHP_CLI"
msgid "Accurate PHP-CLI path"
msgstr "Genauer PHP-CLI-Pfad"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_ACCURATE_PHP_CLI_HELP"
msgid "Enable to have Akeeba Panopticon try to detect the accurate PHP-CLI path on your server. Disable if your server does not allow you to do that, locking your IP address out of your site for several minutes to hours when this happens (for example IONOS)."
msgstr "Aktivieren, damit Akeeba Panopticon versucht, den genauen PHP-CLI-Pfad auf Ihrem Server zu ermitteln. Deaktivieren, wenn Ihr Server dies nicht erlaubt und dabei Ihre IP-Adresse für mehrere Minuten bis Stunden von Ihrer Website sperrt (zum Beispiel IONOS)."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_SITEINFO_FREQ"
msgid "Frequency of Site Information Collection"
msgstr "Häufigkeit der Website-Informationssammlung"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_CACHING_TIME"
msgid "Default Cache Time"
msgstr "Standard-Cache-Zeit"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_CACHE_ADAPTER"
msgid "Storage"
msgstr "Speicher"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_CACHING_REDIS_DSN"
msgid "Redis Data Source Name (DSN)"
msgstr "Redis-Datenquellenname (DSN)"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_CACHING_REDIS_DSN_HELP"
msgid "How to connect to your Redis server. Please read <a href=\"https://symfony.com/doc/current/components/cache/adapters/redis_adapter.html#configure-the-connection\" target=\"_blank\">the Symfony Cache Redis adapter documentation</a> for information on the syntax."
msgstr "Wie eine Verbindung zu Ihrem Redis-Server hergestellt wird. Bitte lesen Sie <a href=\"https://symfony.com/doc/current/components/cache/adapters/redis_adapter.html#configure-the-connection\" target=\"_blank\">die Symfony Cache Redis-Adapter-Dokumentation</a> für Informationen zur Syntax."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_CACHING_MEMCACHED_DSN"
msgid "Memcached Data Source Name (DSN)"
msgstr "Memcached-Datenquellenname (DSN)"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_CACHING_MEMCACHED_DSN_HELP"
msgid "How to connect to your Memcached server. Please read <a href=\"https://symfony.com/doc/current/components/cache/adapters/memcached_adapter.html#configure-the-connection\" target=\"_blank\">the Symfony Cache Memcached adapter documentation</a> for information on the syntax."
msgstr "Wie eine Verbindung zu Ihrem Memcached-Server hergestellt wird. Bitte lesen Sie <a href=\"https://symfony.com/doc/current/components/cache/adapters/memcached_adapter.html#configure-the-connection\" target=\"_blank\">die Symfony Cache Memcached-Adapter-Dokumentation</a> für Informationen zur Syntax."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_LOG_LEVEL"
msgid "Log Level"
msgstr "Protokollierungsebene"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_LOG_ROTATE_COMPRESS"
msgid "Compress Rotated Logs"
msgstr "Rotierte Protokolle komprimieren"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_LOG_ROTATE_FILES"
msgid "Number of Rotated Logs"
msgstr "Anzahl rotierter Protokolle"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_LOG_BACKUP_THRESHOLD"
msgid "Log File Retention"
msgstr "Aufbewahrungsdauer der Protokolldatei"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DBBACKUP_AUTO"
msgid "Automatic Database Backups"
msgstr "Automatische Datenbanksicherungen"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DBBACKUP_AUTO_HELP"
msgid "Should Panopticon take daily, automatic backups of the important database tables?"
msgstr "Soll Panopticon tägliche, automatische Sicherungen der wichtigen Datenbanktabellen erstellen?"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DBBACKUP_COMPRESS"
msgid "Compress Database Backups"
msgstr "Datenbanksicherungen komprimieren"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DBBACKUP_COMPRESS_HELP"
msgid "Should Panopticon compress the database backups with Gzip?"
msgstr "Soll Panopticon die Datenbanksicherungen mit Gzip komprimieren?"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DBBACKUP_MAXFILES"
msgid "Maximum Number Of Database Backups"
msgstr "Maximale Anzahl von Datenbanksicherungen"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DBBACKUP_MAXFILES_HELP"
msgid "How many database backup files should Panopticon keep? Only applies to backups taken automatically, backups taken manually from the Database Backups page, and backups taken from the CLI to the default directory."
msgstr "Wie viele Datenbanksicherungsdateien soll Panopticon aufbewahren? Gilt nur für automatisch erstellte Sicherungen, manuell über die Seite „Datenbanksicherungen\" erstellte Sicherungen und über die CLI im Standardverzeichnis erstellte Sicherungen."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_DATABASE_WARNING_HEAD"
msgid "Do not change without adequate preparation"
msgstr "Nicht ohne angemessene Vorbereitung ändern"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_DATABASE_WARNING_BODY"
msgid "Always make a copy of your <code>config.php</code> file, e.g. by copying it as <code>config.bak.php</code> before changing anything here. Always prepare the new database, database user, and/or database tables before making changes here. Remember that Panopticon will <em>not</em> move or rename database tables for you. If things break, restore your old copy of your <code>config.php</code> file."
msgstr "Erstellen Sie immer eine Kopie Ihrer <code>config.php</code>-Datei, z.B. durch Kopieren als <code>config.bak.php</code>, bevor Sie hier etwas ändern. Bereiten Sie immer die neue Datenbank, den Datenbankbenutzer und/oder die Datenbanktabellen vor, bevor Sie hier Änderungen vornehmen. Denken Sie daran, dass Panopticon Datenbanktabellen <em>nicht</em> für Sie verschieben oder umbenennen wird. Falls etwas nicht funktioniert, stellen Sie Ihre alte Kopie der <code>config.php</code>-Datei wieder her."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DBDRIVER"
msgid "Database Driver"
msgstr "Datenbanktreiber"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DBHOST"
msgid "Database Hostname"
msgstr "Datenbank-Hostname"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DBUSER"
msgid "Database Username"
msgstr "Datenbankbenutzername"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DBPASS"
msgid "Database Password"
msgstr "Datenbankpasswort"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DBNAME"
msgid "Database Name"
msgstr "Datenbankname"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DBPREFIX"
msgid "Database Prefix"
msgstr "Datenbankpräfix"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DBCHARSET"
msgid "Connection Character Set"
msgstr "Verbindungszeichensatz"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DBCHARSET_HELP"
msgid "Best use the utf8mb4 option. The utf8 option will prevent you from using some characters, such as Emoji, some extended Chinese characters, etc."
msgstr "Am besten die Option utf8mb4 verwenden. Die Option utf8 verhindert die Verwendung bestimmter Zeichen, wie z.B. Emoji, einige erweiterte chinesische Zeichen usw."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DBENCRYPTION"
msgid "Database Encryption"
msgstr "Datenbankverschlüsselung"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DBENCRYPTION_HELP"
msgid "Only enable if your database driver requires authentication with an SSL/TLS certificate. Most users can and should leave this disabled."
msgstr "Nur aktivieren, wenn Ihr Datenbanktreiber eine Authentifizierung mit einem SSL/TLS-Zertifikat erfordert. Die meisten Benutzer können und sollten dies deaktiviert lassen."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DBSSLCA"
msgid "Path to SSL/TLS CA Certificate"
msgstr "Pfad zum SSL/TLS-CA-Zertifikat"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DBSSLKEY"
msgid "Path to SSL/TLS Key File"
msgstr "Pfad zur SSL/TLS-Schlüsseldatei"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DBSSLCERT"
msgid "Path to SSL/TLS Certificate File"
msgstr "Pfad zur SSL/TLS-Zertifikatsdatei"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_DBSSLVERIFYSERVERCERT"
msgid "Verify SSL/TLS Server Certificates"
msgstr "SSL/TLS-Serverzertifikate verifizieren"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_MAIL_ONLINE"
msgid "Mail Sending"
msgstr "E-Mail-Versand"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_IMMEDIATE_EMAIL"
msgid "Immediate Email Sending"
msgstr "Sofortiger E-Mail-Versand"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_IMMEDIATE_EMAIL_HELP"
msgid "Enable to sends emails right when they are generated. Disable to enqueue emails for batch sending at a later time. If you have dozens to hundreds of recipients for every email you should disable this option to prevent timeouts."
msgstr "Aktivieren, um E-Mails direkt bei ihrer Generierung zu versenden. Deaktivieren, um E-Mails für den späteren Stapelversand in eine Warteschlange einzureihen. Wenn Sie Dutzende bis Hunderte von Empfängern pro E-Mail haben, sollten Sie diese Option deaktivieren, um Zeitüberschreitungen zu vermeiden."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_MAIL_INLINE_IMAGES"
msgid "Inline Images in Email"
msgstr "Inline-Bilder in E-Mails"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_LOG_ATTACHMENT_GROUPS"
msgid "Attach Log File to These Groups"
msgstr "Protokolldatei an diese Gruppen anhängen"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_LOG_ATTACHMENT_GROUPS_HELP"
msgid "Select which user groups receive the task log file as an email attachment when a core or extension update fails. Leave empty to send the attachment to all notification recipients."
msgstr "Wählen Sie aus, welche Benutzergruppen die Aufgaben-Protokolldatei als E-Mail-Anhang erhalten, wenn eine Kern- oder Erweiterungs-Aktualisierung fehlschlägt. Leer lassen, um den Anhang an alle Benachrichtigungsempfänger zu senden."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_MAILER"
msgid "Mail Handler"
msgstr "E-Mail-Handler"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_MAILFROM"
msgid "Sender Address"
msgstr "Absenderadresse"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_FROMNAME"
msgid "Sender Name"
msgstr "Absendername"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_SMTPHOST"
msgid "SMTP Host"
msgstr "SMTP-Host"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_SMTPPORT"
msgid "SMTP Port"
msgstr "SMTP-Port"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_SMTPSECURE"
msgid "SMTP Security"
msgstr "SMTP-Sicherheit"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_SMTPAUTH"
msgid "SMTP Authentication"
msgstr "SMTP-Authentifizierung"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_SMTPUSER"
msgid "SMTP Username"
msgstr "SMTP-Benutzername"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_SMTPPASS"
msgid "SMTP Password"
msgstr "SMTP-Passwort"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_CHECKSUMS_BASE_URL"
msgid "Checksums source base URL"
msgstr "Basis-URL der Prüfsummenquelle"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_CHECKSUMS_BASE_URL_HELP"
msgid "Base URL Panopticon\'s connectors use to download the reference checksums for the Core File Integrity check. Leave empty to use the default <code>https://getpanopticon.com/checksums</code>. If you host your own mirror, it must serve the same layout: the connector appends <code>/joomla/&lt;version&gt;/sha256_squash.json.gz</code> or <code>/wordpress/&lt;version&gt;/sha256_squash.json.gz</code> to this base URL. Do not include a trailing slash or the CMS name."
msgstr "Basis-URL, die die Konnektoren von Panopticon zum Herunterladen der Referenzprüfsummen für die Kern-Dateiintegritätsprüfung verwenden. Leer lassen, um den Standard <code>https://getpanopticon.com/checksums</code> zu verwenden. Wenn Sie einen eigenen Spiegel betreiben, muss dieser das gleiche Layout bereitstellen: Der Konnektor hängt <code>/joomla/&lt;version&gt;/sha256_squash.json.gz</code> oder <code>/wordpress/&lt;version&gt;/sha256_squash.json.gz</code> an diese Basis-URL an. Keinen abschließenden Schrägstrich oder den CMS-Namen angeben."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_TASKS_COREUPDATE_INSTALL"
msgid "When An Update Is Found"
msgstr "Wenn eine Aktualisierung gefunden wird"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_TASKS_COREUPDATE_INSTALL_HELP"
msgid "Do nothing: no action is taken. Send email: An email is sent, nothing is installed. Patch: Only patch versions (e.g. 1.2.<strong>3</strong> to 1.2.<strong>4</strong>) are installed; an email is sent otherwise. Minor: Only patch and minor versions (e.g. 1.<strong>2</strong>.x to 1.<strong>3</strong>.x) are installed; an email is sent otherwise. Any version: installs all updates, even if the major version changes (e.g. <strong>1</strong>.x to <strong>2</strong>.x)."
msgstr "Nichts tun: Es wird keine Aktion durchgeführt. E-Mail senden: Eine E-Mail wird gesendet, es wird nichts installiert. Patch: Nur Patch-Versionen (z.B. 1.2.<strong>3</strong> auf 1.2.<strong>4</strong>) werden installiert; andernfalls wird eine E-Mail gesendet. Minor: Nur Patch- und Minor-Versionen (z.B. 1.<strong>2</strong>.x auf 1.<strong>3</strong>.x) werden installiert; andernfalls wird eine E-Mail gesendet. Beliebige Version: Installiert alle Aktualisierungen, auch wenn sich die Hauptversion ändert (z.B. <strong>1</strong>.x auf <strong>2</strong>.x)."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_TASKS_EXTUPDATE_INSTALL"
msgid "When An Extension Update Is Found"
msgstr "Wenn eine Erweiterungs-Aktualisierung gefunden wird"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_TASKS_EXTUPDATE_INSTALL_HELP"
msgid "This preference can be overridden for any individual extension below. You can also override this for any individual extension and site in each site\'s configuration page."
msgstr "Diese Einstellung kann für jede einzelne Erweiterung unten überschrieben werden. Sie können dies auch für jede einzelne Erweiterung und Website auf der Konfigurationsseite der jeweiligen Website überschreiben."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_SESSION_TOKEN_ALGORITHM"
msgid "Anti-CSRF Token Algorithm"
msgstr "Anti-CSRF-Token-Algorithmus"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_SESSION_TOKEN_ALGORITHM_HELP"
msgid "The hash algorithm for creating an anti-CSRF token. SHA-512 offers the best security, but may not work on some hosts because it\'s very long. MD5 offers the least security but is compatible with all hosts. Only change if you have problems when clicking action buttons in Panopticon."
msgstr "Der Hash-Algorithmus zur Erstellung eines Anti-CSRF-Tokens. SHA-512 bietet die beste Sicherheit, funktioniert jedoch möglicherweise auf einigen Hosts nicht, da er sehr lang ist. MD5 bietet die geringste Sicherheit, ist aber mit allen Hosts kompatibel. Nur ändern, wenn Sie Probleme beim Klicken auf Aktionsschaltflächen in Panopticon haben."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_LANGUAGE"
msgid "Default language"
msgstr "Standardsprache"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PROXY_ENABLED"
msgid "Use a Proxy Server for Outgoing Connections"
msgstr "Proxyserver für ausgehende Verbindungen verwenden"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PROXY_HOST"
msgid "Proxy hostname or IP Address"
msgstr "Proxy-Hostname oder IP-Adresse"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PROXY_PORT"
msgid "Proxy Port"
msgstr "Proxy-Port"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PROXY_USER"
msgid "Proxy Username (optional)"
msgstr "Proxy-Benutzername (optional)"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PROXY_PASS"
msgid "Proxy Password (optional)"
msgstr "Proxy-Passwort (optional)"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PROXY_NO"
msgid "Do Not Proxy These Domains"
msgstr "Diese Domains nicht über Proxy leiten"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PROXY_NO_HELP"
msgid "Enter a comma–separated list of full, or partial domain names which should not go through the proxy, e.g. <code>www.example.com, .mit.edu, .dev</code>."
msgstr "Geben Sie eine kommagetrennte Liste vollständiger oder teilweiser Domainnamen ein, die nicht über den Proxy geleitet werden sollen, z.B. <code>www.example.com, .mit.edu, .dev</code>."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_FINISHED_SETUP"
msgid "Is installing Panopticon finished?"
msgstr "Ist die Installation von Panopticon abgeschlossen?"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_BEHIND_LOAD_BALANCER"
msgid "Behind load balancer / reverse proxy"
msgstr "Hinter einem Load Balancer / Reverse Proxy"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_BEHIND_LOAD_BALANCER_HELP"
msgid "Only enable if your installation is behind a non-transparent proxy (e.g. Varnish), load balancer (e.g. HAProxy), CDN (e.g. CloudFlare), or security service (e.g. Sucuri) which conveys the real IP address of the visitor through the HTTP header <code>X-Forwarded-For</code>."
msgstr "Nur aktivieren, wenn Ihre Installation hinter einem nicht-transparenten Proxy (z.B. Varnish), Load Balancer (z.B. HAProxy), CDN (z.B. CloudFlare) oder Sicherheitsdienst (z.B. Sucuri) betrieben wird, der die echte IP-Adresse des Besuchers über den HTTP-Header <code>X-Forwarded-For</code> übermittelt."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_SESSION_ENCRYPT"
msgid "Encrypt session data"
msgstr "Sitzungsdaten verschlüsseln"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_SESSION_ENCRYPT_HELP"
msgid "Session data will be stored on disk encrypted with a secret key unique to your Panopticon installation."
msgstr "Sitzungsdaten werden verschlüsselt mit einem geheimen Schlüssel, der für Ihre Panopticon-Installation eindeutig ist, auf dem Datenträger gespeichert."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_SESSION_SAVE_LEVELS"
msgid "Session Path Levels"
msgstr "Sitzungspfad-Ebenen"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_SESSION_SAVE_LEVELS_HELP"
msgid "Session save data files will be saved this many folders deep. 0 means all files in a single folder. Best keep it 0 unless you have thousands of concurrent sessions. Only applies when Use Default PHP Session Save Path is disabled."
msgstr "Sitzungsdatendateien werden in dieser Anzahl von Ordnerebenen tief gespeichert. 0 bedeutet alle Dateien in einem einzigen Ordner. Am besten bei 0 belassen, sofern Sie keine Tausende gleichzeitiger Sitzungen haben. Gilt nur, wenn „Standard-PHP-Sitzungsspeicherpfad verwenden\" deaktiviert ist."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PASSKEY_LOGIN"
msgid "Login with passkey"
msgstr "Anmeldung mit Passkey"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PASSKEY_LOGIN_NO_MFA"
msgid "Bypass MFA when using a passkey"
msgstr "MFA bei Verwendung eines Passkeys umgehen"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PASSKEY_LOGIN_NO_PASSWORD"
msgid "Disable password login when login with passkey is set up"
msgstr "Passwortanmeldung deaktivieren, wenn Passkey-Anmeldung eingerichtet ist"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PASSKEY_LOGIN_NO_PASSWORD_OPT_USER"
msgid "Let the user decide"
msgstr "Benutzer entscheiden lassen"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PASSKEY_LOGIN_FORCE_GROUPS"
msgid "Force passkey login for these groups"
msgstr "Passkey-Anmeldung für diese Gruppen erzwingen"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PASSKEY_LOGIN_FORCE_SUPERUSER"
msgid "Force passkey login for Superusers"
msgstr "Passkey-Anmeldung für Superbenutzer erzwingen"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PASSKEY_LOGIN_FORCE_ADMIN"
msgid "Force passkey login for Administrators"
msgstr "Passkey-Anmeldung für Administratoren erzwingen"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PWRESET"
msgid "Allow self-service password reset"
msgstr "Self-Service-Passwortzurücksetzung erlauben"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PWRESET_MINTIME"
msgid "Minimum time between password reset requests (seconds)"
msgstr "Mindestzeit zwischen Passwortzurücksetzungsanfragen (Sekunden)"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PWRESET_MAXFAILS"
msgid "Maximum failed password reset attempts"
msgstr "Maximale fehlgeschlagene Passwortzurücksetzungsversuche"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PWRESET_MFA"
msgid "Password reset removes MFA"
msgstr "Passwortzurücksetzung entfernt MFA"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PWRESET_COMMON_SECURITY_NOTE"
msgid "<em>Caution</em>: Enabling this option will reduce the security of your installation."
msgstr "<em>Achtung</em>: Die Aktivierung dieser Option verringert die Sicherheit Ihrer Installation."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PWRESET_PASSKEYS"
msgid "Password reset removes passkeys"
msgstr "Passwortzurücksetzung entfernt Passkeys"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PWRESET_SUPERUSER"
msgid "Password reset allowed for Superusers"
msgstr "Passwortzurücksetzung für Superbenutzer erlaubt"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PWRESET_ADMIN"
msgid "Password reset allowed for Administrators"
msgstr "Passwortzurücksetzung für Administratoren erlaubt"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PWRESET_GROUPS"
msgid "Password reset allowed for these groups"
msgstr "Passwortzurücksetzung für diese Gruppen erlaubt"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_PWRESET_GROUPS_HELP"
msgid "Leaving empty will allow users in any user group to reset their password. Superuser and administrator restrictions take precedence over this option."
msgstr "Wenn leer gelassen, können Benutzer in jeder Benutzergruppe ihr Passwort zurücksetzen. Einschränkungen für Superbenutzer und Administratoren haben Vorrang vor dieser Option."

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_USER_REGISTRATION"
msgid "User registration"
msgstr "Benutzerregistrierung"

#, phpformat
msgctxt "PANOPTICON_SYSCONFIG_LBL_FIELD_USER_REGISTRATION_HELP"
msgid "Controls whether new users can create their own accounts. In \'Admin approval\' mode, an administrator must approve new accounts. In \'Self-approval\' mode, users activate their account via an email link."
msgstr "Steuert, ob neue Benutzer eigene Konten erstellen können. Im Modus „Administrator-Genehmigung\" muss ein Administrator neue Konten genehmigen. Im Modus „Selbst-Genehmigung\" aktivieren Benutzer ihr Konto über einen E-Mail-Link."

#, phpformat
