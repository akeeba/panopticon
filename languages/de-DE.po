msgstr "Die Planung der Erweiterungsaktualisierung ist fehlgeschlagen."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_EXTENSION_UPDATE_SCHEDULE_ERROR_CLEARED"
msgid "The scheduling error has been cleared."
msgstr "Der Planungsfehler wurde behoben."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_EXTENSION_UPDATE_SCHEDULE_ERROR_NOT_CLEARED"
