msgstr "Der Planungsfehler konnte nicht behoben werden: %s"

#, phpformat
msgctxt "PANOPTICON_SITE_BTN_CMSUPDATE_RELOAD"
msgid "Reload Update information"
msgstr "Aktualisierungsinformationen neu laden"

#, phpformat
msgctxt "PANOPTICON_SITE_BTN_CMSUPDATE_RELOAD_SR"
msgid "Reload Update information for site “%s”"
msgstr "Aktualisierungsinformationen für Website „%s\" neu laden"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SCHEDULE_OK"
msgid "Scheduled the Joomla core update."
msgstr "Die Joomla-Kernaktualisierung wurde geplant."

#, phpformat
msgctxt "PANOPTICON_SITE_ERR_JUPDATE_SCHEDULE_FAILED"
msgid "Scheduling the Joomla core update has failed."
msgstr "Die Planung der Joomla-Kernaktualisierung ist fehlgeschlagen."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SCHEDULE_ERROR_CLEARED"
msgid "The scheduling error has been cleared."
msgstr "Der Planungsfehler wurde behoben."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SCHEDULE_ERROR_NOT_CLEARED"
msgid "The scheduling error could not be cleared: %s"
msgstr "Der Planungsfehler konnte nicht behoben werden: %s"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_HEAD"
msgid "Joomla!&reg; Update"
msgstr "Joomla!&reg;-Aktualisierung"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_NO_VERSION_HEAD"
msgid "Version information missing"
msgstr "Versionsinformationen fehlen"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_NO_VERSION_BODY"
msgid "Your site has not reported the version of Joomla!&reg; it is running on."
msgstr "Ihre Website hat die Version von Joomla!&reg;, die sie ausführt, nicht gemeldet."

#, phpformat
msgctxt "PANOPTICON_SITE_BTN_JUPDATE_RELOAD"
msgid "Reload Joomla!&reg; Update information"
msgstr "Joomla!&reg;-Aktualisierungsinformationen neu laden"

#, phpformat
msgctxt "PANOPTICON_SITE_BTN_JUPDATE_RELOAD_SR"
msgid "Reload Joomla!&reg; Update information for site “%s”"
msgstr "Joomla!&reg;-Aktualisierungsinformationen für Website „%s\" neu laden"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_LAST_CHECKED"
msgid "Last checked:"
msgstr "Zuletzt geprüft:"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_ERR_JOOMLA_FILES_EXT_MISSING"
msgid "The Joomla! extension record is missing from your site. Joomla! cannot detect whether updates to itself are available."
msgstr "Der Joomla!-Erweiterungseintrag fehlt auf Ihrer Website. Joomla! kann nicht erkennen, ob Aktualisierungen für sich selbst verfügbar sind."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SEEK_HELP_JFORUM"
msgid "Try asking for help on the <a href=\"https://forum.joomla.org\" target=\"_blank\">Joomla! Forum</a>."
msgstr "Versuchen Sie, im <a href=\"https://forum.joomla.org\" target=\"_blank\">Joomla!-Forum</a> Hilfe zu suchen."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_ALT_FIX"
msgid "Alternatively, try clicking the button below."
msgstr "Alternativ können Sie auf die Schaltfläche unten klicken."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_ERR_UPDATESITE_MISSING"
msgid "The Joomla! Update Site record is missing from your site. Joomla! cannot detect whether updates to itself are available."
msgstr "Der Joomla!-Aktualisierungswebsite-Datensatz fehlt auf Ihrer Website. Joomla! kann nicht erkennen, ob Aktualisierungen für sich selbst verfügbar sind."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_UPDATESITE_FIX_J4"
msgid "Go to your site\'s administrator backend, System, Update, Update Sites, and click on the Rebuild button."
msgstr "Gehen Sie in das Administrator-Backend Ihrer Website, System, Aktualisierung, Aktualisierungswebsites, und klicken Sie auf die Schaltfläche Neu erstellen."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_UPDATESITE_FIX_J3"
msgid "Go to your site\'s administrator backend, Extensions, Manage, Update Sites, and click on the Rebuild button."
msgstr "Gehen Sie in das Administrator-Backend Ihrer Website, Erweiterungen, Verwalten, Aktualisierungswebsites, und klicken Sie auf die Schaltfläche Neu erstellen."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_COREUPDATESITEFIX_BTN"
msgid "Attempt an automatic fix"
msgstr "Automatische Reparatur versuchen"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_AVAILABLE_UPDATE"
msgid "Joomla! %s is available"
msgstr "Joomla! %s ist verfügbar"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_CURRENT_VERSION"
msgid "Your site is currently using Joomla! %s."
msgstr "Ihre Website verwendet derzeit Joomla! %s."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_IS_PATCH_RELEASE"
msgid "This is a patch (point) update which is almost always safe."
msgstr "Dies ist ein Patch-Update (Punkt-Release), das fast immer sicher ist."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_IS_MINOR_RELEASE"
msgid "This is a minor (version family) update which may affect your template overrides, templates, and some third party extensions."
msgstr "Dies ist ein Minor-Update (Versionsfamilie), das sich auf Ihre Template-Überschreibungen, Templates und einige Drittanbietererweiterungen auswirken kann."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_MINOR_RELEASE_ADMONISHMENT"
msgid "It is a good idea to take a backup of your site, and test this update on a copy of your site first."
msgstr "Es empfiehlt sich, eine Sicherung Ihrer Website zu erstellen und dieses Update zunächst auf einer Kopie Ihrer Website zu testen."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_IS_MAJOR_RELEASE"
msgid "This is a major version update which will most likely affect your template overrides, templates, and possibly some third party extensions."
msgstr "Dies ist ein Major-Update, das sich höchstwahrscheinlich auf Ihre Template-Überschreibungen, Templates und möglicherweise einige Drittanbietererweiterungen auswirken wird."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_MAJOR_RELEASE_ADMONISHMENT"
msgid "It is very strongly recommended that you take a backup of your site, and test this update on a copy of your site first."
msgstr "Es wird dringend empfohlen, eine Sicherung Ihrer Website zu erstellen und dieses Update zunächst auf einer Kopie Ihrer Website zu testen."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_UP_TO_DATE"
msgid "Joomla! %s is up-to-date"
msgstr "Joomla! %s ist aktuell"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_EOL"
msgid "Joomla! %s is unsupported"
msgstr "Joomla! %s wird nicht mehr unterstützt"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_EOL_MAJOR"
msgid "The Joomla! %s series is End-of-Life"
msgstr "Die Joomla! %s-Reihe hat das End-of-Life erreicht"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_EOL_MINOR"
msgid "The Joomla! %s version family is End-of-Life"
msgstr "Die Joomla! %s-Versionsfamilie hat das End-of-Life erreicht"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_EOL_DATE"
msgid "Joomla! %s became End of Life on %s"
msgstr "Joomla! %s hat das End-of-Life am %s erreicht"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SECURITY_DATE"
msgid "Joomla! %s receives security updates only since %s and will become End-of-Life on %s."
msgstr "Joomla! %s erhält seit %s nur noch Sicherheitsaktualisierungen und wird am %s das End-of-Life erreichen."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_STABLE_DATE"
msgid "Joomla! %s receives security updates and bug fixes until %s. It will become End-of-Life and superseded by a new minor version on %s."
msgstr "Joomla! %s erhält Sicherheitsaktualisierungen und Fehlerbehebungen bis %s. Es wird am %s das End-of-Life erreichen und durch eine neue Minor-Version abgelöst."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_LAST_STABLE_DATE"
msgid "Joomla! %s receives security updates and bug fixes until %s. It will become End-of-Life on %s. It is superseded by a new major version."
msgstr "Joomla! %s erhält Sicherheitsaktualisierungen und Fehlerbehebungen bis %s. Es wird am %s das End-of-Life erreichen. Es wird durch eine neue Major-Version abgelöst."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_CANNOT_INSTALL"
msgid "The newer Joomla! version %s is available but cannot be installed because of your site preferences."
msgstr "Die neuere Joomla!-Version %s ist verfügbar, kann aber aufgrund Ihrer Website-Einstellungen nicht installiert werden."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_FIX_TO_INSTALL_NEXT_VERSION"
msgid "Go to your site\'s administrator backend, System, Update, Joomla, click on Options, and change the update channel to Joomla Next. Please check Joomla\'s requirements, especially the database version and PHP version requirements. Note that your site is currently using PHP %s."
msgstr "Gehen Sie in das Administrator-Backend Ihrer Website, System, Aktualisierung, Joomla, klicken Sie auf Optionen und ändern Sie den Aktualisierungskanal auf Joomla Next. Bitte prüfen Sie die Anforderungen von Joomla, insbesondere die Anforderungen an die Datenbankversion und die PHP-Version. Beachten Sie, dass Ihre Website derzeit PHP %s verwendet."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_NOT_SCHEDULED"
msgid "The update is <span class=\"text-danger fw-semibold\">not scheduled</span> to run automatically. You can run the update manually on your site, or click on the button below."
msgstr "Die Aktualisierung ist <span class=\"text-danger fw-semibold\">nicht geplant</span>, um automatisch ausgeführt zu werden. Sie können die Aktualisierung manuell auf Ihrer Website durchführen oder auf die Schaltfläche unten klicken."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SCHEDULED"
msgid "The update is <span class=\"fw-semibold text-success\">scheduled</span> to run automatically after %s."
msgstr "Die Aktualisierung ist <span class=\"fw-semibold text-success\">geplant</span>, um automatisch nach %s ausgeführt zu werden."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SCHEDULED_ASAP"
msgid "The update is <span class=\"fw-semibold text-success\">scheduled</span> to run automatically as soon as possible."
msgstr "Die Aktualisierung ist <span class=\"fw-semibold text-success\">geplant</span>, um so bald wie möglich automatisch ausgeführt zu werden."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_RUNNING"
msgid "The update is <span class=\"fw-semibold text-success\">currently taking place</span>"
msgstr "Die Aktualisierung <span class=\"fw-semibold text-success\">wird gerade durchgeführt</span>"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_ERRORED"
msgid "The update was scheduled to run automatically but ran into an error:"
msgstr "Die Aktualisierung war zur automatischen Ausführung geplant, ist aber auf einen Fehler gestoßen:"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_THE_ERROR_REPORTED_WAS"
msgid "The error reported was:"
msgstr "Der gemeldete Fehler war:"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_ERROR_TRACE"
msgid "Error trace (for debugging):"
msgstr "Fehler-Trace (zur Fehlersuche):"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SCHEDULE_UPDATE"
msgid "Schedule Automatic Update to Joomla! %s"
msgstr "Automatische Aktualisierung auf Joomla! %s planen"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_UNSCHEDULE_UPDATE"
msgid "Cancel Automatic Update"
msgstr "Automatische Aktualisierung abbrechen"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_UNSCHEDULE_ERR_NOT_SCHEDULED"
msgid "There is no scheduled update."
msgstr "Es ist keine Aktualisierung geplant."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_UNSCHEDULE_ERR_RUNNING"
msgid "The scheduled update is already running."
msgstr "Die geplante Aktualisierung wird bereits ausgeführt."

#, phpformat
msgctxt "PANOPTICON_SITE_ERR_JUPDATE_UNSCHEDULE_FAILED"
msgid "Could not cancel the Joomla core update."
msgstr "Die Joomla-Kernaktualisierung konnte nicht abgebrochen werden."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SCHEDULE_CLEAR_ERROR"
msgid "Clear Error"
msgstr "Fehler löschen"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_REFRESH_CORE_PROMPT"
msgid "Site woes? Try refreshing the Joomla! core files."
msgstr "Probleme mit der Website? Versuchen Sie, die Joomla!-Kerndateien zu aktualisieren."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_BTN_REFRESH_CORE_PROMPT"
msgid "Schedule Joomla! %s Files Refresh"
msgstr "Aktualisierung der Joomla! %s-Dateien planen"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_REFRESH_CORE_NOTE"
msgid "Refreshing the Joomla! core files is <em>always safe</em>. Your site contents will not be changed. Use this to undo changes to the Joomla! core files (“core hacks”), or if you suspect that your site does not work correctly because of a failed update."
msgstr "Die Aktualisierung der Joomla!-Kerndateien ist <em>immer sicher</em>. Der Inhalt Ihrer Website wird nicht verändert. Verwenden Sie diese Funktion, um Änderungen an den Joomla!-Kerndateien rückgängig zu machen („Core-Hacks\"), oder wenn Sie vermuten, dass Ihre Website aufgrund einer fehlgeschlagenen Aktualisierung nicht korrekt funktioniert."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_REFRESH_SCHEDULED"
msgid "The core files refresh is <span class=\"fw-semibold text-success\">scheduled</span> to run automatically after %s."
msgstr "Die Aktualisierung der Kerndateien ist <span class=\"fw-semibold text-success\">geplant</span>, um automatisch nach %s ausgeführt zu werden."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_REFRESH_SCHEDULED_ASAP"
msgid "The core files refresh is <span class=\"fw-semibold text-success\">scheduled</span> to run automatically as soon as possible."
msgstr "Die Aktualisierung der Kerndateien ist <span class=\"fw-semibold text-success\">geplant</span>, um so bald wie möglich automatisch ausgeführt zu werden."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_REFRESH_RUNNING"
msgid "The core files refresh is <span class=\"fw-semibold text-success\">currently taking place</span>"
msgstr "Die Aktualisierung der Kerndateien <span class=\"fw-semibold text-success\">wird gerade durchgeführt</span>"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_REFRESH_ERRORED"
