#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_ERR_JOOMLA_FILES_EXT_MISSING"
msgid "The Joomla! extension record is missing from your site. Joomla! cannot detect whether updates to itself are available."
msgstr "Запись расширения Joomla! отсутствует на вашем сайте. Joomla! не может определить, доступны ли обновления."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SEEK_HELP_JFORUM"
msgid "Try asking for help on the <a href=\"https://forum.joomla.org\" target=\"_blank\">Joomla! Forum</a>."
msgstr "Попробуйте обратиться за помощью на <a href=\\\"https://forum.joomla.org\\\" target=\\\"_blank\\\">форум Joomla! </a>."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_ALT_FIX"
msgid "Alternatively, try clicking the button below."
msgstr "Либо нажмите кнопку ниже."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_ERR_UPDATESITE_MISSING"
msgid "The Joomla! Update Site record is missing from your site. Joomla! cannot detect whether updates to itself are available."
msgstr "Запись сайта обновления Joomla! отсутствует на вашем сайте. Joomla! не может определить, доступны ли обновления."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_UPDATESITE_FIX_J4"
msgid "Go to your site\'s administrator backend, System, Update, Update Sites, and click on the Rebuild button."
msgstr "Перейдите в административную часть сайта: Система → Обновление → Сайты обновления, нажмите кнопку «Восстановить»."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_UPDATESITE_FIX_J3"
msgid "Go to your site\'s administrator backend, Extensions, Manage, Update Sites, and click on the Rebuild button."
msgstr "Перейдите в административную часть сайта: Расширения → Управление → Сайты обновления, нажмите кнопку «Восстановить»."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_COREUPDATESITEFIX_BTN"
msgid "Attempt an automatic fix"
msgstr "Попытаться исправить автоматически"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_AVAILABLE_UPDATE"
msgid "Joomla! %s is available"
msgstr "Доступна Joomla! %s"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_CURRENT_VERSION"
msgid "Your site is currently using Joomla! %s."
msgstr "В данный момент ваш сайт использует Joomla! %s."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_IS_PATCH_RELEASE"
msgid "This is a patch (point) update which is almost always safe."
msgstr "Это патч-обновление (точечное), которое практически всегда безопасно."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_IS_MINOR_RELEASE"
msgid "This is a minor (version family) update which may affect your template overrides, templates, and some third party extensions."
msgstr "Это минорное обновление (семейство версий), которое может повлиять на переопределения шаблонов, шаблоны и некоторые сторонние расширения."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_MINOR_RELEASE_ADMONISHMENT"
msgid "It is a good idea to take a backup of your site, and test this update on a copy of your site first."
msgstr "Рекомендуется создать резервную копию сайта и сначала протестировать это обновление на копии сайта."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_IS_MAJOR_RELEASE"
msgid "This is a major version update which will most likely affect your template overrides, templates, and possibly some third party extensions."
msgstr "Это мажорное обновление версии, которое, скорее всего, повлияет на переопределения шаблонов, шаблоны и, возможно, некоторые сторонние расширения."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_MAJOR_RELEASE_ADMONISHMENT"
msgid "It is very strongly recommended that you take a backup of your site, and test this update on a copy of your site first."
msgstr "Настоятельно рекомендуется создать резервную копию сайта и сначала протестировать это обновление на копии сайта."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_UP_TO_DATE"
msgid "Joomla! %s is up-to-date"
msgstr "Joomla! %s обновлена"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_EOL"
msgid "Joomla! %s is unsupported"
msgstr "Joomla! %s не поддерживается"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_EOL_MAJOR"
msgid "The Joomla! %s series is End-of-Life"
msgstr "Серия Joomla! %s завершила жизненный цикл"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_EOL_MINOR"
msgid "The Joomla! %s version family is End-of-Life"
msgstr "Семейство версий Joomla! %s завершило жизненный цикл"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_EOL_DATE"
msgid "Joomla! %s became End of Life on %s"
msgstr "Joomla! %s завершила жизненный цикл %s"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SECURITY_DATE"
msgid "Joomla! %s receives security updates only since %s and will become End-of-Life on %s."
msgstr "Joomla! %s получает только обновления безопасности с %s и завершит жизненный цикл %s."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_STABLE_DATE"
msgid "Joomla! %s receives security updates and bug fixes until %s. It will become End-of-Life and superseded by a new minor version on %s."
msgstr "Joomla! %s получает обновления безопасности и исправления ошибок до %s. Она завершит жизненный цикл и будет заменена новой минорной версией %s."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_LAST_STABLE_DATE"
msgid "Joomla! %s receives security updates and bug fixes until %s. It will become End-of-Life on %s. It is superseded by a new major version."
msgstr "Joomla! %s получает обновления безопасности и исправления ошибок до %s. Она завершит жизненный цикл %s. Её заменяет новая мажорная версия."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_CANNOT_INSTALL"
msgid "The newer Joomla! version %s is available but cannot be installed because of your site preferences."
msgstr "Новая версия Joomla! %s доступна, но не может быть установлена из-за настроек вашего сайта."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_FIX_TO_INSTALL_NEXT_VERSION"
msgid "Go to your site\'s administrator backend, System, Update, Joomla, click on Options, and change the update channel to Joomla Next. Please check Joomla\'s requirements, especially the database version and PHP version requirements. Note that your site is currently using PHP %s."
msgstr "Перейдите в административную часть: Система → Обновление → Joomla, нажмите «Параметры» и измените канал обновления на «Joomla Next». Проверьте требования Joomla, особенно версии базы данных и PHP. Сайт использует PHP %s."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_NOT_SCHEDULED"
msgid "The update is <span class=\"text-danger fw-semibold\">not scheduled</span> to run automatically. You can run the update manually on your site, or click on the button below."
msgstr "Обновление <span class="text-danger fw-semibold">не запланировано</span> для автоматического выполнения. Вы можете запустить обновление вручную на своём сайте или нажать кнопку ниже."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SCHEDULED"
msgid "The update is <span class=\"fw-semibold text-success\">scheduled</span> to run automatically after %s."
msgstr "Обновление <span class="fw-semibold text-success">запланировано</span> для автоматического выполнения после %s."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_SCHEDULED_ASAP"
msgid "The update is <span class=\"fw-semibold text-success\">scheduled</span> to run automatically as soon as possible."
msgstr "Обновление <span class="fw-semibold text-success">запланировано</span> для автоматического выполнения как можно скорее."

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_RUNNING"
msgid "The update is <span class=\"fw-semibold text-success\">currently taking place</span>"
msgstr "Обновление <span class="fw-semibold text-success">выполняется в настоящее время</span>"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_ERRORED"
msgid "The update was scheduled to run automatically but ran into an error:"
msgstr "Обновление было запланировано для автоматического выполнения, но столкнулось с ошибкой:"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_THE_ERROR_REPORTED_WAS"
msgid "The error reported was:"
msgstr "Сообщение об ошибке:"

#, phpformat
msgctxt "PANOPTICON_SITE_LBL_JUPDATE_ERROR_TRACE"
