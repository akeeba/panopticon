#, phpformat
msgctxt "PANOPTICON_SITES_LBL_CONNECTOR_HEAD"
msgid "Panopticon Connector"
msgstr "Panopticon Connector"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_INSTRUCTIONS_HEAD"
msgid "Connecting your site"
msgstr "Подключение вашего сайта"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_INSTRUCTIONS_BODY"
msgid "First, install the Akeeba Panopticon Connector to your site. Then, retrieve the connection information and paste it below. Here is how to do it depending on your CMS:"
msgstr "Сначала установите Akeeba Panopticon Connector на ваш сайт. Затем получите информацию о подключении и вставьте её ниже. Вот как это сделать в зависимости от вашей CMS:"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_INSTRUCTIONS_JOOMLA4ORLATER"
msgid "<strong>Joomla! 4 or later</strong>: Go to your site\'s backend and click on Components, Akeeba Panopticon Connector to find your connection information."
msgstr "<strong>Joomla! 4 и новее</strong>: перейдите в административную часть сайта и нажмите «Компоненты → Akeeba Panopticon Connector», чтобы найти информацию о подключении."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_INSTRUCTIONS_JOOMLA3"
msgid "<strong>Joomla! 3</strong>: Go to your site\'s backend and click on Extensions, Plugins. Click on System - Panopticon Connector for Joomla 3."
msgstr "<strong>Joomla! 3</strong>: перейдите в административную часть сайта и нажмите «Расширения → Плагины». Найдите «Система — Panopticon Connector for Joomla 3»."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_INSTRUCTIONS_WORDPRESS"
msgid "<strong>WordPress</strong>: Go to your site\'s wp-admin and click on Tools, Panopticon."
msgstr "<strong>WordPress</strong>: перейдите в wp-admin вашего сайта и нажмите «Инструменты → Panopticon»."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_INSTRUCTIONS_DOWNLOAD_HERE"
msgid "You can download the connector installation package from the following locations."
msgstr "Пакет установки коннектора можно загрузить по следующим ссылкам."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_INSTRUCTIONS_DOWNLOAD_J4_LATER"
msgid "Joomla 4.x and later"
msgstr "Joomla 4.x и новее"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_INSTRUCTIONS_DOWNLOAD_J3"
msgid "Joomla 3.9 and 3.10"
msgstr "Joomla 3.9 и 3.10"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_INSTRUCTIONS_DOWNLOAD_WP"
msgid "WordPress"
msgstr "WordPress"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_ADMIN_PASSWORD_HEAD"
msgid "Administrator Directory Password Protection"
msgstr "Защита каталога администратора паролем"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_ADMIN_PASSWORD_INFO_1"
msgid "If your site\'s <code>administrator</code> directory is password–protected, please enter the username and password used for this password protection. Otherwise, Joomla!&reg; updates will fail with an error mentioning “401 Unauthorized”."
msgstr "Если директория <code>administrator</code> вашего сайта защищена паролем, укажите имя пользователя и пароль для этой защиты. В противном случае обновления Joomla!&reg; будут завершаться ошибкой «401 Unauthorized»."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_ADMIN_PASSWORD_INFO_2"
msgid "Please note that this is <em>NOT</em> asking for your Joomla! username and password."
msgstr "Обратите внимание: здесь запрашивается <em>НЕ</em> имя пользователя и пароль Joomla!."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_ADMIN_PASSWORD_NEEDED_HEAD"
msgid "Do I need to do this?"
msgstr "Нужно ли это делать?"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_ADMIN_PASSWORD_NEEDED_INFO_1"
msgid "This is only necessary if you have password–protected your <code>administrator</code> directory with one of the following methods:"
msgstr "Это необходимо только в том случае, если вы защитили каталог <code>administrator</code> паролем одним из следующих способов:"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_ADMIN_PASSWORD_NEEDED_INFO_2"
msgid "You used a third party extension, e.g. Admin Tools\' “Password-protect Administrator” feature."
msgstr "Вы используете стороннее расширение, например функцию «Password-protect Administrator» в Admin Tools."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_ADMIN_PASSWORD_NEEDED_INFO_3"
msgid "You used your hosting control panel\'s directory password protection feature, if one is available."
msgstr "С помощью функции защиты каталога паролем в панели управления хостингом (если таковая имеется)."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_ADMIN_PASSWORD_NEEDED_INFO_4"
msgid "You have manually set this up, e.g. using a <code>.htaccess</code> and <code>.htpasswd</code> file with the Apache web server."
msgstr "Вручную, например с помощью файлов <code>.htaccess</code> и <code>.htpasswd</code> на веб-сервере Apache."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_ADMIN_PASSWORD_NEEDED_INFO_5"
msgid "If you have done nothing of these, or have no idea what these even mean, leave the following fields blank."
msgstr "Если вы ничего из этого не делали или не понимаете, о чём речь, оставьте следующие поля пустыми."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_NAUGHTY_UPDATES"
msgid "Extension With Problematic Updates"
msgstr "Расширение с проблемными обновлениями"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_ADMIN_USERNAME"
msgid "Administrator Directory Username"
msgstr "Имя пользователя для каталога администратора"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_ADMIN_PASSWORD"
msgid "Administrator Directory Password"
msgstr "Пароль для каталога администратора"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_CORE_UPDATE_INSTALL"
msgid "What To Do On CMS Update Found"
msgstr "Действие при обнаружении обновления CMS"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_CORE_UPDATE_WHEN"
msgid "When Should Updates Be Installed"
msgstr "Когда следует устанавливать обновления"

#, phpformat
msgctxt "PANOPTICON_SITES_OPT_CONFIG_CORE_UPDATE_WHEN_IMMEDIATELY"
msgid "Immediately"
msgstr "Немедленно"

#, phpformat
msgctxt "PANOPTICON_SITES_OPT_CONFIG_CORE_UPDATE_WHEN_TIME"
msgid "Time of Day"
msgstr "В определённое время суток"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_CORE_UPDATE_TIME"
msgid "Time Of The Day to Install Updates On (Hour:Minute)"
msgstr "Время суток для установки обновлений (Час:Минута)"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_CORE_UPDATE_TIME_HOUR"
msgid "Hour"
msgstr "Час"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_CORE_UPDATE_TIME_MINUTES"
msgid "Minutes"
msgstr "Минуты"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_CORE_UPDATE_TIME_HELP"
msgid "The time expressed in the %s timezone. If updates are found <em>after</em> this time of the day the update installation will take place on the next calendar day. Avoid using the Daylight Savings Time changeover time of the day (usually: between 2am and 4am); otherwise, update scheduling will act in what you perceive to be a “weird” or “wrong” way if an update is found on the day of the Daylight Savings Time changeover."
msgstr "Время задаётся в часовом поясе %s. Если обновления обнаружены <em>после</em> указанного времени суток, установка обновления будет перенесена на следующий календарный день. Избегайте использования времени перехода на летнее/зимнее время (обычно: с 2:00 до 4:00); в противном случае планировщик обновлений может вести себя «странно» или «неправильно», если обновление обнаружено в день перехода на летнее/зимнее время."

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_CORE_UPDATE_EMAIL_CC"
msgid "CC the Following Email Addresses"
msgstr "Копия на следующие адреса электронной почты"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_CORE_UPDATE_EMAIL_CC_HELP"
msgid "A comma-separated list of additional email addresses to Carbon Copy when sending emails about the site update. Addresses can be in the format <code>foo@example.com</code> (only email address) or <code>Mr. Foo Bar &lt;foo@example.com&gt;</code> (name and address)."
msgstr "Список дополнительных адресов электронной почты для копии (CC) при отправке писем об обновлении сайта, разделённых запятыми. Адреса могут быть в формате <code>foo@example.com</code> (только адрес) или <code>Mr. Foo Bar &lt;foo@example.com&gt;</code> (имя и адрес)."

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_CORE_UPDATE_EMAIL_ERROR"
msgid "Send Email after Update Failure"
msgstr "Отправить электронное письмо после сбоя обновления"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_CORE_UPDATE_EMAIL_AFTER"
msgid "Send Email after Update Success"
msgstr "Отправить электронное письмо после успешного обновления"

#, phpformat
msgctxt "PANOPTICON_LBL_SITE_SAVED"
msgid "The Site definition has been saved."
msgstr "Определение сайта было сохранено."

#, phpformat
msgctxt "PANOPTICON_LBL_SITE_COPIED"
msgid "The selected Site definition(s) have been copied."
msgstr "Выбранные определения сайтов скопированы."

#, phpformat
msgctxt "PANOPTICON_LBL_SITE_DELETED"
msgid "The selected Site definition(s) have been deleted."
msgstr "Выбранные определения сайтов удалены."

#, phpformat
msgctxt "PANOPTICON_LBL_FIELD_ENABLED_HELP"
msgid "Controls whether the site is shown in the Overview page, whether its information is automatically refreshed, and whether it participates in any kind of scheduled (automatic) actions such as updates."
msgstr "Управляет отображением сайта на странице обзора, автоматическим обновлением его информации и участием в любых запланированных (автоматических) действиях, таких как обновления."

#, phpformat
msgctxt "PANOPTICON_LBL_SITE_OWNERSHIP"
msgid "Site Ownership"
msgstr "Владелец сайта"

#, phpformat
msgctxt "PANOPTICON_LBL_SITE_OWNERSHIP_NON_SUPER"
msgid "If you need the site ownership information modified please contact a user with administration or superuser privileges."
msgstr "Для изменения информации о владельце сайта обратитесь к пользователю с правами администратора или суперпользователя."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_GROUPS_INFO"
msgid "This section is only relevant to multi–user installations with different access per site; please consult the documentation for more information. If you are managing a single–user installation, or if all users have equal access to all sites, you can ignore it."
msgstr "Этот раздел актуален только для многопользовательских установок с разным доступом к сайтам; подробности см. в документации. Если вы управляете однопользовательской установкой или все пользователи имеют одинаковый доступ ко всем сайтам, его можно проигнорировать."

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_GROUPS"
msgid "Groups"
msgstr "Группы"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_GROUPS_PLACEHOLDER"
msgid "Select one or more groups (optional)"
msgstr "Выберите одну или несколько групп (необязательно)"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_DLKEY_EDIT_TITLE"
msgid "Edit a Download Key"
msgstr "Редактирование ключа загрузки"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_DLKEY"
msgid "Download Key"
msgstr "Ключ загрузки"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_CONNECTION_DOCTOR_TITLE"
msgid "Connection Doctor"
msgstr "Соединение"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_CONNECTION_DOCTOR_OKAY"
msgid "All good!"
msgstr "Всё в порядке!"

#, phpformat
msgctxt "PANOPTICON_SITES_LBL_CONNECTION_DOCTOR_OKAY_MORE"
msgid "The connection to your site was tested, and found to be working fine."
msgstr "Подключение к вашему сайту протестировано и работает нормально."

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_SSL_WARNING"
msgid "SSL/TLS Expiration First Warning"
msgstr "Первое предупреждение об истечении срока SSL/TLS"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_SSL_WARNING_HELP"
msgid "Panopticon will warn you that your site\'s SSL/TLS certificate is expiring this many days before it expires. 0 disables the warning."
msgstr "Panopticon предупредит об истечении срока действия сертификата SSL/TLS за указанное количество дней. 0 отключает предупреждение."

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_DOMAIN_WARNING"
msgid "Domain Expiration First Warning"
msgstr "Первое предупреждение об истечении срока регистрации домена"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_DOMAIN_WARNING_HELP"
msgid "Panopticon will warn you that your site\'s domain name is expiring this many days before it expires. 0 disables the warning."
msgstr "Panopticon предупредит об истечении срока регистрации домена за указанное количество дней. 0 отключает предупреждение."

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_BACKUP_MAX_AGE"
msgid "Maximum Backup Age"
msgstr "Максимальный возраст резервной копии"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_BACKUP_MAX_AGE_HELP"
msgid "Successful backups will be considered “too old” after this many hours. Use 0 to disable this feature."
msgstr "Успешные резервные копии будут считаться «устаревшими» по истечении указанного количества часов. Используйте 0, чтобы отключить эту функцию."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSL_TLS_CERT_INFO"
msgid "SSL/TLS (HTTPS) Certificate Information"
msgstr "Информация о сертификате SSL/TLS (HTTPS)"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_TABLE_CAPTION"
msgid "Table of SSL/TLS certificate information"
msgstr "Таблица информации о сертификате SSL/TLS"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_SERIAL"
msgid "Serial"
msgstr "Серийный номер"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_SIG_TYPE"
msgid "Signature Type"
msgstr "Тип подписи"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_FROM"
msgid "Valid From"
msgstr "Действителен с"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_TO"
msgid "Valid To"
msgstr "Действителен до"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_CN"
msgid "Common Names (domains)"
msgstr "Общие имена (домены)"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_ISSUER"
msgid "Issued By"
msgstr "Выдан"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_ERR_DATE_INVALID_HEAD"
msgid "Unknown Validity"
msgstr "Неизвестный сайт"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_ERR_DATE_INVALID"
msgid "The SSL/TLS certificate lacks valid from/to dates, making it impossible to determine whether it is valid."
msgstr "В сертификате SSL/TLS отсутствуют даты начала и окончания действия, что делает невозможным определение его действительности."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_TOOSOON_HEAD"
msgid "Invalid (Too Soon)"
msgstr "Недействителен (слишком рано)"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_TOOSOON"
msgid "The SSL/TLS certificate has a Valid From date in the future. Browsers will report it as invalid as it\'s not meant to be used just yet."
msgstr "Дата начала действия сертификата SSL/TLS находится в будущем. Браузеры будут сообщать о его недействительности, поскольку он ещё не предназначен для использования."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_EXPIRING_HEAD"
msgid "Imminent Expiration"
msgstr "Скорое истечение срока действия"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_EXPIRING"
msgid "The SSL/TLS certificate will expire soon. You need to replace it with a new one to prevent problems with your site."
msgstr "Срок действия сертификата SSL/TLS скоро истечёт. Необходимо заменить его на новый, чтобы избежать проблем с сайтом."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_EXPIRED_HEAD"
msgid "Expired"
msgstr "Срок действия истёк"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_EXPIRED"
msgid "The SSL/TLS certificate has a Valid To date in the past. Browsers will report it as invalid as it\'s not meant to be used any more."
msgstr "Дата окончания действия сертификата SSL/TLS находится в прошлом. Браузеры будут сообщать о его недействительности, поскольку он более не предназначен для использования."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_INVALID_CN_HEAD"
msgid "Invalid Domain"
msgstr "Недействительный домен"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_INVALID_CN"
msgid "The SSL/TLS certificate is issued for a different domain name than the one you are using it for. Browsers will report it as invalid."
msgstr "Сертификат SSL/TLS выдан для другого доменного имени. Браузеры будут сообщать о его недействительности."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_INVALID_SIG_HEAD"
msgid "Invalid or Self-signed Certificate"
msgstr "Недействительный или самоподписанный сертификат"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_SSLTLS_INVALID_SIG"
msgid "The signature of your SSL/TLS certificate cannot be verified against the Certification Authorities known to the server. This usually means that you are using a self-signed certificate which will be rejected by browsers."
msgstr "Подпись вашего сертификата SSL/TLS не может быть проверена по центрам сертификации, известным серверу. Обычно это означает, что используется самоподписанный сертификат, который будет отклонён браузерами."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO"
msgid "Domain Information"
msgstr "Информация о домене"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_ERR_DATE_INVALID_HEAD"
msgid "Unknown Validity"
msgstr "Неизвестный срок действия"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_ERR_DATE_INVALID"
msgid "We could not retrieve the domain\'s expiration date. Either the domain name does not appear in the WHOIS database, or you are using a domain name which only resolves locally."
msgstr "Не удалось получить дату истечения срока регистрации домена. Возможно, доменное имя отсутствует в базе данных WHOIS или используется доменное имя, которое разрешается только локально."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_TOOSOON_HEAD"
msgid "Invalid (Too Soon)"
msgstr "Недействителен (слишком рано)"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_TOOSOON"
msgid "The domain registrar claims the domain name was registered in a future date. This does not seem right."
msgstr "Регистратор домена утверждает, что доменное имя было зарегистрировано в будущей дате. Это выглядит подозрительно."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_EXPIRING_HEAD"
msgid "Imminent Expiration"
msgstr "Скорое истечение срока"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_EXPIRING"
msgid "The domain name will expire soon. You need to renew it with your registrar to avoid losing it."
msgstr "Срок регистрации доменного имени скоро истечёт. Необходимо продлить его у регистратора, чтобы не потерять домен."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_EXPIRED_HEAD"
msgid "Expired"
msgstr "Срок истёк"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_EXPIRED"
msgid "The domain name has expired. You might still be able to access the domain due to your registrar\'s grace period, but <strong>you must renew this domain name immediately with your registrar</strong> to avoid losing it."
msgstr "Срок регистрации доменного имени истёк. Возможно, домен ещё доступен благодаря льготному периоду регистратора, но <strong>необходимо немедленно продлить его у регистратора</strong>, чтобы не потерять домен."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_NONAMESERVERS_HEAD"
msgid "Missing nameservers"
msgstr "Отсутствуют серверы имён"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_NONAMESERVERS"
msgid "There are no nameservers reported in the WHOIS database. A site without valid nameservers will not be accessible on the Internet. If you recently assigned nameservers to the domain don\'t panic; it may take up to 5 days for this information to propagate."
msgstr "В базе данных WHOIS не указаны серверы имён. Сайт без действующих серверов имён будет недоступен в Интернете. Если вы недавно назначили серверы имён домену, не беспокойтесь — распространение этой информации может занять до 5 дней."

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_TABLE_CAPTION"
msgid "Table of domain information"
msgstr "Таблица информации о домене"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_DOMAIN"
msgid "Domain"
msgstr "Домен"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_REGISTERED"
msgid "Registered On"
msgstr "Дата регистрации"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_EXPIRES"
msgid "Expires On"
msgstr "Дата истечения срока"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_REGISTRAR"
msgid "Registrar"
msgstr "Регистратор"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_NAMESERVERS"
msgid "Nameservers"
msgstr "Серверы имён"

#, phpformat
msgctxt "PANOPTICON_MAIN_SITES_LBL_WHOISINFO_CACHING_NOTICE"
msgid "Domain registration information may be cached in the WHOIS servers for a period ranging from a few hours to a few days. As a result, the information above may be out of date."
msgstr "Информация о регистрации домена может кэшироваться на серверах WHOIS в течение нескольких часов или дней. В связи с этим приведённые сведения могут быть устаревшими."

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_UPTIME_TITLE"
msgid "Very Basic Site Uptime Monitoring"
msgstr "Базовый мониторинг доступности сайта"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_UPTIME_NOTE"
msgid "This is <em>very basic</em> uptime monitoring through Panopticon itself. It only notifies you by email when your site goes down and comes back up. It does not integrate with third party services, it does not offer history, it does not have a public uptime page. We strongly recommend using a third party service or software to monitor your sites\' uptime instead of using this feature."
msgstr "Это <em>очень базовый</em> мониторинг доступности через сам Panopticon. Он только отправляет уведомления по электронной почте, когда сайт становится недоступным или восстанавливается. Не интегрируется со сторонними сервисами, не предоставляет историю, не имеет публичной страницы доступности. Настоятельно рекомендуется использовать сторонний сервис или программное обеспечение."

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_UPTIME_ENABLED"
msgid "Monitor Uptime"
msgstr "Мониторинг доступности"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_UPTIME_ENABLED_HELP"
msgid "Disabling this option will no longer send you emails, log site actions, or display badges when your site goes down and comes back up."
msgstr "Отключение этого параметра прекратит отправку писем, запись действий сайта и отображение значков при недоступности сайта и его восстановлении."

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_UPTIME_PATH"
msgid "URL Path To Monitor"
msgstr "URL-путь для мониторинга"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_UPTIME_STRING"
msgid "Look For This String"
msgstr "Искать эту строку"

#, phpformat
msgctxt "PANOPTICON_SITES_FIELD_CONFIG_UPTIME_STRING_HELP"
msgid "The site will be considered up if the page contains this string. Do <em>NOT</em> use HTML; all tags and multiple whitespaces are removed before evaluating this string. Leave blank to consider any HTTP 2xx response as adequate proof the site is up."
msgstr "Сайт будет считаться доступным, если страница содержит эту строку. <em>НЕ</em> используйте HTML — все теги и лишние пробелы удаляются перед проверкой. Оставьте пустым, чтобы считать любой ответ HTTP 2xx подтверждением доступности сайта."

#, phpformat
msgctxt "PANOPTICON_SITES_BATCH_TITLE"
msgid "Batch process the selected sites"
msgstr "Пакетная обработка выбранных сайтов"

#, phpformat
