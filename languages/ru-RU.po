msgid "Fixed Code"
msgstr "Фиксированный код"

#, phpformat
msgctxt "PANOPTICON_MFA_FIXED_LBL_SHORTINFO"
msgid "Choose your own preset code, essentially a second password. <strong>For demonstration purposes only - this is disabled in production</strong>."
msgstr "Выберите собственный предустановленный код — по сути, второй пароль. <strong>Только для демонстрации.</strong>"

#, phpformat
msgctxt "PANOPTICON_MFA_FIXED_LBL_LABEL"
