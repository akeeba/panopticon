# Template for tests/.env.test
#
# Copy this file to .env.test in the repository root and fill in real values.
# The actual .env.test file is gitignored (it must contain real credentials and
# must point at a DEDICATED throwaway database — never a production DB).
#
# The phpunit bootstrap will refuse to run if PANOPTICON_DBNAME below matches
# the dbname defined in the local config.php (production sanity guard).
#
# Keys mirror the live env loader in src/Application/Configuration.php.

PANOPTICON_DBDRIVER=mysqli
PANOPTICON_DBHOST=127.0.0.1
PANOPTICON_DBPORT=3306
PANOPTICON_DBUSER=panopticon_test
PANOPTICON_DBPASS=changeme
PANOPTICON_DBNAME=panopticon_test
PANOPTICON_PREFIX=pnptctest_
PANOPTICON_DBENCRYPTION=false

# Application secret used for HMAC operations (API tokens, etc).
# MUST be a non-empty string. Generate with: openssl rand -hex 32
PANOPTICON_SECRET=test-secret-do-not-use-in-prod
